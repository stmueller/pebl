##  PEBL ScaleRunner - Unified Psychological Scale Administration System
##
##  This system provides a single, extensible platform for running psychological
##  questionnaires and scales using JSON-based scale definitions.
##
##  Features:
##  - Multiple question types: Likert, VAS, Grid, Text, Multiple Choice
##  - Reverse coding and composite scoring
##  - Automatic report generation
##  - Multi-language support via translations
##  - LSL integration for event markers
##  - Upload support for online deployment
##
##  Usage:
##    bin/pebl2 battery/scales/ScaleRunner.pbl -s P001
##    bin/pebl2 battery/scales/ScaleRunner.pbl -s P001 --pfile ABCD.pbl.par.json

##
##  See doc/SCALERUNNER_DESIGN.md for complete documentation
##

##  Some online sources for scales:
##  http://psychology-tools.com
##  https://scales.arabpsychology.com/
##  https://www.psytoolkit.org/survey-library/
##  https://www.apa.org/pubs/databases/psyctests/
##  https://psytests.org/en.html
##############################################################################
## HELPER FUNCTIONS (not in standard library)
##############################################################################

define ReadJSON(filename)
{
  ## Read JSON file and return parsed object
  obj <- 0
  jsonText <- FileReadText(filename)

  if(StringLength(jsonText) > 0)
  {
    obj <- ParseJSON(jsonText)
  } else {
    Print("ERROR: FileReadText returned empty string for: " + filename)
  }

  return(obj)
}

define ShuffleByGroup(questions)
{
  ## Shuffle questions within randomization groups.
  ## Group 0 = fixed (opted out of shuffling) — the default for all items.
  ## Group 1+ = shuffle within that numbered group when shuffle_questions is active.
  ## Items must explicitly set random_group >= 1 to participate in shuffling.

  result <- questions

  if(Length(questions) > 0)
  {
    ## Build parallel list of group IDs
    indices <- Sequence(1, Length(questions), 1)
    groupList <- []
    loop(i, indices)
    {
      q <- Nth(questions, i)
      if(PropertyExists(q, "random_group"))
      {
        PushOnEnd(groupList, q.random_group)
      } else {
        PushOnEnd(groupList, 0)  ## default: fixed (not part of any shuffle group)
      }
    }

    ## Group indices by group ID using ListBy
    grouped <- ListBy(indices, groupList)
    uniqueGroups <- First(grouped)
    indexLists <- Second(grouped)

    ## Build shuffled mapping for each non-zero group
    shuffledMap <- MakeCustomObject("shuffled")
    loop(pair, Transpose([uniqueGroups, indexLists]))
    {
      grp <- First(pair)
      grpIndices <- Second(pair)
      if(grp > 0)
      {
        shuffled <- Shuffle(grpIndices)

        loop(j, Sequence(1, Length(grpIndices), 1))
        {
          origIdx <- Nth(grpIndices, j)
          newIdx <- Nth(shuffled, j)
          SetProperty(shuffledMap, origIdx + "", Nth(questions, newIdx))
        }
      }
    }

    ## Build result: fixed items stay, grouped items use shuffled mapping
    result <- []
    loop(i, indices)
    {
      if(PropertyExists(shuffledMap, i + ""))
      {
        PushOnEnd(result, GetProperty(shuffledMap, i + ""))
      } else {
        PushOnEnd(result, Nth(questions, i))
      }
    }
  }

  return(result)
}


##############################################################################
## SECTION ORDER RANDOMIZATION (S4)
##############################################################################

define ShuffleSectionOrder(questions, randomizeDef)
{
  ## Reorganize the flat question list by shuffling section order while
  ## keeping "fixed" sections (listed in randomizeDef.fixed) in place.
  ## Items before the first section marker (preamble) always stay first.

  ## Step 1: Split into preamble + list of [marker, [items]] groups
  preamble <- []
  realSections <- []
  currentItems <- []
  currentMarker <- 0
  hitSection <- 0

  loop(q, questions)
  {
    if(q.type == "section")
    {
      if(hitSection)
      {
        PushOnEnd(realSections, [currentMarker, currentItems])
      } else {
        preamble <- currentItems
        hitSection <- 1
      }
      currentMarker <- q
      currentItems <- []
    } else {
      PushOnEnd(currentItems, q)
    }
  }

  ## Default: return unchanged if no section markers found
  flatList <- questions

  if(hitSection)
  {
    ## Save last group
    PushOnEnd(realSections, [currentMarker, currentItems])

    ## Step 2: Get fixed IDs
    fixedIds <- []
    if(PropertyExists(randomizeDef, "fixed"))
    {
      fixedIds <- randomizeDef.fixed
    }

    ## Step 3: Mark each section as fixed or free; collect free sections
    n <- Length(realSections)
    isFixedFlags <- []
    freeSections <- []

    loop(i, Sequence(1, n, 1))
    {
      sec <- Nth(realSections, i)
      marker <- First(sec)
      secId <- marker.id
      isThisFixed <- 0
      loop(fid, fixedIds)
      {
        if(fid == secId)
        {
          isThisFixed <- 1
        }
      }
      PushOnEnd(isFixedFlags, isThisFixed)
      if(not isThisFixed)
      {
        PushOnEnd(freeSections, sec)
      }
    }

    ## Step 4: Shuffle free sections
    shuffledFree <- Shuffle(freeSections)

    ## Step 5: Rebuild ordered list — fixed sections stay, free slots filled from shuffle
    reordered <- []
    freeIdx <- 1
    loop(i, Sequence(1, n, 1))
    {
      if(Nth(isFixedFlags, i))
      {
        PushOnEnd(reordered, Nth(realSections, i))
      } else {
        PushOnEnd(reordered, Nth(shuffledFree, freeIdx))
        freeIdx <- freeIdx + 1
      }
    }

    ## Step 6: Flatten back to question list
    flatList <- preamble
    loop(sec, reordered)
    {
      PushOnEnd(flatList, First(sec))
      loop(item, Second(sec))
      {
        PushOnEnd(flatList, item)
      }
    }
  }

  return(flatList)
}


##############################################################################
## PER-SECTION QUESTION RANDOMIZATION (C5) + RANDOM_GROUP SHUFFLING (C2/S4)
##
## Two complementary mechanisms, dispatched per section:
##
## 1. Section marker randomize.method=shuffle (ShuffleSectionItemsFixed):
##    All items in the section are shuffled into ONE pool.
##    Pinned items: random_group=0 on the item, OR listed in randomize.fixed.
##    random_group grouping (1, 2, 3...) is NOT used — all non-pinned items
##    form a single shuffle pool.
##
## 2. Scale-level shuffle_questions (ShuffleByGroup):
##    Items are shuffled within their random_group number.
##    Group 0 = fixed. Groups 1, 2, 3... shuffle independently within section.
##    Items without random_group: inst and visible_when items -> 0 (fixed);
##    all other items -> 1 (shuffled).
##
## When a section has randomize, ShuffleSectionItemsFixed is used for that
## section; ShuffleByGroup is skipped.
##############################################################################

define ShuffleSectionItemsFixed(items, fixedIds)
{
  ## Shuffle questions in a section's item list.
  ## Items whose id appears in fixedIds (a list of strings) stay in their
  ## original positions; all other items are shuffled.
  ## Also keeps section markers (type=="section") fixed automatically.

  n <- Length(items)

  ## Classify each position as fixed or free
  freeItems <- []
  freeFlags <- []  ## parallel to items: 1=free, 0=fixed

  loop(i, Sequence(1, n, 1))
  {
    item <- Nth(items, i)
    isFixed <- 0

    ## Section sub-markers are never shuffled
    if(PropertyExists(item, "type"))
    {
      if(item.type == "section")
      {
        isFixed <- 1
      }
    }

    ## Check random_group: 0 (pins item regardless of which shuffle mechanism is active)
    if(not isFixed)
    {
      if(PropertyExists(item, "random_group"))
      {
        if(item.random_group == 0)
        {
          isFixed <- 1
        }
      }
    }

    ## Check explicit fixed list (convenience alternative to random_group: 0)
    if(not isFixed)
    {
      loop(fid, fixedIds)
      {
        if(PropertyExists(item, "id"))
        {
          if(item.id == fid)
          {
            isFixed <- 1
          }
        }
      }
    }

    if(isFixed)
    {
      PushOnEnd(freeFlags, 0)
    } else {
      PushOnEnd(freeFlags, 1)
      PushOnEnd(freeItems, item)
    }
  }

  ## Shuffle the free items
  shuffledFree <- Shuffle(freeItems)

  ## Reconstruct: fixed positions keep original item; free positions get next shuffled item
  result <- []
  freeIdx <- 1

  loop(i, Sequence(1, n, 1))
  {
    if(Nth(freeFlags, i))
    {
      PushOnEnd(result, Nth(shuffledFree, freeIdx))
      freeIdx <- freeIdx + 1
    } else {
      PushOnEnd(result, Nth(items, i))
    }
  }

  return(result)
}


define FlushSection(items, sectionMarker, doGroupShuffle)
{
  ## Return items for one section after applying the appropriate shuffle:
  ##   - If the marker has randomize.method=shuffle: use ShuffleSectionItemsFixed
  ##     (one shuffle pool; items with random_group=0 or listed in fixed are pinned).
  ##   - Else if doGroupShuffle: apply random_group-based ShuffleByGroup
  ##     (multiple independent pools by group number).
  ##   - Otherwise return unchanged.

  result <- items

  if(doGroupShuffle)
  {
    if(PropertyExists(sectionMarker, "randomize"))
    {
      rdm <- sectionMarker.randomize
      if(PropertyExists(rdm, "method"))
      {
        if(rdm.method == "shuffle")
        {
          fixedIds <- []
          if(PropertyExists(rdm, "fixed"))
          {
            fixedIds <- rdm.fixed
          }
          result <- ShuffleSectionItemsFixed(items, fixedIds)
        }
      }
    } else {
      result <- ShuffleByGroup(items)
    }
  }

  return(result)
}


define ApplyAllQuestionRandomization(questions, doGroupShuffle)
{
  ## Single-pass handler for both per-section randomize and random_group shuffling.
  ## Per section: if the section marker has randomize, use ShuffleSectionItemsFixed
  ## (random_group: 0 and the fixed list both pin items; all others form one pool).
  ## Otherwise use ShuffleByGroup when doGroupShuffle is true
  ## (items shuffle within their random_group number independently).

  result <- []
  preamble <- []
  currentMarker <- 0
  currentItems <- []
  inSection <- 0

  loop(q, questions)
  {
    if(q.type == "section")
    {
      if(inSection)
      {
        ## Flush previous section with appropriate shuffling
        PushOnEnd(result, currentMarker)
        sectionItems <- FlushSection(currentItems, currentMarker, doGroupShuffle)
        loop(item, sectionItems)
        {
          PushOnEnd(result, item)
        }
      } else {
        ## Flush preamble — treated as a section with no marker (only group-shuffle applies)
        preambleItems <- preamble
        if(doGroupShuffle)
        {
          preambleItems <- ShuffleByGroup(preamble)
        }
        loop(item, preambleItems)
        {
          PushOnEnd(result, item)
        }
      }
      currentMarker <- q
      currentItems <- []
      inSection <- 1
    } else {
      if(inSection)
      {
        PushOnEnd(currentItems, q)
      } else {
        PushOnEnd(preamble, q)
      }
    }
  }

  ## Flush final section or preamble
  if(inSection)
  {
    PushOnEnd(result, currentMarker)
    sectionItems <- FlushSection(currentItems, currentMarker, doGroupShuffle)
    loop(item, sectionItems)
    {
      PushOnEnd(result, item)
    }
  } else {
    preambleItems <- preamble
    if(doGroupShuffle)
    {
      preambleItems <- ShuffleByGroup(preamble)
    }
    loop(item, preambleItems)
    {
      PushOnEnd(result, item)
    }
  }

  return(result)
}


##############################################################################
## BRANCH GROUP SELECTION (A1)
##############################################################################

define SelectBranchArms(scaleDef)
{
  ## For each branch group in scaleDef.branches, selects one arm and
  ## records which sections to exclude (those belonging to unchosen arms).
  ## Returns the list of excluded section IDs.
  ##
  ## Methods: "random" (default) — uniform random; "parameter" — arm id
  ## matches a named gParams value; "balanced" — not yet implemented
  ## (falls through to random).

  excludedSectionIds <- []

  if(PropertyExists(scaleDef, "branches"))
  {
  loop(branchGroup, scaleDef.branches)
  {
    if(not PropertyExists(branchGroup, "arms"))
    {
      ## Skip malformed group
    } else {

    arms <- branchGroup.arms
    nArms <- Length(arms)

    if(nArms > 0)
    {
      ## Determine the chosen arm based on the branch method.
      chosenArm <- Nth(arms, RandomDiscrete(nArms))  ## default: random

      ## "parameter" method: pick the arm whose id matches a param value
      if(PropertyExists(branchGroup, "method"))
      {
        if(branchGroup.method == "parameter" and PropertyExists(branchGroup, "parameter"))
        {
          pName <- branchGroup.parameter
          if(PropertyExists(gParams, pName))
          {
            pVal <- GetProperty(gParams, pName) + ""
            loop(arm, arms)
            {
              if(arm.id + "" == pVal)
              {
                chosenArm <- arm
              }
            }
          }
        }
      }

      ## Record choice in global for data logging
      SetProperty(gBranchChoices, branchGroup.id, chosenArm.id)

      ## Collect all section IDs that appear in any arm of this group
      allGroupSections <- []
      loop(arm, arms)
      {
        if(PropertyExists(arm, "sections"))
        {
          loop(sid, arm.sections)
          {
            alreadyIn <- 0
            loop(existing, allGroupSections)
            {
              if(existing == sid)
              {
                alreadyIn <- 1
              }
            }
            if(not alreadyIn)
            {
              PushOnEnd(allGroupSections, sid)
            }
          }
        }
      }

      ## Sections in this group but not in chosen arm are excluded
      chosenSections <- []
      if(PropertyExists(chosenArm, "sections"))
      {
        chosenSections <- chosenArm.sections
      }

      loop(sid, allGroupSections)
      {
        inChosen <- 0
        loop(cs, chosenSections)
        {
          if(cs == sid)
          {
            inChosen <- 1
          }
        }
        if(not inChosen)
        {
          PushOnEnd(excludedSectionIds, sid)
        }
      }
    }

    } ## end arms-exists check
  }
  } ## end branches-exist check

  return(excludedSectionIds)
}


define FilterExcludedSections(questions, excludedSectionIds)
{
  ## Remove sections and their items from the question list.
  ## Sections not referenced by any branch group are always included.
  ## Items before the first section marker (preamble) are always included.

  filtered <- questions

  if(Length(excludedSectionIds) > 0)
  {
    filtered <- []
    currentSectionExcluded <- 0

    loop(q, questions)
    {
      if(q.type == "section")
      {
        isExcluded <- 0
        loop(eid, excludedSectionIds)
        {
          if(eid == q.id)
          {
            isExcluded <- 1
          }
        }
        currentSectionExcluded <- isExcluded
        if(not isExcluded)
        {
          PushOnEnd(filtered, q)
        }
      } else {
        if(not currentSectionExcluded)
        {
          PushOnEnd(filtered, q)
        }
      }
    }
  }

  return(filtered)
}


define QuoteCSVField(field)
{
  ## Properly quote a CSV field if it contains commas, quotes, or newlines
  ## Follows RFC 4180 CSV standard for field quoting

  fieldStr <- field + ""  ## Convert to string
  result <- fieldStr  ## Default: return unmodified

  ## Check if field contains comma, quote, or newline that requires quoting
  needsQuoting <- 0
  if(FindInString(fieldStr, ",", 1) > 0 or FindInString(fieldStr, CR(1), 1) > 0 or FindInString(fieldStr, gQuote, 1) > 0)
  {
    needsQuoting <- 1
  }

  if(needsQuoting)
  {
    ## Escape internal quotes by doubling them (RFC 4180)
    doubleQuote <- gQuote + gQuote
    escapedField <- ReplaceChar(fieldStr, gQuote, doubleQuote)
    ## Wrap in quotes using gQuote
    result <- gQuote + escapedField + gQuote
  }

  return(result)
}

define ShowFormattedMessage(messageText, win)
{
  ## Display a formatted HTML message and wait for click
  ## Similar to MessageBox but supports HTML formatting

  ## Create formatted TextBox in center of screen
  boxWidth <- 800
  boxHeight <- 400
  boxX <- (gVideoWidth - boxWidth)/2
  boxY <- (gVideoHeight - boxHeight)/2

  msgBox <- MakeTextBoxWithBorder(messageText, gQuestFont, boxWidth, boxHeight, boxX, boxY)

  ## Create OK button below message
  buttonY <- boxY + boxHeight + 60
  okButton <- MakeScaleButton("OK", gVideoWidth/2, buttonY, 150, 50)

  Draw()

  ## Wait for click
  WaitForClickOnTarget([okButton.border], [1])

  ## Cleanup
  RemoveObject(msgBox.border, gWin)
  RemoveObject(msgBox.textbox, gWin)
  RemoveObject(okButton.border, gWin)
  RemoveObject(okButton.label, gWin)

  return(1)
}


##############################################################################
## PARAMETER / ANSWER SUBSTITUTION HELPERS  (S2 / S3)
##############################################################################

## Build [["{key}", value], ...] replist from a params object.
## Used to pre-process gStrings once at startup.
define BuildParamReplist(params)
{
  replist <- []
  loop(key, GetPropertyList(params))
  {
    val <- GetProperty(params, key)
    ## GetPropertyList returns keys uppercased; OSD substitution tokens use lowercase
    replist <- Append(replist, ["{" + Lowercase(key) + "}", val + ""])
  }
  return(replist)
}

## Return a new strings object with all {param_name} patterns replaced.
## Applied once after GetStrings so every subsequent GetProperty already
## has param values embedded.
define PreprocessStrings(strings, replist)
{
  processed <- MakeCustomObject("processed_strings")
  loop(key, GetPropertyList(strings))
  {
    val <- GetProperty(strings, key)
    if(IsString(val))
    {
      SetProperty(processed, key, SubstituteStrings(val, replist))
    } else {
      SetProperty(processed, key, val)
    }
  }
  return(processed)
}

## Build question-id -> alias_name map from scale definition.
## gAliasMap[question_id] = alias_name
define BuildAliasMap(scaleDef)
{
  aliasMap <- MakeCustomObject("alias_map")
  loop(qdef, scaleDef.items)
  {
    if(PropertyExists(qdef, "answer_alias"))
    {
      SetProperty(aliasMap, qdef.id, qdef.answer_alias)
    }
  }
  return(aliasMap)
}

## Substitute {answer.id} and {answer.alias} patterns in text using the
## current global response map.  Called on each question text at display
## time so newly recorded answers are always visible.
define PipeAnswers(text)
{
  replist <- []
  loop(key, GetPropertyList(gResponseMap))
  {
    val <- GetProperty(gResponseMap, key)
    replist <- Append(replist, ["{answer." + key + "}", val + ""])
    ## If this question has an alias also provide the alias form
    if(PropertyExists(gAliasMap, key))
    {
      alias <- GetProperty(gAliasMap, key)
      replist <- Append(replist, ["{answer." + alias + "}", val + ""])
    }
  }
  return(SubstituteStrings(text, replist))
}


define Start(p)
{
  ##############################################################################
  ## PARAMETER SETUP
  ##############################################################################

  parpairs <- [["scale", "sample"],
               ["shuffle_questions", 0],
               ["show_header", 1]]

  gParams <- CreateParameters(parpairs, gParamFile)
  gShowTitle <- gParams.show_header

  ##############################################################################
  ## LOAD SCALE DEFINITION
  ##############################################################################

  gScaleDef <- LoadScaleDefinition(gParams.scale)

  if(gScaleDef == 0)
  {
    SignalFatalError("Failed to load scale definition for: " + gParams.scale)
  }

  ## Merge scale-specific parameters into gParams
  MergeScaleParameters(gScaleDef)

  ##############################################################################
  ## INITIALIZATION
  ##############################################################################

  gSleepEasy <- 1
  gWin <- MakeWindow("grey10")

  InitializeLSL(gWin)
  InitializeUpload()

  if(gSubNum+"" == "0")
  {
    gSubNum <- GetSubNum(gWin)
  }

  ## Load translations for this scale
  GetStrings(gLanguage, gScaleDef.scale_info.code)

  ## Load ScaleRunner UI chrome strings (runner-level, not scale-specific)
  LoadRunnerStrings(gLanguage)

  ## S2: Pre-process strings — substitute {param_name} patterns once at startup
  gParamReplist <- BuildParamReplist(gParams)
  gStrings <- PreprocessStrings(gStrings, gParamReplist)

  ## S3: Build alias map and initialise global response map for answer piping
  gAliasMap <- BuildAliasMap(gScaleDef)
  gResponseMap <- MakeCustomObject("response_map")

  ## Create color theme
  gTheme <- CreateColorTheme()

  ## Create fonts using theme colors (font background should be transparent for labels)
  gQuestFont <- MakeFont(gPEBLBaseFont, 0, 35, gTheme.instructionText, gTheme.textboxBg, 0)
  gSmallFont <- MakeFont(gPEBLBaseFont, 0, 18, gTheme.questionText, gTheme.windowBg, 0)
  gHeadFont <- MakeFont(gPEBLBaseFont, 0, 32, gTheme.questionText, gTheme.windowBg, 0)
  gItemFont <- MakeFont(gPEBLBaseFont, 0, 48, gTheme.questionText, gTheme.windowBg, 0)
  gVASLabelFont <- MakeFont(gPEBLBaseFont, 0, 24, gTheme.questionText, gTheme.windowBg, 0)
  gDoneFont <- MakeFont(gPEBLBaseFontMono, 0, 28, gTheme.buttonText, gTheme.windowBg, 0)
  gHeaderFont <- MakeFont(gPEBLBaseFont, 1, 28, gTheme.headerText, gTheme.headerBg, 0)
  gLikertNumFont <- MakeFont(gPEBLBaseFont, 0, 35, gTheme.likertNumber, gTheme.windowBg, 0)
  gLikertLabelFont <- MakeFont(gPEBLBaseFont, 0, 18, gTheme.likertLabel, gTheme.windowBg, 0)

  ## Create layout with zones (using Layout.pbl system)
  gParams.responsemode <- "none"  ## No response mode needed for questionnaires
  gLayout <- CreateLayout("scales", gWin, gParams)

  ## Create branding elements
  CreateBranding()

  ## Create output directory
  MakeDirectory("data")

  ##############################################################################
  ## CREATE DATA FILES
  ##############################################################################

  ## Build dynamic column header with dimension names
  columnHeader <- "subnum,order,timestamp,question_id,text_key,question_text,response,rt"

  ## Add dimension columns dynamically
  if(PropertyExists(gScaleDef, "dimensions"))
  {
    loop(dim, gScaleDef.dimensions)
    {
      columnHeader <- columnHeader + "," + dim.id
    }
  }

  ## Add transformed dimension columns for dims that have a transform defined
  if(PropertyExists(gScaleDef, "dimensions") and PropertyExists(gScaleDef, "scoring"))
  {
    loop(dim, gScaleDef.dimensions)
    {
      if(PropertyExists(gScaleDef.scoring, dim.id))
      {
        dimScoreDef <- GetProperty(gScaleDef.scoring, dim.id)
        if(PropertyExists(dimScoreDef, "transform"))
        {
          columnHeader <- columnHeader + "," + dim.id + "_t"
        }
      }
    }
  }

  gFileOut <- GetNewDataFile(gSubNum, gWin, gScaleDef.scale_info.code, "csv", columnHeader)

  dir <- GetDirectory(gFileOut.filename) + "../"
  safeCode <- ReplaceChar(gScaleDef.scale_info.code, [" ", "/", "\", ":", ",", "|"], "_")
  pooledFilename <- safeCode + "-pooled.csv"
  pooledPath <- dir + pooledFilename

  ## Always build header from scale definition
  pooledHeader <- BuildPooledHeader(gScaleDef)

  if(FileExists(pooledPath))
  {
    gPooledFile <- FileOpenAppend(pooledPath)
  } else {
    gPooledFile <- FileOpenWrite(pooledPath)
    FilePrint(gPooledFile, pooledHeader)
  }

  ##############################################################################
  ## RUN SCALE
  ##############################################################################

  gStartTime <- GetTime()

  results <- RunScale(gScaleDef)

  gEndTime <- GetTime()
  gCompletionTime <- gEndTime - gStartTime  ## milliseconds

  ##############################################################################
  ## COMPUTE SCORES
  ##############################################################################

  scoreResult       <- ComputeScores(results, gScaleDef)
  scores            <- First(scoreResult)
  transformedScores <- Second(scoreResult)
  scores.completion_time <- gCompletionTime

  ## Compute computed variables (S7)
  responseMap <- BuildResponseMap(results)
  computedVars <- ComputeComputedVars(gScaleDef, scores, transformedScores, responseMap)

  ##############################################################################
  ## SAVE DATA
  ##############################################################################

  SaveIndividualData(results, transformedScores, gScaleDef)
  pooledLine <- SavePooledData(results, scores, transformedScores, gScaleDef)

  FileClose(gFileOut)
  FileClose(gPooledFile)

  ##############################################################################
  ## GENERATE REPORT
  ##############################################################################

  reportFile <- GenerateReport(results, scores, transformedScores, gScaleDef, computedVars)

  ##############################################################################
  ## UPLOAD
  ##############################################################################

  UploadFile(gSubNum, gFileOut.filename)
  UploadFile(gSubNum, reportFile.filename)

  ## Append pooled line to shared server-side file.
  ## UploadLine appends one line at a time with file locking, so the server
  ## maintains a single shared pooled file across all participants.
  UploadLine(gSubNum, pooledFilename, pooledHeader, pooledLine)

  FinalizeLSL()

  ## Display completion message — gate termination takes priority over debrief
  if(PropertyExists(results, "gateTriggered") and results.gateTriggered)
  {
    ShowFormattedMessage(results.gateMessage, gWin)
  } else {
    if(PropertyExists(gStrings, "debrief"))
    {
      ShowFormattedMessage(gStrings.debrief, gWin)
    } else {
      ## Default completion message if no debrief provided
      ShowFormattedMessage("Thank you for completing this questionnaire.", gWin)
    }
  }
}


##############################################################################
## COLOR THEME SYSTEM
##############################################################################

define CreateColorTheme()
{
  ## Centralized color theme - edit here to try different schemes
  theme <- MakeCustomObject("ColorTheme")

  ## Background colors
  theme.windowBg <- MakeColor("grey10")
  theme.headerBg <- MakeColor("grey18")        ## Charcoal strip (was navy)
  theme.textboxBg <- MakeColor("grey8")        ## Near-black text areas (was white)
  theme.textboxBorder <- MakeColor("grey24")   ## Subtle edge on text areas
  theme.buttonBg <- MakeColor("grey22")        ## Dark button (was lightgrey)
  theme.buttonBorder <- MakeColor("grey33")    ## Subtle button border

  ## Text colors
  theme.headerText <- MakeColor("white")
  theme.instructionText <- MakeColor("grey88") ## Light text in dark text areas (was black)
  theme.questionText <- MakeColor("white")
  theme.buttonText <- MakeColor("grey88")      ## Light text on dark button (was black)
  theme.likertNumber <- MakeColor("white")
  theme.likertLabel <- MakeColor("grey82")     ## Slight de-emphasis vs. numbers

  ## Accent — single neutral tone for progress label and separator line
  theme.accent1 <- MakeColor("grey50")
  theme.accent2 <- MakeColor("grey50")
  theme.accent3 <- MakeColor("grey50")

  ## Response option colors
  theme.optionBg <- MakeColor("grey14")        ## Dark option areas (was white)
  theme.optionBorder <- MakeColor("grey22")    ## Very subtle border (was grey60)
  theme.optionText <- MakeColor("white")       ## Light text on dark option

  return(theme)
}


##############################################################################
## BRANDING AND VISUAL DESIGN
##############################################################################

define CreateBranding()
{
  ## Calculate combined header+subheader region
  headerTop <- gLayout.zones.header.y
  subheaderBottom <- gLayout.zones.subheader.y + gLayout.zones.subheader.height
  combinedHeight <- subheaderBottom - headerTop
  combinedCenterY <- headerTop + combinedHeight/2

  ## Single thin horizontal separator below the header band
  gAccentLine1 <- Line(0, subheaderBottom, gVideoWidth, 0, MakeColor("grey32"))
  AddObject(gAccentLine1, gWin)

  ## Scale title in header (replace Layout's default label with a formatted TextBox
  ## so we can show both the scale name <h1> and active section title <h2>)
  if(PropertyExists(gScaleDef, "scale_info"))
  {
    ## Use display_title if provided, otherwise use scale name
    gScaleName <- gScaleDef.scale_info.name
    if(PropertyExists(gStrings, "display_title"))
    {
      customTitle <- GetProperty(gStrings, "display_title")
      if(StringLength(customTitle) > 0)
      {
        gScaleName <- customTitle
      }
    }

    ## Add header background covering header+subheader zones
    gHeaderBar <- Rectangle(gVideoWidth/2, combinedCenterY, gVideoWidth, combinedHeight, gTheme.headerBg, 1)
    AddObject(gHeaderBar, gWin)

    ## Replace the layout's plain Label with a formatted TextBox.
    ## Base font 10px: <h1>=23px, <h2>=20px — both fit in the combined banner (~75px).
    ## TextBox is upper-left anchored, so position it at the top of the banner.
    RemoveObject(gLayout.header, gWin)
    headerBoxFont <- MakeFont(gPEBLBaseFont, 0, 10, gTheme.headerText, gTheme.headerBg, 0)
    headerBoxWidth <- Round(gVideoWidth * 0.85)
    gScaleHeaderBox <- MakeTextBox("", headerBoxFont, headerBoxWidth, combinedHeight)
    gScaleHeaderBox.formatted <- 1
    gScaleHeaderBox.isadaptive <- 0
    AddObject(gScaleHeaderBox, gWin)
    Move(gScaleHeaderBox, (gVideoWidth - headerBoxWidth)/2, headerTop)

    ## Set initial text — scale name only (if showtitle=1), no section yet
    if(gShowTitle)
    {
      gScaleHeaderBox.text <- "<h1=center>" + gScaleName + "</h1>"
    } else {
      gScaleHeaderBox.text <- ""
    }

    ## Subheader label stays for functional messages (instructions, errors).
    ## It renders on top of the TextBox in the lower part of the banner.
    Show(gLayout.subheader)
    gLayout.subheader.font.fgcolor <- gTheme.headerText
    subheaderY <- gLayout.zones.subheader.y + gLayout.zones.subheader.height / 2 - 20
    Move(gLayout.subheader, gVideoWidth / 2, subheaderY)
    RemoveObject(gLayout.subheader, gWin)
    AddObject(gLayout.subheader, gWin)
  }

  ## Progress label at bottom of screen (e.g., "3 of 8")
  progressFont <- MakeFont(gPEBLBaseFont, 0, 27, gTheme.accent1, gTheme.windowBg, 0)
  gProgressLabel <- MakeLabel("", progressFont)
  AddObject(gProgressLabel, gWin)
  Move(gProgressLabel, gVideoWidth/2, gVideoHeight - 50)
  Hide(gProgressLabel)
}


define UpdateScaleHeader()
{
  ## Update the banner TextBox to show scale name and (if active) section title.
  ## Called whenever a new section marker is processed.
  if(gShowTitle and gSectionTitle != "")
  {
    gScaleHeaderBox.text <- "<h1=center>" + gScaleName + "</h1><br><h2=center>" + gSectionTitle + "</h2>"
  } elseif(gShowTitle)
  {
    gScaleHeaderBox.text <- "<h1=center>" + gScaleName + "</h1>"
  } elseif(gSectionTitle != "")
  {
    gScaleHeaderBox.text <- "<h2=center>" + gSectionTitle + "</h2>"
  } else {
    gScaleHeaderBox.text <- ""
  }
  Draw()
}


define UpdateProgressLabel(current, total)
{
  ## Update the [x of N] progress indicator at the bottom of the screen.
  ## Hidden during instruction screens and when total is 0.
  if(total > 0)
  {
    gProgressLabel.text <- current + " of " + total
    Show(gProgressLabel)
  } else {
    Hide(gProgressLabel)
  }
  Draw()
}


define GetDisplayNumber(questions, questIdx)
{
  ## Return the 1-based display number of the item at questIdx,
  ## counting only non-section, non-inst items up to and including questIdx.
  count <- 0
  loop(i, Sequence(1, questIdx, 1))
  {
    q <- Nth(questions, i)
    if(q.type != "section" and q.type != "inst")
    {
      count <- count + 1
    }
  }
  return(count)
}


define MakeScaleButton(text, x, y, width, height)
{
  ## Creates a clickable button with border and label using theme colors
  ## Returns custom object with .border and .label properties

  button <- MakeCustomObject("ScaleButton")

  ## Create border rectangle using theme colors
  button.border <- Rectangle(x, y, width, height, gTheme.buttonBg, 1)
  button.border.color <- gTheme.buttonBorder
  AddObject(button.border, gWin)

  ## Create label using theme colors
  button.label <- MakeLabel(text, gDoneFont)
  AddObject(button.label, gWin)
  Move(button.label, x, y)

  button.x <- x
  button.y <- y

  return(button)
}


define MakeTextBoxWithBorder(text, font, width, height, x, y)
{
  ## Creates a TextBox with background and border using theme colors
  ## Returns custom object with .border, .textbox, and position properties

  obj <- MakeCustomObject("TextBoxWithBorder")

  ## Create background rectangle using theme colors
  obj.border <- Rectangle(x + width/2, y + height/2, width + 4, height + 4, gTheme.textboxBg, 1)
  obj.border.color <- gTheme.textboxBorder
  AddObject(obj.border, gWin)

  ## Create TextBox (placed by upper-left corner)
  obj.textbox <- MakeTextBox(text, font, width, height)
  obj.textbox.isadaptive <- 1
  obj.textbox.formatted <- 1
  AddObject(obj.textbox, gWin)
  Move(obj.textbox, x, y)

  obj.x <- x
  obj.y <- y
  obj.width <- width
  obj.height <- height

  return(obj)
}


##############################################################################
## SCALE DEFINITION LOADING
##############################################################################

define LoadScaleDefinition(scaleCode)
{
  ## Load scale definition.  Searched in order:
  ##   1. {code}/{code}.osd        — OSD bundle in scale subdirectory (workspace layout)
  ##   2. {code}.osd               — OSD bundle in current directory
  ##   3. definitions/{code}.json  — flat definition (launcher-generated, legacy)
  ##   4. definitions/{code}/{code}.osd — OSD in definitions subdirectory (legacy)

  scaleDef <- 0

  ## Try workspace layout first: {code}/{code}.osd
  osdPaths <- [scaleCode + "/" + scaleCode + ".osd",
               scaleCode + ".osd",
               "definitions/" + scaleCode + "/" + scaleCode + ".osd"]

  loop(osdPath, osdPaths)
  {
    if(scaleDef == 0 and FileExists(osdPath))
    {
      Print("Loading scale definition from: " + osdPath)
      osdData <- ReadJSON(osdPath)
      if(PropertyExists(osdData, "definition"))
      {
        scaleDef <- osdData.definition
        if(PropertyExists(osdData, "translations"))
        {
          SetProperty(scaleDef, "_embedded_translations", osdData.translations)
        }
      }
    }
  }

  ## Try legacy flat JSON format
  if(scaleDef == 0)
  {
    filename <- "definitions/" + scaleCode + ".json"
    if(FileExists(filename))
    {
      Print("Loading scale definition from: " + filename)
      scaleDef <- ReadJSON(filename)
    }
  }

  if(scaleDef == 0)
  {
    Print("ERROR: Scale definition file not found for: " + scaleCode)
    Print("Current directory: " + GetWorkingDirectory())
  }

  return(scaleDef)
}


define MergeScaleParameters(scaleDef)
{
  ## Add scale-specific parameters to gParams if they exist in the scale definition
  ## This allows parameter overrides from command line or params file

  if(PropertyExists(scaleDef, "parameters"))
  {
    params <- scaleDef.parameters
    paramNames <- GetPropertyList(params)

    loop(paramName, paramNames)
    {
      paramDef <- GetProperty(params, paramName)

      ## If parameter exists in gParams, keep command-line value
      ## Otherwise, use default from scale definition
      if(not PropertyExists(gParams, paramName))
      {
        SetProperty(gParams, paramName, paramDef.default)
      }
    }
  }
}


##############################################################################
## MAIN SCALE RUNNER
##############################################################################

define RunScale(scaleDef)
{
  ## Prepare question list
  questions <- scaleDef.items

  ## Filter questions based on enabled dimensions
  if(PropertyExists(scaleDef, "dimensions"))
  {
    questions <- FilterQuestionsByDimensions(questions, scaleDef)
  }

  ## Initialize branch choices map (global so SavePooledData can read it)
  gBranchChoices <- MakeCustomObject("BranchChoices")

  ## Apply branching (A1): select one arm per branch group, drop excluded sections
  if(PropertyExists(scaleDef, "branches"))
  {
    excludedSections <- SelectBranchArms(scaleDef)
    questions <- FilterExcludedSections(questions, excludedSections)
  }

  ## Apply section order randomization (S4)
  if(PropertyExists(scaleDef, "randomize_sections"))
  {
    questions <- ShuffleSectionOrder(questions, scaleDef.randomize_sections)
  }

  ## Apply per-section and random_group question randomization (C2/C5).
  ## Per-section randomize.method=shuffle takes priority over shuffle_questions
  ## for that section (the two mechanisms are mutually exclusive per section).
  doGroupShuffle <- ToNumber(gParams.shuffle_questions)
  questions <- ApplyAllQuestionRandomization(questions, doGroupShuffle)

  ## Track question order and responses
  results <- MakeCustomObject("scale_results")
  results.items <- []
  results.responses <- []
  results.rts <- []
  results.order <- []
  results.timestamps <- []
  results.responseMap <- MakeCustomObject("response_map")

  ## Gate termination tracking
  gateTriggered <- 0
  gateMessage <- ""

  ## Back-navigation: set to 1 before calling DoQuestion to show Back button
  gCanGoBack <- 0
  ## 1 = current section allows revision (auto-advance on likert/multi when 1)
  gSectionRevisable <- 1

  ## Current section title shown in the subheader (empty when no named section is active)
  gSectionTitle <- ""

  ## Pre-fill: set to the participant's previous response before calling DoQuestion.
  ## Empty string means no previous response. DoShortAnswer and DoLongAnswer use this.
  gPrevResponse <- ""

  ## Send LSL marker
  LSLMarker("scale_start_" + scaleDef.scale_info.code)

  ## Check for page definitions (OSD format)
  if(PropertyExists(scaleDef, "pages"))
  {
    ## Page-based rendering
    questOrder <- 1
    loop(page, scaleDef.pages)
    {
      ## Collect questions for this page
      pageQuestions <- GetPageQuestions(page, questions)

      ## Check if all questions on this page are VAS
      allVAS <- 1
      loop(pq, pageQuestions)
      {
        if(pq.type != "vas")
        {
          allVAS <- 0
        }
      }

      if(allVAS and Length(pageQuestions) > 1)
      {
        if(gateTriggered)
        {
          ## Gate was triggered — record all VAS items on this page as NA
          loop(qdef, pageQuestions)
          {
            PushOnEnd(results.items, qdef)
            PushOnEnd(results.responses, "NA")
            PushOnEnd(results.rts, 0)
            PushOnEnd(results.order, questOrder)
            PushOnEnd(results.timestamps, GetTime())
            SetProperty(results.responseMap, qdef.id, "NA")
            SetProperty(gResponseMap, qdef.id, "NA")
            questOrder <- questOrder + 1
          }
        } else {
          ## Multi-item VAS page
          pageStartTime <- GetTime()
          LSLMarker("vaspage_" + page.id + "_start")

          pageResults <- DoVASPage(pageQuestions, scaleDef)

          ## Unpack results for each item
          loop(pr, pageResults)
          {
            qdef <- First(pr)
            response <- Second(pr)
            rt <- Third(pr)

            LSLMarker("question_" + qdef.id + "_response_" + response)

            PushOnEnd(results.items, qdef)
            PushOnEnd(results.responses, response)
            PushOnEnd(results.rts, rt)
            PushOnEnd(results.order, questOrder)
            PushOnEnd(results.timestamps, pageStartTime)
            SetProperty(results.responseMap, qdef.id, response)
            SetProperty(gResponseMap, qdef.id, response)

            questOrder <- questOrder + 1
          }
        }
      } else {
        ## Render page questions individually
        loop(qdef, pageQuestions)
        {
          ## Check dimension-level visible_when
          showQuestion <- 1
          if(PropertyExists(qdef, "dimension"))
          {
            dimDef <- FindDimension(qdef.dimension, scaleDef)
            if(dimDef != 0)
            {
              if(PropertyExists(dimDef, "visible_when"))
              {
                if(not EvaluateCondition(dimDef.visible_when, results.responseMap, gParams))
                {
                  showQuestion <- 0
                }
              }
            }
          }

          ## Check per-question visible_when condition
          if(showQuestion and PropertyExists(qdef, "visible_when"))
          {
            if(not EvaluateCondition(qdef.visible_when, results.responseMap, gParams))
            {
              showQuestion <- 0
            }
          }

          if(showQuestion and not gateTriggered)
          {
            questionStartTime <- GetTime()
            LSLMarker("question_" + qdef.id + "_start")

            result <- DoQuestion(qdef, scaleDef)

            LSLMarker("question_" + qdef.id + "_response_" + First(result))

            PushOnEnd(results.items, qdef)
            PushOnEnd(results.responses, First(result))
            PushOnEnd(results.rts, Second(result))
            PushOnEnd(results.order, questOrder)
            PushOnEnd(results.timestamps, questionStartTime)
            SetProperty(results.responseMap, qdef.id, First(result))
            SetProperty(gResponseMap, qdef.id, First(result))

            ## Check gate — if response doesn't match required_value, terminate
            if(PropertyExists(qdef, "gate"))
            {
              gate <- qdef.gate
              response <- First(result) + ""
              if(PropertyExists(gate, "required_value"))
              {
                if(response != gate.required_value + "")
                {
                  gateTriggered <- 1
                  if(PropertyExists(gate, "terminate_message_key"))
                  {
                    msgKey <- gate.terminate_message_key
                    if(PropertyExists(gStrings, msgKey))
                    {
                      gateMessage <- GetProperty(gStrings, msgKey)
                    } else {
                      gateMessage <- "You are not eligible to continue this study."
                    }
                  } else {
                    gateMessage <- "You are not eligible to continue this study."
                  }
                }
              }
            }

            questOrder <- questOrder + 1
          } else {
            ## Question hidden by visible_when or gate triggered — record NA
            PushOnEnd(results.items, qdef)
            PushOnEnd(results.responses, "NA")
            PushOnEnd(results.rts, 0)
            PushOnEnd(results.order, questOrder)
            PushOnEnd(results.timestamps, GetTime())
            SetProperty(results.responseMap, qdef.id, "NA")
            SetProperty(gResponseMap, qdef.id, "NA")

            questOrder <- questOrder + 1
          }
        }
      }
    }

  } else {

    ## No pages - index-based loop supporting per-section backup (revisable)
    questOrder <- 1
    sectionActive <- 1      ## 1 = current section is visible, 0 = skip until next section marker
    sectionRevisable <- 1   ## 1 = Back button allowed within this section
    sectionBoundaryIdx <- 1 ## First question index (1-based) in the current section
    sectionFirstAnsweredIdx <- 0  ## Index of first answered question in current section (0 = none yet)

    ## recordedMap: qid -> position in results arrays (1-based).
    ## Allows updating a previously recorded response when the user goes back and re-answers.
    recordedMap <- MakeCustomObject("recordedIdx")

    questIdx <- 1
    nQuestions <- Length(questions)

    ## Count items that will show a progress number (excludes section markers and instructions)
    nDisplayQuestions <- 0
    loop(qi, Sequence(1, nQuestions, 1))
    {
      qt <- Nth(questions, qi)
      if(qt.type != "section" and qt.type != "inst")
      {
        nDisplayQuestions <- nDisplayQuestions + 1
      }
    }

    while(questIdx <= nQuestions)
    {
      qdef <- Nth(questions, questIdx)

      ## ── Section markers ──────────────────────────────────────────
      if(qdef.type == "section")
      {
        sectionActive <- 1
        sectionRevisable <- 1
        sectionBoundaryIdx <- questIdx + 1  ## content starts after this marker
        sectionFirstAnsweredIdx <- 0        ## reset answered-question tracker

        ## Track section title and update the banner header TextBox
        gSectionTitle <- ""
        if(PropertyExists(qdef, "text_key"))
        {
          if(PropertyExists(gStrings, qdef.text_key))
          {
            gSectionTitle <- GetProperty(gStrings, qdef.text_key)
          }
        }
        UpdateScaleHeader()

        if(PropertyExists(qdef, "revisable"))
        {
          if(not qdef.revisable)
          {
            sectionRevisable <- 0
          }
        }

        if(PropertyExists(qdef, "visible_when"))
        {
          if(not EvaluateCondition(qdef.visible_when, results.responseMap, gParams))
          {
            sectionActive <- 0
          }
        }
        ## Section markers are not displayed or recorded
        questIdx <- questIdx + 1

      } else {

      ## ── Compute visibility ────────────────────────────────────────
      showQuestion <- sectionActive

      ## Check dimension-level visible_when
      if(showQuestion and PropertyExists(qdef, "dimension"))
      {
        dimDef <- FindDimension(qdef.dimension, scaleDef)
        if(dimDef != 0)
        {
          if(PropertyExists(dimDef, "visible_when"))
          {
            if(not EvaluateCondition(dimDef.visible_when, results.responseMap, gParams))
            {
              showQuestion <- 0
            }
          }
        }
      }

      ## Check per-question visible_when condition
      if(showQuestion and PropertyExists(qdef, "visible_when"))
      {
        if(not EvaluateCondition(qdef.visible_when, results.responseMap, gParams))
        {
          showQuestion <- 0
        }
      }

      if(showQuestion and not gateTriggered)
      {
        ## ── Determine if Back button should be shown ──────────────
        gCanGoBack <- 0
        gSectionRevisable <- sectionRevisable
        if(sectionRevisable and sectionFirstAnsweredIdx > 0 and questIdx > sectionFirstAnsweredIdx)
        {
          gCanGoBack <- 1
        }

        ## Pre-fill: pass previous response to all question types
        gPrevResponse <- ""
        if(PropertyExists(results.responseMap, qdef.id))
        {
          prevR <- GetProperty(results.responseMap, qdef.id)
          if(prevR != "NA" and prevR != "")
          {
            gPrevResponse <- prevR + ""
          }
        }

        questionStartTime <- GetTime()

        LSLMarker("question_" + qdef.id + "_start")

        ## Update progress indicator: show "X of N" for non-instruction items
        if(qdef.type != "inst")
        {
          UpdateProgressLabel(GetDisplayNumber(questions, questIdx), nDisplayQuestions)
        } else {
          Hide(gProgressLabel)
        }

        result <- DoQuestion(qdef, scaleDef)

        ## ── Check for Back button press ───────────────────────────
        if(First(result) == -1 or First(result) == "-1")
        {
          ## User pressed Back — find previous answered question within section
          gCanGoBack <- 0
          backFound <- 0
          backIdx <- questIdx - 1

          while(backIdx >= sectionBoundaryIdx and not backFound)
          {
            prevQ <- Nth(questions, backIdx)
            if(prevQ.type != "section")
            {
              ## Only land on questions that were actually answered (not hidden NA)
              if(PropertyExists(recordedMap, prevQ.id))
              {
                prevResp <- GetProperty(results.responseMap, prevQ.id)
                if(prevResp != "NA")
                {
                  backFound <- 1
                  questIdx <- backIdx
                }
              }
            }
            if(not backFound)
            {
              backIdx <- backIdx - 1
            }
          }

          ## If no previous answered question found within section, stay put
          ## (Back button shouldn't have been shown — edge case safety)

        } else {
          ## ── Normal forward: record (or update) the response ──────
          LSLMarker("question_" + qdef.id + "_response_" + First(result))

          if(PropertyExists(recordedMap, qdef.id))
          {
            ## Re-answer after backup: update existing results entry in place
            pos <- GetProperty(recordedMap, qdef.id)
            SetElement(results.responses, pos, First(result))
            SetElement(results.rts, pos, Second(result))
            SetElement(results.timestamps, pos, questionStartTime)
          } else {
            ## First answer: push to results arrays
            SetProperty(recordedMap, qdef.id, Length(results.items) + 1)
            PushOnEnd(results.items, qdef)
            PushOnEnd(results.responses, First(result))
            PushOnEnd(results.rts, Second(result))
            PushOnEnd(results.order, questOrder)
            PushOnEnd(results.timestamps, questionStartTime)
            questOrder <- questOrder + 1
          }

          SetProperty(results.responseMap, qdef.id, First(result))
          SetProperty(gResponseMap, qdef.id, First(result))

          ## Track first answered question in section (sets Back boundary)
          if(sectionFirstAnsweredIdx == 0)
          {
            sectionFirstAnsweredIdx <- questIdx
          }

          ## ── Gate check ────────────────────────────────────────────
          if(PropertyExists(qdef, "gate"))
          {
            gate <- qdef.gate
            response <- First(result) + ""
            gateFailed <- 0

            ## Exact-match form (multi): required_value must equal response
            if(PropertyExists(gate, "required_value"))
            {
              if(response != gate.required_value + "")
              {
                gateFailed <- 1
              }
            }

            ## Numeric operator form (short): operator + value threshold
            if(not gateFailed and PropertyExists(gate, "operator") and PropertyExists(gate, "value"))
            {
              op <- gate.operator
              numResp <- ToNumber(response)
              threshold <- ToNumber(gate.value)
              if(op == "greater_than")
              {
                if(not (numResp > threshold))
                {
                  gateFailed <- 1
                }
              }
              if(op == "less_than")
              {
                if(not (numResp < threshold))
                {
                  gateFailed <- 1
                }
              }
              if(op == "equals")
              {
                if(numResp != threshold)
                {
                  gateFailed <- 1
                }
              }
              if(op == "not_equals")
              {
                if(numResp == threshold)
                {
                  gateFailed <- 1
                }
              }
            }

            ## If gate failed, set termination message and flag
            if(gateFailed)
            {
              gateTriggered <- 1
              if(PropertyExists(gate, "terminate_message_key"))
              {
                msgKey <- gate.terminate_message_key
                if(PropertyExists(gStrings, msgKey))
                {
                  gateMessage <- GetProperty(gStrings, msgKey)
                }
                if(gateMessage == "" or gateMessage == 0)
                {
                  gateMessage <- "You are not eligible to continue this study."
                }
              } else {
                gateMessage <- "You are not eligible to continue this study."
              }
            }
          }

          questIdx <- questIdx + 1
        }

      } else {
        ## ── Question hidden: record NA (first time only) ──────────
        if(not PropertyExists(recordedMap, qdef.id))
        {
          SetProperty(recordedMap, qdef.id, Length(results.items) + 1)
          PushOnEnd(results.items, qdef)
          PushOnEnd(results.responses, "NA")
          PushOnEnd(results.rts, 0)
          PushOnEnd(results.order, questOrder)
          PushOnEnd(results.timestamps, GetTime())
          SetProperty(results.responseMap, qdef.id, "NA")
          SetProperty(gResponseMap, qdef.id, "NA")
          questOrder <- questOrder + 1
        }
        questIdx <- questIdx + 1
      }
      }  ## end section type check
    }
  }

  LSLMarker("scale_end_" + scaleDef.scale_info.code)

  results.gateTriggered <- gateTriggered
  results.gateMessage <- gateMessage

  return(results)
}


define GetPageQuestions(page, allQuestions)
{
  ## Given a page definition with item IDs, find matching question defs
  pageQuestions <- []

  loop(itemID, page.items)
  {
    loop(qdef, allQuestions)
    {
      if(qdef.id == itemID)
      {
        PushOnEnd(pageQuestions, qdef)
        break
      }
    }
  }

  return(pageQuestions)
}


define EvaluateCondition(condition, responseMap, params)
{
  ## Evaluates a visible_when condition object against collected responses
  ## and scale parameters. Returns 1 (true) or 0 (false).
  ##
  ## PEBL constraint: no early returns. Single return at end via result variable.

  result <- 0

  if(PropertyExists(condition, "all"))
  {
    ## Compound AND: all conditions must be true
    result <- 1
    loop(subcond, condition.all)
    {
      if(not EvaluateCondition(subcond, responseMap, params))
      {
        result <- 0
      }
    }

  } elseif(PropertyExists(condition, "any")) {

    ## Compound OR: at least one condition must be true
    result <- 0
    loop(subcond, condition.any)
    {
      if(EvaluateCondition(subcond, responseMap, params))
      {
        result <- 1
      }
    }

  } else {

    ## Simple condition — resolve actual value, then compare
    op <- condition.operator
    actual <- ""
    canCompare <- 0

    if(PropertyExists(condition, "item") or PropertyExists(condition, "question"))
    {
      qID <- ""
      if(PropertyExists(condition, "item"))
      {
        qID <- condition.item
      } else {
        qID <- condition.question
      }

      if(op == "is_answered")
      {
        if(PropertyExists(responseMap, qID))
        {
          actual <- GetProperty(responseMap, qID)
          result <- (actual != "NA")
        }
        ## else result stays 0
      } elseif(op == "is_not_answered") {
        if(PropertyExists(responseMap, qID))
        {
          actual <- GetProperty(responseMap, qID)
          result <- (actual == "NA")
        } else {
          result <- 1
        }
      } else {
        ## Standard operator — need a real answer
        if(PropertyExists(responseMap, qID))
        {
          actual <- GetProperty(responseMap, qID)
          if(actual != "NA")
          {
            canCompare <- 1
          }
        }
      }

    } elseif(PropertyExists(condition, "parameter")) {

      pName <- condition.parameter

      if(op == "is_answered")
      {
        result <- PropertyExists(params, pName)
      } elseif(op == "is_not_answered") {
        result <- (not PropertyExists(params, pName))
      } else {
        if(PropertyExists(params, pName))
        {
          actual <- GetProperty(params, pName)
          canCompare <- 1
        }
      }
    }

    ## Compare actual vs expected for standard operators
    if(canCompare)
    {
      expected <- condition.value

      if(op == "equals")
      {
        result <- (actual + "" == expected + "")
      } elseif(op == "not_equals") {
        result <- (actual + "" != expected + "")
      } elseif(op == "greater_than") {
        result <- (ToNumber(actual) > ToNumber(expected))
      } elseif(op == "less_than") {
        result <- (ToNumber(actual) < ToNumber(expected))
      } elseif(op == "in") {
        result <- 0
        loop(v, expected)
        {
          if(actual + "" == v + "")
          {
            result <- 1
          }
        }
      } elseif(op == "not_in") {
        result <- 1
        loop(v, expected)
        {
          if(actual + "" == v + "")
          {
            result <- 0
          }
        }
      }
    }
  }

  return(result)
}


define FindDimension(dimID, scaleDef)
{
  ## Look up a dimension object by ID from scaleDef.dimensions
  ## Returns the dimension object, or 0 if not found

  result <- 0
  if(PropertyExists(scaleDef, "dimensions"))
  {
    loop(dim, scaleDef.dimensions)
    {
      if(dim.id == dimID)
      {
        result <- dim
      }
    }
  }
  return(result)
}


define IsQuestionRequired(qdef, scaleDef)
{
  ## Determine if a question must be answered before advancing.
  ## Precedence: per-question explicit > scale-level default > type-based default.
  ## Returns 1 (required) or 0 (optional).

  result <- 1

  ## Per-question explicit setting takes precedence
  if(PropertyExists(qdef, "required"))
  {
    if(qdef.required)
    {
      result <- 1
    } else {
      result <- 0
    }
  } else {

    ## Scale-level default
    if(PropertyExists(scaleDef, "default_required"))
    {
      if(scaleDef.default_required)
      {
        result <- 1
      } else {
        result <- 0
      }
    } else {

      ## Type-based defaults
      type <- qdef.type
      if(type == "short" or type == "long" or type == "inst" or type == "image")
      {
        result <- 0
      } else {
        result <- 1
      }
    }
  }

  return(result)
}


define MakeSkipButton(x, y)
{
  ## Create a SKIP button for optional questions.
  ## Uses skip_label from translation strings if available.
  skipText <- "SKIP"
  if(PropertyExists(gStrings, "skip_label"))
  {
    skipText <- gStrings.skip_label
  }
  skipBtn <- MakeScaleButton(skipText, x, y, 100, 40)
  return(skipBtn)
}


define MakeBackButton(x, y)
{
  ## Create a BACK button for revisable sections.
  ## Uses back_label from translation strings if available.
  backText <- "BACK"
  if(PropertyExists(gStrings, "back_label"))
  {
    backText <- gStrings.back_label
  }
  backBtn <- MakeScaleButton(backText, x, y, 150, 50)
  return(backBtn)
}


define FilterQuestionsByDimensions(questions, scaleDef)
{
  ## Filter out questions from disabled dimensions
  filtered <- []

  loop(qdef, questions)
  {
    include <- 1

    ## Check if question has a dimension field
    if(PropertyExists(qdef, "dimension"))
    {
      dimID <- qdef.dimension

      ## Find dimension definition
      loop(dim, scaleDef.dimensions)
      {
        if(dim.id == dimID)
        {
          ## Check if dimension is enabled via parameter
          if(PropertyExists(dim, "enabled_param"))
          {
            paramName <- dim.enabled_param
            if(PropertyExists(gParams, paramName))
            {
              include <- GetProperty(gParams, paramName)
            }
          }
          break
        }
      }
    }

    if(include)
    {
      PushOnEnd(filtered, qdef)
    }
  }

  return(filtered)
}


##############################################################################
## QUESTION TYPE DISPATCHER
##############################################################################

define DoQuestion(qdef, scaleDef)
{
  type <- qdef.type
  result <- [0, 0]

  ## Create screenshots directory
  MakeDirectory("screenshots")

  if(type == "likert")
  {
    result <- DoLikert(qdef, scaleDef, gPrevResponse)
  } elseif(type == "vas")
  {
    result <- DoVAS(qdef, scaleDef, gPrevResponse)
  } elseif(type == "grid")
  {
    result <- DoGrid(qdef, scaleDef, gPrevResponse)
  } elseif(type == "short")
  {
    result <- DoShortAnswer(qdef, scaleDef, gPrevResponse)
  } elseif(type == "long")
  {
    result <- DoLongAnswer(qdef, scaleDef, gPrevResponse)
  } elseif(type == "multi")
  {
    result <- DoMultiChoice(qdef, scaleDef, gPrevResponse)
  } elseif(type == "multicheck")
  {
    result <- DoMultiCheck(qdef, scaleDef, gPrevResponse)
  } elseif(type == "inst")
  {
    result <- DoInstructions(qdef, gPrevResponse)
  } elseif(type == "image")
  {
    result <- DoImage(qdef, gPrevResponse)
  } elseif(type == "imageresponse")
  {
    result <- DoImageResponse(qdef, scaleDef, gPrevResponse)
  } elseif(type == "section")
  {
    ## Section markers are handled by the calling loop — no display action here
  } else {
    Print("ERROR: Unknown question type: " + type)
  }

  return(result)
}


##############################################################################
## LIKERT SCALE QUESTION (Horizontal click rectangles)
##############################################################################

define DoLikert(qdef, scaleDef, prefill:"")
{
  ## Get configuration
  points <- GetQuestionPoints(qdef, scaleDef)

  gLayout.subheader.text <- ""

  ## Get question text from translations
  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))

  ## Resolve question head: item-level (qdef.question_head) overrides scale-level
  questionHead <- ""
  if(PropertyExists(qdef, "question_head"))
  {
    if(PropertyExists(gStrings, qdef.question_head))
    {
      questionHead <- GetProperty(gStrings, qdef.question_head)
    }
  } elseif(PropertyExists(scaleDef, "likert_options"))
  {
    if(PropertyExists(scaleDef.likert_options, "question_head"))
    {
      headKey <- scaleDef.likert_options.question_head
      if(PropertyExists(gStrings, headKey))
      {
        questionHead <- GetProperty(gStrings, headKey)
      }
    }
  }

  ## Create question head as formatted adaptive textbox below the banner
  headWidth <- Round(gVideoWidth * 0.75)
  headHeight <- 80
  headX <- Round((gVideoWidth - headWidth) / 2)
  headY <- gLayout.stimulusRegion.y + 5

  head <- MakeTextBox(questionHead, gHeadFont, headWidth, headHeight)
  head.isadaptive <- 1
  head.formatted <- 1
  head.justify <- "CENTER"
  AddObject(head, gWin)
  Move(head, headX, headY)

  ## Pre-calculate response area position so we can vertically center the question text
  numHeight <- 50  ## height of the number label area in the response row
  yval <- gVideoHeight/2 + 100  ## vertical center of the number labels

  ## Center question text in the available space between head and Likert response area
  questWidth <- Round(gVideoWidth * 0.80)
  questHeight <- 120
  questX <- Round((gVideoWidth - questWidth) / 2)
  availTop <- headY + head.height + 10
  availBottom <- yval - numHeight/2 - 20
  questY <- Round((availTop + availBottom) / 2) - 50
  if(questY < availTop)
  {
    questY <- availTop
  }

  quest <- MakeTextBox(questionText, gItemFont, questWidth, questHeight)
  quest.isadaptive <- 1
  quest.formatted <- 1
  quest.justify <- "CENTER"
  AddObject(quest, gWin)
  Move(quest, questX, questY)

  ## Create response options
  ## Get min/max range for this question
  range <- GetQuestionRange(qdef, scaleDef)
  minVal <- First(range)
  maxVal <- Second(range)

  ## Get labels for this question (question-level or scale-level)
  labelKeys <- GetQuestionLabels(qdef, scaleDef)

  ## Reversed display: show maxVal on left down to minVal on right
  likertReversed <- 0
  if(PropertyExists(qdef, "likert_reverse"))
  {
    if(qdef.likert_reverse)
    {
      likertReversed <- 1
    }
  }

  skip <- 150
  left <- gVideoWidth/2 - skip * ((points-1)/2)

  ## Pass 1: Create adaptive label textboxes (not yet added to window)
  ## to measure the tallest one.
  ## Labels are ordered by display position (left to right), so when reversed
  ## position i corresponds to value (maxVal - (i-1)), label index (points - i).
  labels <- []
  maxLabelHeight <- 80  ## minimum height

  loop(i, Sequence(1, points, 1))
  {
    labelIdx <- i
    if(likertReversed)
    {
      labelIdx <- points - i + 1
    }
    if(Length(labelKeys) >= labelIdx)
    {
      labelKey <- Nth(labelKeys, labelIdx)
      if(IsString(labelKey) and StringLength(labelKey) > 0)
      {
        labelText <- GetProperty(gStrings, labelKey)
        optLabel <- MakeTextBox(labelText, gLikertLabelFont, skip-15, 80)
        optLabel.isadaptive <- 1
        optLabel.justify <- "CENTER"
        ## Temporarily add to measure adaptive height
        AddObject(optLabel, gWin)
        if(optLabel.height > maxLabelHeight)
        {
          maxLabelHeight <- optLabel.height
        }
        RemoveObject(optLabel, gWin)
        PushOnEnd(labels, optLabel)
      } else {
        PushOnEnd(labels, 0)  ## sentinel: no label at this position
      }
    }
  }

  ## Calculate box dimensions based on tallest label (numHeight and yval already set above)
  boxHeight <- numHeight + maxLabelHeight + 20

  ## Pass 2: Create and position everything with uniform sizing
  ## backs     = full-height click targets (border only, never filled)
  ## selBacks = number-height green highlight rectangles (toggled on selection)
  backs <- []
  selBacks <- []
  nums <- []
  responseValues <- []

  loop(i, Sequence(1, points, 1))
  {
    x <- left + skip * (i - 1)

    ## Calculate display value based on range (reversed: count down from max)
    if(likertReversed)
    {
      displayValue <- maxVal - (i - 1)
    } else {
      displayValue <- minVal + (i - 1)
    }
    PushOnEnd(responseValues, displayValue)

    ## Green highlight: number-height, drawn first so the border box renders on top.
    ## Fill color locked to green at creation; SetSingleSelection toggles filled 0/1.
    selHL <- Rectangle(x, yval, skip-10, numHeight, MakeColor("darkgreen"), 0)
    AddObject(selHL, gWin)
    PushOnEnd(selBacks, selHL)

    ## Full-height border box: drawn on top of selHL so its outline always shows.
    ## Always filled=0 (border only); interior transparent so green shows through.
    ## Used as click target for WaitForClickOnTarget.
    back <- Rectangle(x, yval + boxHeight/2 - numHeight/2, skip-10, boxHeight, gTheme.accent1, 0)
    back.color <- gTheme.optionBorder
    AddObject(back, gWin)
    PushOnEnd(backs, back)

    ## Number label — drawn on top of both rectangles
    num <- MakeLabel(displayValue+"", gLikertNumFont)
    Move(num, x, yval)
    AddObject(num, gWin)
    PushOnEnd(nums, num)

    ## Add pre-measured label textbox below number (skip sentinel 0 = empty slot)
    if(Length(labels) >= i)
    {
      optLabel <- Nth(labels, i)
      if(not IsNumber(optLabel))
      {
        AddObject(optLabel, gWin)
        Move(optLabel, x - optLabel.width/2, yval + numHeight/2 + 5)
      }
    }
  }

  footerObj <- 0
  footerBottom <- yval + boxHeight + 15
  if(PropertyExists(scaleDef.likert_options, "response_footer"))
  {
    footerKey <- scaleDef.likert_options.response_footer
    footerText <- GetProperty(gStrings, footerKey)
    if(footerText != "" and footerText != 0)
    {
      footerWidth <- Round(gVideoWidth * 0.80)
      footerX <- Round((gVideoWidth - footerWidth) / 2)
      footerY <- yval + boxHeight + 15
      footerFont <- MakeFont(gPEBLBaseFont, 0, 16, gTheme.questionText, gTheme.windowBg, 0)

      footerObj <- MakeTextBox(footerText, footerFont, footerWidth, 40)
      footerObj.isadaptive <- 1
      footerObj.formatted <- 1
      footerObj.justify <- "CENTER"
      AddObject(footerObj, gWin)
      Move(footerObj, footerX, footerY)
      footerBottom <- footerY + footerObj.height + 10
    }
  }

  ## NEXT button (hidden until selection is made)
  nextBtn <- MakeScaleButton("NEXT", gVideoWidth/2, footerBottom + 25, 150, 50)

  ## SKIP button for optional questions (available from start)
  isRequired <- IsQuestionRequired(qdef, scaleDef)
  skipBtn <- 0
  if(not isRequired)
  {
    skipBtn <- MakeSkipButton(gVideoWidth/2 + 200, footerBottom + 25)
  }

  ## BACK button for revisable sections
  backBtn <- 0
  if(gCanGoBack)
  {
    backBtn <- MakeBackButton(gVideoWidth/2 - 200, footerBottom + 25)
  }

  ## Pre-fill: find matching option and pre-select it
  selectedIdx <- 0
  selectedVal <- 0
  if(prefill != "")
  {
    prefillNum <- ToNumber(prefill)
    loop(i, Sequence(1, Length(responseValues), 1))
    {
      if(Nth(responseValues, i) == prefillNum)
      {
        selectedIdx <- i
        selectedVal <- prefillNum
      }
    }
    if(selectedIdx > 0)
    {
      SetSingleSelection(selBacks, selectedIdx)
    }
  }

  ## NEXT hidden until a selection is made (prefill may already provide one)
  nextVisible <- 1
  if(selectedIdx == 0)
  {
    Hide(nextBtn.border)
    Hide(nextBtn.label)
    nextVisible <- 0
  }

  Draw()

  ## Selection loop: click to select, NEXT to confirm
  t1 <- GetTime()
  continueLoop <- 1
  wasSkipped <- 0
  wentBack <- 0

  while(continueLoop)
  {
    ## Build click targets: options always available
    curTargets <- backs
    curKeys <- Sequence(1, points, 1)

    ## NEXT available once a selection exists
    if(selectedIdx > 0)
    {
      curTargets <- Merge(curTargets, [nextBtn.border])
      curKeys <- Merge(curKeys, [-1])
    }

    if(skipBtn != 0)
    {
      curTargets <- Merge(curTargets, [skipBtn.border])
      curKeys <- Merge(curKeys, [-2])
    }

    if(backBtn != 0)
    {
      curTargets <- Merge(curTargets, [backBtn.border])
      curKeys <- Merge(curKeys, [-3])
    }

    clicked <- WaitForClickOnTarget(curTargets, curKeys)

    if(clicked == -1)
    {
      ## NEXT clicked — confirm selection
      continueLoop <- 0
    } elseif(clicked == -2)
    {
      ## SKIP clicked
      continueLoop <- 0
      wasSkipped <- 1
    } elseif(clicked == -3)
    {
      ## BACK clicked
      continueLoop <- 0
      wentBack <- 1
    } else {
      ## Option clicked — highlight it and reveal NEXT
      selectedIdx <- clicked
      selectedVal <- Nth(responseValues, clicked)
      SetSingleSelection(selBacks, selectedIdx)

      Show(nextBtn.border)
      Show(nextBtn.label)
      nextVisible <- 1
      Draw()

      if(gSectionRevisable)
      {
        ## Auto-advance: briefly show NEXT then move on
        Wait(400)
        continueLoop <- 0
      }
    }
  }

  t2 <- GetTime()

  if(wasSkipped)
  {
    response <- "NA"
  } elseif(wentBack)
  {
    response <- "BACK"
  } else {
    response <- selectedVal
  }

  ## Clean up
  RemoveObject(head, gWin)
  RemoveObject(quest, gWin)
  RemoveObjects(backs, gWin)
  RemoveObjects(selBacks, gWin)
  RemoveObjects(nums, gWin)
  loop(optLabel, labels) { if(not IsNumber(optLabel)) { RemoveObject(optLabel, gWin) } }
  if(footerObj != 0)
  {
    RemoveObject(footerObj, gWin)
  }
  RemoveObject(nextBtn.border, gWin)
  RemoveObject(nextBtn.label, gWin)
  if(skipBtn != 0)
  {
    RemoveObject(skipBtn.border, gWin)
    RemoveObject(skipBtn.label, gWin)
  }
  if(backBtn != 0)
  {
    RemoveObject(backBtn.border, gWin)
    RemoveObject(backBtn.label, gWin)
  }

  retVal <- [response, t2-t1]
  if(wentBack)
  {
    retVal <- [-1, 0]
  }
  return(retVal)
}


##############################################################################
## HELPER FUNCTIONS
##############################################################################

define GetQuestionPoints(qdef, scaleDef)
{
  ## Get number of points for this question
  ## Check question-specific setting first, then scale default

  points <- 5  ## Default to 5-point scale

  if(PropertyExists(qdef, "likert_points"))
  {
    points <- qdef.likert_points
  } elseif(PropertyExists(scaleDef.likert_options, "points"))
  {
    points <- scaleDef.likert_options.points
  }

  return(points)
}


define GetQuestionRange(qdef, scaleDef)
{
  ## Get min and max values for this question
  ## Check question-specific settings first, then scale defaults
  ## Returns [min, max]

  minVal <- 1
  maxVal <- 5

  ## For grid items, range is [1, number of columns] (column indices are 1-based)
  if(PropertyExists(qdef, "type") and qdef.type == "grid")
  {
    maxVal <- 6  ## fallback; overridden by actual column count when present
    if(PropertyExists(qdef, "columns"))
    {
      maxVal <- Length(qdef.columns)
    }

  ## For VAS questions, use the direct min/max fields
  } elseif(PropertyExists(qdef, "type") and qdef.type == "vas")
  {
    minVal <- 0
    maxVal <- 100
    if(PropertyExists(qdef, "min"))
    {
      minVal <- qdef.min
    }
    if(PropertyExists(qdef, "max"))
    {
      maxVal <- qdef.max
    }

  } else {

    ## For Likert and other types
    points <- GetQuestionPoints(qdef, scaleDef)

    ## Default min/max based on points
    ## Binary scales: 0-1, Regular Likert: 1-N
    if(points == 2)
    {
      minVal <- 0
    }
    maxVal <- minVal + points - 1

    ## Check for question-specific overrides
    if(PropertyExists(qdef, "likert_min"))
    {
      minVal <- qdef.likert_min
    } elseif(PropertyExists(scaleDef.likert_options, "min"))
    {
      minVal <- scaleDef.likert_options.min
    }

    if(PropertyExists(qdef, "likert_max"))
    {
      maxVal <- qdef.likert_max
    } elseif(PropertyExists(scaleDef.likert_options, "max"))
    {
      maxVal <- scaleDef.likert_options.max
    }
  }

  return([minVal, maxVal])
}


define GetQuestionLabels(qdef, scaleDef)
{
  ## Get labels for this question's response options
  ## Check question-specific labels first, then scale defaults
  ## Returns list of label keys

  result <- []

  ## Check for question-specific labels
  if(PropertyExists(qdef, "likert_labels"))
  {
    questionLabels <- GetProperty(qdef, "likert_labels")
    if(IsList(questionLabels))
    {
      labelCount <- Length(questionLabels)
      if(labelCount > 0)
      {
        result <- questionLabels
      }
    }
  }

  ## Fall back to scale-level labels if no question-specific labels
  if(Length(result) == 0)
  {
    if(PropertyExists(scaleDef.likert_options, "labels"))
    {
      result <- scaleDef.likert_options.labels
    }
  }

  return(result)
}


##############################################################################
## CODING AND SCORING
##############################################################################

define ComputeScores(results, scaleDef)
{
  scores            <- MakeCustomObject("scores")
  transformedScores <- MakeCustomObject("transformedScores")

  ## Check if scale has scoring definitions
  if(PropertyExists(scaleDef, "scoring"))
  {
    ## Build lookup tables for efficient access
    questionMap <- BuildQuestionMap(scaleDef.items)
    responseMap <- BuildResponseMap(results)

    scoringDefs <- scaleDef.scoring
    dimIDs      <- GetPropertyList(scoringDefs)

    ## Pass 1: item-based dimensions (no scores field)
    loop(dimID, dimIDs)
    {
      scoreDef <- GetProperty(scoringDefs, dimID)
      if(not PropertyExists(scoreDef, "scores"))
      {
        dimResult <- ComputeDimensionScore(dimID, scoreDef, questionMap, responseMap, scaleDef, scores, transformedScores)
        dimScore  <- First(dimResult)
        codedVals <- Second(dimResult)
        SetProperty(scores, dimID, dimScore)

        if(PropertyExists(scoreDef, "transform"))
        {
          tScore <- ApplyTransform(dimScore, scoreDef.transform, codedVals)
          SetProperty(transformedScores, dimID, tScore)
        }
      }
    }

    ## Pass 2: composite dimensions that reference other dimension scores
    loop(dimID, dimIDs)
    {
      scoreDef <- GetProperty(scoringDefs, dimID)
      if(PropertyExists(scoreDef, "scores"))
      {
        dimResult <- ComputeDimensionScore(dimID, scoreDef, questionMap, responseMap, scaleDef, scores, transformedScores)
        dimScore  <- First(dimResult)
        codedVals <- Second(dimResult)
        SetProperty(scores, dimID, dimScore)

        if(PropertyExists(scoreDef, "transform"))
        {
          tScore <- ApplyTransform(dimScore, scoreDef.transform, codedVals)
          SetProperty(transformedScores, dimID, tScore)
        }
      }
    }
  }

  return([scores, transformedScores])
}


define ComputeComputedVars(scaleDef, scores, transformedScores, responseMap)
{
  ## Compute derived variables from the "computed" block.
  ## Expressions can reference score.X, answer.X, computed.X using simple arithmetic.
  ## Returns a custom object with name->value mappings.

  computedVars <- MakeCustomObject("computed")

  if(PropertyExists(scaleDef, "computed"))
  {

  computedBlock <- scaleDef.computed
  varNames <- GetPropertyList(computedBlock)

  ## Build merged scores (prefer transformed over raw)
  mergedScores <- MakeCustomObject("mergedScores")
  scoreNames <- GetPropertyList(scores)
  loop(sn, scoreNames)
  {
    if(PropertyExists(transformedScores, sn))
    {
      SetProperty(mergedScores, sn, GetProperty(transformedScores, sn))
    } else {
      SetProperty(mergedScores, sn, GetProperty(scores, sn))
    }
  }

  ## Simple dependency ordering: evaluate multiple passes until all resolved
  ## (handles computed vars that reference other computed vars)
  maxPasses <- 3
  pass <- 1
  remaining <- varNames

  while(Length(remaining) > 0 and pass <= maxPasses)
  {
    nextRemaining <- []
    loop(varName, remaining)
    {
      varDef <- GetProperty(computedBlock, varName)
      expr <- varDef.expression

      ## Try to evaluate — if it references an unresolved computed var, defer
      val <- EvalSimpleExpression(expr, mergedScores, responseMap, computedVars)

      if(val != "EVAL_ERROR")
      {
        if(PropertyExists(varDef, "type"))
        {
          if(varDef.type == "boolean")
          {
            if(val > 0)
            {
              val <- 1
            } else {
              val <- 0
            }
          }
        }
        SetProperty(computedVars, varName, val)
      } else {
        PushOnEnd(nextRemaining, varName)
      }
    }
    remaining <- nextRemaining
    pass <- pass + 1
  }

  } ## end if PropertyExists computed

  return(computedVars)
}


define EvalSimpleExpression(expr, scores, responseMap, computedVars)
{
  ## Simple expression evaluator for computed variables.
  ## Supports: +, -, *, /, >=, <=, >, <, ==, !=
  ## Variable references: score.X, answer.X, computed.X
  ## Parentheses for grouping.
  ## Returns numeric result or "EVAL_ERROR" if a variable can't be resolved.

  ## Step 1: Tokenize
  tokens <- TokenizeExpression(expr)

  ## Step 2: Resolve variable references to numbers
  resolvedTokens <- []
  loop(tok, tokens)
  {
    resolved <- tok

    ## Check for variable references: score.X, answer.X, computed.X
    if(StringLength(tok) > 6 and SubString(tok, 1, 6) == "score.")
    {
      varRef <- SubString(tok, 7, StringLength(tok) - 6)
      if(PropertyExists(scores, varRef))
      {
        resolved <- GetProperty(scores, varRef) + ""
      } else {
        resolved <- "0"
      }
    } elseif(StringLength(tok) > 7 and SubString(tok, 1, 7) == "answer.")
    {
      varRef <- SubString(tok, 8, StringLength(tok) - 7)
      if(PropertyExists(responseMap, varRef))
      {
        val <- GetProperty(responseMap, varRef)
        resolved <- val + ""
      } else {
        resolved <- "0"
      }
    } elseif(StringLength(tok) > 9 and SubString(tok, 1, 9) == "computed.")
    {
      varRef <- SubString(tok, 10, StringLength(tok) - 9)
      if(PropertyExists(computedVars, varRef))
      {
        resolved <- GetProperty(computedVars, varRef) + ""
      } else {
        resolved <- "EVAL_ERROR"
      }
    }

    PushOnEnd(resolvedTokens, resolved)
  }

  ## Check for unresolved references
  hasError <- 0
  loop(tok, resolvedTokens)
  {
    if(tok == "EVAL_ERROR")
    {
      hasError <- 1
    }
  }

  ## Step 3: Evaluate the expression using recursive descent
  val <- "EVAL_ERROR"
  if(not hasError)
  {
    result <- EvalExprTokens(resolvedTokens, 1)
    val <- First(result)
  }

  return(val)
}


define TokenizeExpression(expr)
{
  ## Split expression into tokens: numbers, operators, parens, variable refs
  tokens <- []
  pos <- 1
  len <- StringLength(expr)

  while(pos <= len)
  {
    ch <- SubString(expr, pos, 1)

    ## Skip whitespace
    if(ch == " " or ch == Tab())
    {
      pos <- pos + 1
    } elseif(ch == "(" or ch == ")")
    {
      PushOnEnd(tokens, ch)
      pos <- pos + 1
    } elseif(ch == "+" or ch == "*" or ch == "/")
    {
      PushOnEnd(tokens, ch)
      pos <- pos + 1
    } elseif(ch == "-")
    {
      ## Could be minus operator or negative number
      ## Negative if at start, after operator, or after open paren
      isNeg <- 0
      if(Length(tokens) == 0)
      {
        isNeg <- 1
      } else {
        prevTok <- Nth(tokens, Length(tokens))
        if(prevTok == "(" or prevTok == "+" or prevTok == "-" or prevTok == "*" or prevTok == "/" or prevTok == ">=" or prevTok == "<=" or prevTok == ">" or prevTok == "<" or prevTok == "==" or prevTok == "!=")
        {
          isNeg <- 1
        }
      }
      if(isNeg)
      {
        ## Read negative number
        numStr <- "-"
        pos <- pos + 1
        done <- 0
        while(pos <= len and not done)
        {
          nch <- SubString(expr, pos, 1)
          if(IsDigitChar(nch) or nch == ".")
          {
            numStr <- numStr + nch
            pos <- pos + 1
          } else {
            done <- 1
          }
        }
        PushOnEnd(tokens, numStr)
      } else {
        PushOnEnd(tokens, "-")
        pos <- pos + 1
      }
    } elseif(ch == ">" or ch == "<" or ch == "=" or ch == "!")
    {
      ## Two-char operators: >=, <=, ==, !=
      if(pos < len)
      {
        nextCh <- SubString(expr, pos + 1, 1)
        if(nextCh == "=")
        {
          PushOnEnd(tokens, ch + "=")
          pos <- pos + 2
        } else {
          PushOnEnd(tokens, ch)
          pos <- pos + 1
        }
      } else {
        PushOnEnd(tokens, ch)
        pos <- pos + 1
      }
    } elseif(IsDigitChar(ch) or ch == ".")
    {
      ## Number
      numStr <- ""
      done <- 0
      while(pos <= len and not done)
      {
        nch <- SubString(expr, pos, 1)
        if(IsDigitChar(nch) or nch == ".")
        {
          numStr <- numStr + nch
          pos <- pos + 1
        } else {
          done <- 1
        }
      }
      PushOnEnd(tokens, numStr)
    } elseif(IsLetterChar(ch))
    {
      ## Variable reference (e.g., score.PHQ_total, answer.q1)
      varStr <- ""
      done <- 0
      while(pos <= len and not done)
      {
        nch <- SubString(expr, pos, 1)
        if(IsLetterChar(nch) or IsDigitChar(nch) or nch == "." or nch == "_")
        {
          varStr <- varStr + nch
          pos <- pos + 1
        } else {
          done <- 1
        }
      }
      PushOnEnd(tokens, varStr)
    } else {
      ## Unknown character, skip
      pos <- pos + 1
    }
  }

  return(tokens)
}


define IsDigitChar(ch)
{
  result <- (ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9")
  return(result)
}


define IsLetterChar(ch)
{
  letters <- "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
  result <- (FindInString(letters, ch, 1) > 0)
  return(result)
}


define EvalExprTokens(tokens, pos)
{
  ## Recursive descent parser for arithmetic expressions.
  ## Returns [value, nextPos].
  ## Precedence: comparison < addition < multiplication
  ## Grammar:
  ##   expr     -> addExpr (compOp addExpr)*
  ##   addExpr  -> mulExpr (('+' | '-') mulExpr)*
  ##   mulExpr  -> primary (('*' | '/') primary)*
  ##   primary  -> NUMBER | '(' expr ')'

  result <- EvalAddExpr(tokens, pos)
  val <- First(result)
  pos <- Second(result)

  ## Check for comparison operators
  cont <- 1
  while(cont and pos <= Length(tokens))
  {
    tok <- Nth(tokens, pos)
    if(tok == ">=" or tok == "<=" or tok == ">" or tok == "<" or tok == "==" or tok == "!=")
    {
      op <- tok
      pos <- pos + 1
      rhsResult <- EvalAddExpr(tokens, pos)
      rhs <- First(rhsResult)
      pos <- Second(rhsResult)

      if(op == ">=")      { val <- (val >= rhs) }
      elseif(op == "<=")  { val <- (val <= rhs) }
      elseif(op == ">")   { val <- (val > rhs) }
      elseif(op == "<")   { val <- (val < rhs) }
      elseif(op == "==")  { val <- (val == rhs) }
      elseif(op == "!=")  { val <- (val != rhs) }
    } else {
      cont <- 0
    }
  }

  return([val, pos])
}


define EvalAddExpr(tokens, pos)
{
  result <- EvalMulExpr(tokens, pos)
  val <- First(result)
  pos <- Second(result)

  cont <- 1
  while(cont and pos <= Length(tokens))
  {
    tok <- Nth(tokens, pos)
    if(tok == "+")
    {
      pos <- pos + 1
      rhsResult <- EvalMulExpr(tokens, pos)
      rhs <- First(rhsResult)
      pos <- Second(rhsResult)
      val <- val + rhs
    } elseif(tok == "-")
    {
      pos <- pos + 1
      rhsResult <- EvalMulExpr(tokens, pos)
      rhs <- First(rhsResult)
      pos <- Second(rhsResult)
      val <- val - rhs
    } else {
      cont <- 0
    }
  }

  return([val, pos])
}


define EvalMulExpr(tokens, pos)
{
  result <- EvalPrimary(tokens, pos)
  val <- First(result)
  pos <- Second(result)

  cont <- 1
  while(cont and pos <= Length(tokens))
  {
    tok <- Nth(tokens, pos)
    if(tok == "*")
    {
      pos <- pos + 1
      rhsResult <- EvalPrimary(tokens, pos)
      rhs <- First(rhsResult)
      pos <- Second(rhsResult)
      val <- val * rhs
    } elseif(tok == "/")
    {
      pos <- pos + 1
      rhsResult <- EvalPrimary(tokens, pos)
      rhs <- First(rhsResult)
      pos <- Second(rhsResult)
      if(rhs != 0) { val <- val / rhs }
    } else {
      cont <- 0
    }
  }

  return([val, pos])
}


define EvalPrimary(tokens, pos)
{
  ## Primary: number or parenthesized expression
  val <- 0
  if(pos <= Length(tokens))
  {
    tok <- Nth(tokens, pos)
    if(tok == "(")
    {
      pos <- pos + 1
      result <- EvalExprTokens(tokens, pos)
      val <- First(result)
      pos <- Second(result)
      ## Skip closing paren
      if(pos <= Length(tokens))
      {
        if(Nth(tokens, pos) == ")")
        {
          pos <- pos + 1
        }
      }
    } else {
      ## Must be a number
      val <- ToNumber(tok)
      pos <- pos + 1
    }
  }

  return([val, pos])
}


define ComputeDimensionScore(dimID, scoreDef, questionMap, responseMap, scaleDef, prevScores, prevTScores)
{
  method  <- scoreDef.method
  itemIDs <- []
  if(PropertyExists(scoreDef, "items"))
  {
    itemIDs <- scoreDef.items
  }

  ## Collect coded values and parallel weights for this dimension
  values      <- []
  itemWeights <- []

  loop(itemID, itemIDs)
  {
    ## Look up question definition from map
    if(PropertyExists(questionMap, itemID))
    {
      qdef <- GetProperty(questionMap, itemID)

      ## Look up response from map
      if(PropertyExists(responseMap, itemID))
      {
        resp <- GetProperty(responseMap, itemID)

        ## Check if response is numeric (0 is a valid response)
        if(IsNumber(resp))
        {
          ## Get question range for coding
          range <- GetQuestionRange(qdef, scaleDef)
          minVal <- First(range)
          maxVal <- Second(range)

          ## Apply coding: read from scoring definition's item_coding object.
          ## 1 = forward, -1 = reverse, 0 or absent = exclude from this dimension's score.
          coding <- 0
          if(PropertyExists(scoreDef, "item_coding"))
          {
            if(PropertyExists(scoreDef.item_coding, itemID))
            {
              coding <- GetProperty(scoreDef.item_coding, itemID)
            }
          }

          if(coding != 0)
          {
            ## For multi/multicheck items, the option value already encodes
            ## the scoring direction — use it directly without range reversal.
            ## (Reversal via item_coding only applies to Likert/VAS/grid types.)
            if(PropertyExists(qdef, "type") and
               (qdef.type == "multi" or qdef.type == "multicheck"))
            {
              PushOnEnd(values, resp)
            } else {
              coded <- CodeResponse(resp, coding, minVal, maxVal)
              PushOnEnd(values, coded)
            }

            ## Track weight for this item (default 1)
            w <- 1
            if(PropertyExists(scoreDef, "weights") and PropertyExists(scoreDef.weights, itemID))
            {
              w <- GetProperty(scoreDef.weights, itemID)
            }
            PushOnEnd(itemWeights, w)
          }
        }
      }
    }
  }

  ## Process score inputs (composite scoring — pass 2 only)
  if(PropertyExists(scoreDef, "scores"))
  {
    loop(scoreID, scoreDef.scores)
    {
      coding <- 0
      if(PropertyExists(scoreDef, "item_coding"))
      {
        if(PropertyExists(scoreDef.item_coding, scoreID))
        {
          coding <- GetProperty(scoreDef.item_coding, scoreID)
        }
      }

      if(coding != 0)
      {
        ## Prefer transformed score; fall back to raw score
        scoreVal <- 0
        hasVal   <- 0
        if(PropertyExists(prevTScores, scoreID))
        {
          scoreVal <- GetProperty(prevTScores, scoreID)
          hasVal   <- 1
        } elseif(PropertyExists(prevScores, scoreID))
        {
          scoreVal <- GetProperty(prevScores, scoreID)
          hasVal   <- 1
        }

        if(hasVal)
        {
          ## coding=1: forward; coding=-1: negate; coding=0: exclude
          codedVal <- scoreVal * coding
          PushOnEnd(values, codedVal)

          w <- 1
          if(PropertyExists(scoreDef, "weights") and PropertyExists(scoreDef.weights, scoreID))
          {
            w <- GetProperty(scoreDef.weights, scoreID)
          }
          PushOnEnd(itemWeights, w)
        }
      }
    }
  }

  ## Compute composite based on method
  result <- 0

  if(Length(values) == 0)
  {
    result <- 0
  } elseif(method == "sum_coded")
  {
    result <- Sum(values)
  } elseif(method == "mean_coded")
  {
    result <- Mean(values)
  } elseif(method == "weighted_sum")
  {
    wTotal <- 0
    idx    <- 1
    loop(v, values)
    {
      wTotal <- wTotal + v * Nth(itemWeights, idx)
      idx    <- idx + 1
    }
    result <- wTotal
  } elseif(method == "weighted_mean")
  {
    wTotal  <- 0
    wSum    <- 0
    idx     <- 1
    loop(v, values)
    {
      w      <- Nth(itemWeights, idx)
      wTotal <- wTotal + v * w
      wSum   <- wSum + w
      idx    <- idx + 1
    }
    if(wSum != 0)
    {
      result <- wTotal / wSum
    }
  } elseif(method == "sum_correct")
  {
    ## Count number of correct responses
    ## Supports correct_answers map in scoring section (preferred)
    ## Falls back to correct_answer on question definition (backward compat)
    ## Handles short/long/multi (text match), multicheck (set match), grid (per-row match)
    ## Patterns support * (any chars) and ? (single char) wildcards
    numCorrect <- 0

    ## Check for correct_answers map in scoring definition
    hasCorrectMap <- PropertyExists(scoreDef, "correct_answers")

    loop(itemID, itemIDs)
    {
      if(PropertyExists(questionMap, itemID) and PropertyExists(responseMap, itemID))
      {
        qdef <- GetProperty(questionMap, itemID)
        resp <- GetProperty(responseMap, itemID)
        qtype <- qdef.type

        ## Get correct answer list for this item
        correctList <- []

        if(hasCorrectMap and PropertyExists(scoreDef.correct_answers, itemID))
        {
          correctList <- GetProperty(scoreDef.correct_answers, itemID)
        } elseif(PropertyExists(qdef, "correct_answer"))
        {
          ## Backward compatibility: single string on question
          correctList <- [qdef.correct_answer + ""]
        }

        if(Length(correctList) > 0)
        {
          if(qtype == "grid")
          {
            ## Grid: space-separated row values, compare per-row
            ## Each correct row adds 1 point
            gridResponses <- SplitString(resp + "", " ")
            rowIdx <- 1
            loop(correctVal, correctList)
            {
              if(rowIdx <= Length(gridResponses))
              {
                rowResp <- Nth(gridResponses, rowIdx)
                if(WildcardMatch(rowResp + "", correctVal + ""))
                {
                  numCorrect <- numCorrect + 1
                }
              }
              rowIdx <- rowIdx + 1
            }
          } elseif(qtype == "multicheck")
          {
            ## Multicheck: pipe-separated selected options
            ## Correct if selected set exactly matches correct answer set
            respParts <- SplitString(resp + "", "|")

            ## Normalize both to lowercase trimmed
            normResp <- []
            loop(r, respParts)
            {
              PushOnEnd(normResp, Lowercase(StripSpace(r + "")))
            }

            normCorrect <- []
            loop(c, correctList)
            {
              PushOnEnd(normCorrect, Lowercase(StripSpace(c + "")))
            }

            ## Check set equality: same length and all correct items in response
            if(Length(normResp) == Length(normCorrect))
            {
              allFound <- 1
              loop(c, normCorrect)
              {
                if(not IsMember(c, normResp))
                {
                  allFound <- 0
                }
              }
              if(allFound == 1)
              {
                numCorrect <- numCorrect + 1
              }
            }
          } else {
            ## Short, long, multi, imageresponse: text match against patterns
            respStr <- Lowercase(StripSpace(resp + ""))
            if(MatchesAnyPattern(respStr, correctList))
            {
              numCorrect <- numCorrect + 1
            }
          }
        }
      }
    }
    result <- numCorrect
  } else {
    Print("WARNING: Unknown scoring method: " + method)
  }

  return([result, values])
}


define ApplyTransform(rawScore, transformSteps, codedValues)
{
  ## Build a simple named-stats object for transforms that reference stats
  stats <- MakeCustomObject("stats")
  n <- Length(codedValues)
  if(n > 0)
  {
    SetProperty(stats, "sum",   Sum(codedValues))
    SetProperty(stats, "mean",  Mean(codedValues))
    SetProperty(stats, "min",   Min(codedValues))
    SetProperty(stats, "max",   Max(codedValues))
    SetProperty(stats, "range", Max(codedValues) - Min(codedValues))
    SetProperty(stats, "n",     n)
    SetProperty(stats, "sd",    StdDev(codedValues))
  }

  result <- rawScore
  loop(step, transformSteps)
  {
    op  <- step.op
    val <- step.value
    if(IsString(val))
    {
      if(PropertyExists(stats, val)) { val <- GetProperty(stats, val) }
      else { val <- 0 }
    }
    if(op == "add")          { result <- result + val }
    elseif(op == "subtract") { result <- result - val }
    elseif(op == "multiply") { result <- result * val }
    elseif(op == "divide")
    {
      if(val != 0) { result <- result / val }
    }
  }
  return(result)
}


define CodeResponse(response, coding, minVal, maxVal)
{
  ## Apply coding to response value
  ## Reverse coding formula: reversed = (min + max) - response
  ##
  ## This formula works for any range:
  ##   Binary (0,1):  reversed = 1 - response  (0→1, 1→0)
  ##   Likert (1,5):  reversed = 6 - response  (1→5, 2→4, 3→3, 4→2, 5→1)
  ##   Custom (50,300): reversed = 350 - response (50→300, 300→50)

  result <- response

  if(coding < 0)
  {
    ## Apply reverse coding: swap min↔max
    result <- (minVal + maxVal) - response
  }

  return(result)
}


define BuildQuestionMap(questions)
{
  ## Build lookup table: questionID -> question definition object
  ## For grid items, also register sub-item IDs (gridId_1, gridId_2, ...)
  ## pointing to the parent grid definition so range lookup works.
  map <- MakeCustomObject("questionMap")

  loop(qdef, questions)
  {
    SetProperty(map, qdef.id, qdef)
    if(PropertyExists(qdef, "type") and qdef.type == "grid")
    {
      if(PropertyExists(qdef, "rows"))
      {
        rowIdx <- 1
        loop(rowKey, qdef.rows)
        {
          subID <- qdef.id + "_" + rowIdx
          SetProperty(map, subID, qdef)
          rowIdx <- rowIdx + 1
        }
      }
    }
  }

  return(map)
}


define BuildResponseMap(results)
{
  ## Build lookup table: questionID -> response value
  ## For grid items, also expand sub-item entries: gridId_1, gridId_2, ...
  map <- MakeCustomObject("responseMap")
  index <- 1

  loop(qdef, results.items)
  {
    resp <- Nth(results.responses, index)
    SetProperty(map, qdef.id, resp)
    if(PropertyExists(qdef, "type") and qdef.type == "grid")
    {
      if(PropertyExists(qdef, "rows"))
      {
        parts <- SplitString(resp + "", " ")
        rowIdx <- 1
        loop(rowKey, qdef.rows)
        {
          subID  <- qdef.id + "_" + rowIdx
          subVal <- ""
          if(rowIdx <= Length(parts))
          {
            subVal <- Nth(parts, rowIdx)
          }
          ## Store as number (grid responses are always integer column indices)
          if(StringLength(subVal + "") > 0)
          {
            SetProperty(map, subID, ToNumber(subVal))
          }
          rowIdx <- rowIdx + 1
        }
      }
    }
    index <- index + 1
  }

  return(map)
}


define WildcardMatch(text, pattern)
{
  ## Glob matching: * matches any sequence, ? matches single char
  ## Case-insensitive by default; prefix pattern with (?c) for case-sensitive
  ## Returns 1 if match, 0 if no match
  rawP <- StripSpace(pattern + "")
  rawT <- StripSpace(text + "")

  ## Check for (?c) case-sensitive prefix
  caseSensitive <- 0
  if(StringLength(rawP) >= 4)
  {
    if(SubString(rawP, 1, 4) == "(?c)")
    {
      caseSensitive <- 1
      rawP <- SubString(rawP, 5, StringLength(rawP) - 4)
    }
  }

  if(caseSensitive == 0)
  {
    t <- Lowercase(rawT)
    p <- Lowercase(rawP)
  } else {
    t <- rawT
    p <- rawP
  }

  tLen <- StringLength(t)
  pLen <- StringLength(p)

  matched <- 1

  if(pLen == 0)
  {
    ## Empty pattern only matches empty text
    if(tLen > 0)
    {
      matched <- 0
    }
  } else {
    ## Iterative two-pointer wildcard matching
    ti <- 1
    pi <- 1
    starPI <- 0
    starTI <- 0

    while((ti <= tLen or pi <= pLen) and matched == 1)
    {
      if(pi <= pLen)
      {
        pc <- SubString(p, pi, 1)
      } else {
        pc <- ""
      }

      if(ti <= tLen)
      {
        tc <- SubString(t, ti, 1)
      } else {
        tc <- ""
      }

      if(pc == "*")
      {
        ## Star: remember position and advance pattern
        starPI <- pi
        starTI <- ti
        pi <- pi + 1
      } elseif(ti <= tLen and (pc == "?" or pc == tc))
      {
        ## Direct match or single-char wildcard
        ti <- ti + 1
        pi <- pi + 1
      } elseif(starPI > 0 and starTI <= tLen)
      {
        ## Mismatch: backtrack to last star, consume one more text char
        pi <- starPI + 1
        starTI <- starTI + 1
        ti <- starTI
      } else {
        ## No match possible
        matched <- 0
      }
    }
  }

  return(matched)
}


define InterpretScore(score, scoreDef)
{
  ## Returns the norm threshold label for a score, or "" if no norms defined.
  ## Supports both "label" (literal string) and "label_key" (translation key).
  result <- ""
  if(PropertyExists(scoreDef, "norms"))
  {
    normsObj <- scoreDef.norms
    if(PropertyExists(normsObj, "thresholds"))
    {
      loop(t, normsObj.thresholds)
      {
        if(score >= t.min and score <= t.max)
        {
          if(PropertyExists(t, "label_key"))
          {
            if(PropertyExists(gStrings, t.label_key))
            {
              result <- GetProperty(gStrings, t.label_key)
            } else {
              result <- t.label_key
            }
          } else {
            if(PropertyExists(t, "label"))
            {
              result <- t.label
            }
          }
        }
      }
    }
  }
  return(result)
}


define MatchesAnyPattern(text, patternList)
{
  ## Check if text matches any pattern in the list (case-insensitive with wildcards)
  ## Returns 1 if any match, 0 if none
  found <- 0

  loop(pattern, patternList)
  {
    if(WildcardMatch(text, pattern) == 1)
    {
      found <- 1
    }
  }

  return(found)
}


define CheckItemCorrectness(qdef, resp, scoreDef)
{
  ## Check if a single item's response is correct for sum_correct scoring
  ## Returns 1 if correct, 0 if not
  ## Handles short/long/multi/imageresponse (text match) and multicheck (set match)
  ## Grid rows should be checked individually, not with this function
  correct <- 0
  itemID <- qdef.id

  ## Get correct answer list
  correctList <- []
  if(PropertyExists(scoreDef, "correct_answers") and PropertyExists(scoreDef.correct_answers, itemID))
  {
    correctList <- GetProperty(scoreDef.correct_answers, itemID)
  } elseif(PropertyExists(qdef, "correct_answer"))
  {
    correctList <- [qdef.correct_answer + ""]
  }

  if(Length(correctList) > 0)
  {
    if(qdef.type == "multicheck")
    {
      ## Set comparison: pipe-separated selected options must match correct set
      respParts <- SplitString(resp + "", "|")
      normResp <- []
      loop(r, respParts)
      {
        PushOnEnd(normResp, Lowercase(StripSpace(r + "")))
      }
      normCorrect <- []
      loop(c, correctList)
      {
        PushOnEnd(normCorrect, Lowercase(StripSpace(c + "")))
      }
      if(Length(normResp) == Length(normCorrect))
      {
        allFound <- 1
        loop(c, normCorrect)
        {
          if(not IsMember(c, normResp))
          {
            allFound <- 0
          }
        }
        correct <- allFound
      }
    } else {
      ## Text match for short/long/multi/imageresponse
      respStr <- Lowercase(StripSpace(resp + ""))
      correct <- MatchesAnyPattern(respStr, correctList)
    }
  }

  return(correct)
}


##############################################################################
## DATA SAVING
##############################################################################

define SaveIndividualData(results, transformedScores, scaleDef)
{
  ## Save detailed trial-by-trial data with dynamic dimension columns
  index <- 1
  loop(qdef, results.items)
  {
    order <- Nth(results.order, index)
    resp <- Nth(results.responses, index)
    rt <- Nth(results.rts, index)
    timestamp <- Nth(results.timestamps, index)

    ## Skip questions hidden by visible_when (recorded as NA with rt 0)
    ## Use nested ifs because PEBL does not short-circuit 'and'
    skipQuestion <- 0
    if(resp == "NA")
    {
      if(rt == 0)
      {
        if(PropertyExists(qdef, "visible_when"))
        {
          skipQuestion <- 1
        }
      }
    }

    if(skipQuestion)
    {
      index <- index + 1
    } else {

    ## Look up question text from translations
    questionText <- ""
    if(PropertyExists(gStrings, qdef.text_key))
    {
      questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))
      ## Replace commas to prevent breaking CSV format
      questionText <- ReplaceChar(questionText, ",", "|")
    }

    ## Special handling for grid questions - save as multiple rows
    if(qdef.type == "grid")
    {
      ## Parse grid response (space-separated ratings)
      gridResponses <- SplitString(resp, " ")

      ## Get row labels from question definition
      rowLabels <- []
      if(PropertyExists(qdef, "subitems"))
      {
        ## Old format: objects with text_key
        loop(subitem, qdef.subitems)
        {
          itemText <- GetProperty(gStrings, subitem.text_key)
          PushOnEnd(rowLabels, itemText)
        }
      } elseif(PropertyExists(qdef, "rows"))
      {
        ## Scale Builder format: literal text in rows array
        rowLabels <- qdef.rows
      }

      ## Save one row per grid item
      rowIdx <- 1
      loop(rowLabel, rowLabels)
      {
        ## Check if we have a response for this row
        if(rowIdx <= Length(gridResponses))
        {
          ## Clean row label for CSV (replace commas with pipes)
          cleanRowLabel <- ReplaceChar(rowLabel, ",", "|")

          ## Create modified IDs with numeric suffix (_1, _2, _3)
          modifiedQuestionId <- qdef.id + "_" + rowIdx
          modifiedTextKey <- qdef.text_key + "_" + rowIdx

          ## Create modified question text: questionText: rowLabel
          modifiedQuestionText <- questionText + ": " + cleanRowLabel

          ## Get response for this row
          rowResp <- Nth(gridResponses, rowIdx)

          ## Build data line with modified question_id and text_key
          dataline <- [gSubNum, order, timestamp, modifiedQuestionId, modifiedTextKey, modifiedQuestionText, rowResp, rt]

          ## Add dimension values for grid rows
          if(PropertyExists(scaleDef, "dimensions") and PropertyExists(scaleDef, "scoring"))
          {
            loop(dim, scaleDef.dimensions)
            {
              gridDimValue <- ""
              if(PropertyExists(scaleDef.scoring, dim.id))
              {
                gridScoreDef <- GetProperty(scaleDef.scoring, dim.id)
                gridItemIDs <- gridScoreDef.items

                ## Check if this grid row sub-item is in this dimension
                ## Sub-item IDs are gridId_1, gridId_2, ... (not the parent gridId)
                gridSubID <- qdef.id + "_" + rowIdx
                gridIsMember <- 0
                loop(gridItemID, gridItemIDs)
                {
                  if(gridItemID == gridSubID)
                  {
                    gridIsMember <- 1
                    break
                  }
                }

                if(gridIsMember)
                {
                  if(gridScoreDef.method == "sum_correct")
                  {
                    ## Check this row against corresponding correct answer
                    gridCorrectList <- []
                    if(PropertyExists(gridScoreDef, "correct_answers") and PropertyExists(gridScoreDef.correct_answers, gridSubID))
                    {
                      gridCorrectList <- GetProperty(gridScoreDef.correct_answers, gridSubID)
                    }
                    if(Length(gridCorrectList) > 0)
                    {
                      correctVal <- First(gridCorrectList)
                      if(WildcardMatch(rowResp + "", correctVal + ""))
                      {
                        gridDimValue <- 1
                      } else {
                        gridDimValue <- 0
                      }
                    }
                  } elseif(IsNumber(rowResp))
                  {
                    ## Coded value for grid row
                    gridRange <- GetQuestionRange(qdef, scaleDef)
                    gridMinVal <- First(gridRange)
                    gridMaxVal <- Second(gridRange)
                    gridCoding <- 1
                    if(PropertyExists(gridScoreDef, "item_coding") and PropertyExists(gridScoreDef.item_coding, gridSubID))
                    {
                      gridCoding <- GetProperty(gridScoreDef.item_coding, gridSubID)
                    }
                    gridDimValue <- CodeResponse(rowResp, gridCoding, gridMinVal, gridMaxVal)
                  }
                }
              }
              PushOnEnd(dataline, gridDimValue)
            }
          }

          ## Add transformed dim values for dims that have a transform
          if(PropertyExists(scaleDef, "dimensions") and PropertyExists(scaleDef, "scoring"))
          {
            loop(dim, scaleDef.dimensions)
            {
              if(PropertyExists(scaleDef.scoring, dim.id))
              {
                gridTScoreDef <- GetProperty(scaleDef.scoring, dim.id)
                if(PropertyExists(gridTScoreDef, "transform"))
                {
                  ## Check if this grid row sub-item is in this dimension
                  gridTMember <- 0
                  loop(gridTItemID, gridTScoreDef.items)
                  {
                    if(gridTItemID == gridSubID)
                    {
                      gridTMember <- 1
                      break
                    }
                  }
                  if(gridTMember and PropertyExists(transformedScores, dim.id))
                  {
                    PushOnEnd(dataline, GetProperty(transformedScores, dim.id))
                  } else {
                    PushOnEnd(dataline, "")
                  }
                }
              }
            }
          }

          FilePrint(gFileOut, ConcatenateList(dataline, ","))
        }
        rowIdx <- rowIdx + 1
      }
    } else {
      ## Regular question - save as single row

      ## Quote text responses (short/long answers) to protect commas
      quotedResp <- resp
      if(qdef.type == "short" or qdef.type == "long")
      {
        quotedResp <- QuoteCSVField(resp)
      }

      ## Build data line with fixed columns
      dataline <- [gSubNum, order, timestamp, qdef.id, qdef.text_key, questionText, quotedResp, rt]

      ## Add dimension values (recoded per dimension)
      if(PropertyExists(scaleDef, "dimensions") and PropertyExists(scaleDef, "scoring"))
      {
        loop(dim, scaleDef.dimensions)
        {
          ## Check if this question belongs to this dimension
          dimValue <- ""  ## Default to empty

          if(PropertyExists(scaleDef.scoring, dim.id))
          {
            scoreDef <- GetProperty(scaleDef.scoring, dim.id)
            itemIDs <- scoreDef.items

            ## Check if current question is in this dimension's items
            isMember <- 0
            loop(itemID, itemIDs)
            {
              if(itemID == qdef.id)
              {
                isMember <- 1
                break
              }
            }

            if(isMember)
            {
              if(scoreDef.method == "sum_correct")
              {
                ## For sum_correct: 1 if correct, 0 if not
                dimValue <- CheckItemCorrectness(qdef, resp, scoreDef)
              } elseif(IsNumber(resp))
              {
                ## For coded methods: compute recoded value
                ## Note: resp can be 0 (valid response), so check if numeric
                range <- GetQuestionRange(qdef, scaleDef)
                minVal <- First(range)
                maxVal <- Second(range)

                ## Get dimension-specific coding
                coding <- 1
                if(PropertyExists(scoreDef, "item_coding") and PropertyExists(scoreDef.item_coding, qdef.id))
                {
                  coding <- GetProperty(scoreDef.item_coding, qdef.id)
                }

                dimValue <- CodeResponse(resp, coding, minVal, maxVal)
              }
            }
          }

          PushOnEnd(dataline, dimValue)
        }
      }

      ## Add transformed dim values for dims that have a transform
      if(PropertyExists(scaleDef, "dimensions") and PropertyExists(scaleDef, "scoring"))
      {
        loop(dim, scaleDef.dimensions)
        {
          if(PropertyExists(scaleDef.scoring, dim.id))
          {
            tScoreDef <- GetProperty(scaleDef.scoring, dim.id)
            if(PropertyExists(tScoreDef, "transform"))
            {
              ## Check if this question is in this dimension
              tIsMember <- 0
              loop(tItemID, tScoreDef.items)
              {
                if(tItemID == qdef.id)
                {
                  tIsMember <- 1
                  break
                }
              }
              if(tIsMember and PropertyExists(transformedScores, dim.id))
              {
                PushOnEnd(dataline, GetProperty(transformedScores, dim.id))
              } else {
                PushOnEnd(dataline, "")
              }
            }
          }
        }
      }

      FilePrint(gFileOut, ConcatenateList(dataline, ","))
    }

    index <- index + 1
    } ## end else (not hidden)
  }
}


define SavePooledData(results, scores, transformedScores, scaleDef)
{
  ## Save one-line summary with all responses and dimension scores.
  ## Uses definition order (scaleDef.items) so columns match
  ## BuildPooledHeader, regardless of randomized presentation order.
  line <- gSubNum + "," + TimeStamp() + "," + gCompletionTime

  ## Add all responses in definition order via responseMap
  loop(qdef, scaleDef.items)
  {
    ## Look up response by question ID
    resp <- "NA"
    if(PropertyExists(results.responseMap, qdef.id))
    {
      resp <- GetProperty(results.responseMap, qdef.id)
    }

    ## Special handling for grid questions - save as multiple columns
    if(qdef.type == "grid")
    {
      ## Parse grid response (space-separated ratings)
      gridResponses <- SplitString(resp, " ")

      ## Add each grid response as separate column
      loop(gridResp, gridResponses)
      {
        line <- line + "," + gridResp
      }
    } else {
      ## Regular question - save as single column

      ## Quote text responses (short/long answers) to protect commas
      quotedResp <- resp
      if(qdef.type == "short" or qdef.type == "long")
      {
        quotedResp <- QuoteCSVField(resp)
      }

      line <- line + "," + quotedResp
    }
  }

  ## Add dimension scores
  if(PropertyExists(scaleDef, "dimensions"))
  {
    loop(dim, scaleDef.dimensions)
    {
      if(PropertyExists(scores, dim.id))
      {
        score <- GetProperty(scores, dim.id)
        line <- line + "," + score
      } else {
        line <- line + ",NA"
      }
    }
  }

  ## Add transformed dimension scores (_t columns, only for dims with transform defined)
  if(PropertyExists(scaleDef, "dimensions") and PropertyExists(scaleDef, "scoring"))
  {
    loop(dim, scaleDef.dimensions)
    {
      if(PropertyExists(scaleDef.scoring, dim.id))
      {
        pooledScoreDef <- GetProperty(scaleDef.scoring, dim.id)
        if(PropertyExists(pooledScoreDef, "transform"))
        {
          if(PropertyExists(transformedScores, dim.id))
          {
            tScore <- GetProperty(transformedScores, dim.id)
            line <- line + "," + tScore
          } else {
            line <- line + ",NA"
          }
        }
      }
    }
  }

  ## Add branch arm choices (must match BuildPooledHeader column order)
  if(PropertyExists(scaleDef, "branches"))
  {
    loop(branchGroup, scaleDef.branches)
    {
      armChoice <- "NA"
      if(PropertyExists(gBranchChoices, branchGroup.id))
      {
        armChoice <- GetProperty(gBranchChoices, branchGroup.id)
      }
      line <- line + "," + armChoice
    }
  }

  FilePrint(gPooledFile, line)
  return(line)
}


##############################################################################
## BuildPooledHeader: generates the CSV header for the pooled data file
## matching the column order produced by SavePooledData.
## Columns: subnum, timestamp, time, [question columns], [dimension scores]
## Grid questions are expanded to one column per row (id_1, id_2, ...).
##############################################################################
define BuildPooledHeader(scaleDef)
{
  header <- "subnum,timestamp,time"

  ## Add question columns
  loop(qdef, scaleDef.items)
  {
    if(qdef.type == "grid")
    {
      ## Count rows for this grid question
      numRows <- 0
      if(PropertyExists(qdef, "subitems"))
      {
        numRows <- Length(qdef.subitems)
      } elseif(PropertyExists(qdef, "rows"))
      {
        numRows <- Length(qdef.rows)
      }

      ## One column per grid row: id_1, id_2, ...
      loop(rowIdx, Sequence(1, numRows, 1))
      {
        header <- header + "," + qdef.id + "_" + rowIdx
      }
    } else {
      header <- header + "," + qdef.id
    }
  }

  ## Add dimension score columns
  if(PropertyExists(scaleDef, "dimensions"))
  {
    loop(dim, scaleDef.dimensions)
    {
      header <- header + "," + dim.id
    }
  }

  ## Add transformed dimension score columns (_t) for dims with transform defined
  if(PropertyExists(scaleDef, "dimensions") and PropertyExists(scaleDef, "scoring"))
  {
    loop(dim, scaleDef.dimensions)
    {
      if(PropertyExists(scaleDef.scoring, dim.id))
      {
        hdrScoreDef <- GetProperty(scaleDef.scoring, dim.id)
        if(PropertyExists(hdrScoreDef, "transform"))
        {
          header <- header + "," + dim.id + "_t"
        }
      }
    }
  }

  ## Add branch arm columns (one per branch group: {group_id}_arm)
  if(PropertyExists(scaleDef, "branches"))
  {
    loop(branchGroup, scaleDef.branches)
    {
      header <- header + "," + branchGroup.id + "_arm"
    }
  }

  return(header)
}


##############################################################################
## REPORT GENERATION
##############################################################################

define GenerateReport(results, scores, transformedScores, scaleDef, computedVars:0)
{
  ## Generate HTML report with dimension scores and response table
  safeCode <- ReplaceChar(gScaleDef.scale_info.code, [" ", "/", "\", ":", ",", "|"], "_")
  reportFilename <- safeCode + "-report-" + gSubNum + ".html"

  Print("Creating HTML report...")

  subNoSpc <- ReplaceChar(gSubNum + "", [" ", "/", "\", ",", ":"], "_")

  ## Save HTML report in same subdirectory as individual CSV
  reportPath <- GetDirectory(gFileOut.filename) + reportFilename
  htmlFile <- FileOpenWrite(reportPath)

  ##############################################################################
  ## HTML HEADER AND CSS
  ##############################################################################

  FilePrint(htmlFile, "<html><head><title>" + scaleDef.scale_info.name + " Report - " + gSubNum + "</title>")
  FilePrint(htmlFile, "<style>")
  FilePrint(htmlFile, "body { font-family: Arial, sans-serif; margin: 40px; }")
  FilePrint(htmlFile, "table { border-collapse: collapse; margin: 20px 0; }")
  FilePrint(htmlFile, "th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }")
  FilePrint(htmlFile, "th { background-color: #4CAF50; color: white; }")
  FilePrint(htmlFile, "tr:nth-child(even) { background-color: #f2f2f2; }")
  FilePrint(htmlFile, ".summary { background-color: #e7f3e7; padding: 20px; border-radius: 5px; margin: 20px 0; }")
  FilePrint(htmlFile, "h1 { color: #333; }")
  FilePrint(htmlFile, "h2 { color: #666; }")
  FilePrint(htmlFile, ".citation { font-style: italic; color: #666; margin: 10px 0; }")
  FilePrint(htmlFile, ".norm-label { font-style: italic; color: #555; }")
  FilePrint(htmlFile, "</style></head><body>")

  ##############################################################################
  ## TITLE AND METADATA
  ##############################################################################

  FilePrint(htmlFile, H(scaleDef.scale_info.name, 1))

  if(PropertyExists(scaleDef.scale_info, "citation"))
  {
    FilePrint(htmlFile, P("<span class='citation'>" + scaleDef.scale_info.citation + "</span>"))
  }

  ## License information
  licenseText <- ""
  if(PropertyExists(scaleDef.scale_info, "license"))
  {
    licenseText <- scaleDef.scale_info.license
  }
  if(PropertyExists(scaleDef.scale_info, "license_explanation"))
  {
    if(licenseText != "")
    {
      licenseText <- licenseText + " — "
    }
    licenseText <- licenseText + scaleDef.scale_info.license_explanation
  }
  if(licenseText != "")
  {
    FilePrint(htmlFile, P("<span class='citation'>License: " + licenseText + "</span>"))
  }
  if(PropertyExists(scaleDef.scale_info, "license_url"))
  {
    if(scaleDef.scale_info.license_url != "")
    {
      FilePrint(htmlFile, P("<span class='citation'><a href='" + scaleDef.scale_info.license_url + "'>" + scaleDef.scale_info.license_url + "</a></span>"))
    }
  }

  FilePrint(htmlFile, P("Participant: " + B(gSubNum)))
  FilePrint(htmlFile, P("Test Date: " + B(TimeStamp())))
  FilePrint(htmlFile, HL())

  ##############################################################################
  ## SUMMARY SECTION
  ##############################################################################

  FilePrint(htmlFile, "<div class='summary'>")
  FilePrint(htmlFile, H("Summary", 2))
  FilePrint(htmlFile, P(B("Completion Time: ") + Round((gCompletionTime/1000/60)*100)/100 + " minutes"))

  ## Add description if available
  if(PropertyExists(scaleDef.scale_info, "description"))
  {
    FilePrint(htmlFile, P(scaleDef.scale_info.description))
  }

  FilePrint(htmlFile, "</div>")

  ##############################################################################
  ## DIMENSION SCORES
  ##############################################################################

  if(PropertyExists(scaleDef, "dimensions"))
  {
    FilePrint(htmlFile, H("Dimension Scores", 2))

    ## Build table data with optional norm interpretation and transforms
    tableData <- []
    hasNorms <- 0
    hasTrans <- 0
    loop(dim, scaleDef.dimensions)
    {
      if(PropertyExists(scores, dim.id))
      {
        score <- GetProperty(scores, dim.id)
        normLabel <- ""
        if(PropertyExists(scaleDef.scoring, dim.id))
        {
          dimScoreDef <- GetProperty(scaleDef.scoring, dim.id)
          normLabel <- InterpretScore(score, dimScoreDef)
        }
        if(normLabel != "")
        {
          hasNorms <- 1
        }
        tScoreStr <- ""
        if(PropertyExists(transformedScores, dim.id))
        {
          tScore <- GetProperty(transformedScores, dim.id)
          tScoreStr <- Round(tScore*100)/100 + ""
          hasTrans <- 1
        }
        rowData <- [dim.name, Round(score*100)/100 + "", tScoreStr, normLabel]
        PushOnEnd(tableData, rowData)
      }
    }

    ## Generate table — choose columns based on available data
    if(hasTrans == 1 or hasNorms == 1)
    {
      FilePrint(htmlFile, Table(tableData, ["Dimension", "Score", "Transformed", "Interpretation"]))
    } else {
      tableData2 <- []
      loop(row, tableData)
      {
        PushOnEnd(tableData2, [Nth(row, 1), Nth(row, 2)])
      }
      FilePrint(htmlFile, Table(tableData2, ["Dimension", "Score"]))
    }
  }

  ##############################################################################
  ## COMPUTED VARIABLES
  ##############################################################################

  if(computedVars != 0 and PropertyExists(scaleDef, "computed"))
  {
    cvNames <- GetPropertyList(scaleDef.computed)
    if(Length(cvNames) > 0)
    {
      FilePrint(htmlFile, H("Computed Variables", 2))
      FilePrint(htmlFile, "<table><thead><tr><th>Variable</th><th>Value</th><th>Type</th><th>Interpretation</th></tr></thead>")
      loop(cvName, cvNames)
      {
        cvDef <- GetProperty(scaleDef.computed, cvName)
        cvVal <- ""
        if(PropertyExists(computedVars, cvName))
        {
          cvVal <- GetProperty(computedVars, cvName) + ""
        }
        cvType <- "number"
        if(PropertyExists(cvDef, "type"))
        {
          cvType <- cvDef.type
        }
        normLabel <- ""
        if(PropertyExists(cvDef, "norms"))
        {
          normLabel <- InterpretScore(ToNumber(cvVal), cvDef)
        }
        FilePrint(htmlFile, "<tr><td>" + cvName + "</td><td>" + cvVal + "</td><td>" + cvType + "</td><td><span class='norm-label'>" + normLabel + "</span></td></tr>")
      }
      FilePrint(htmlFile, "</table>")
    }
  }

  ##############################################################################
  ## RESPONSE TABLE
  ##############################################################################

  FilePrint(htmlFile, H("Responses", 2))

  ## Build header row: Question, Response, then one column per dimension
  respHeaders <- ["Question", "Response"]
  if(PropertyExists(scaleDef, "dimensions"))
  {
    loop(dim, scaleDef.dimensions)
    {
      PushOnEnd(respHeaders, dim.name)
    }
  }

  ## Build table rows in definition order using responseMap
  respTableData <- []
  loop(qdef, scaleDef.items)
  {
    ## Look up response by question ID
    resp <- "NA"
    if(PropertyExists(results.responseMap, qdef.id))
    {
      resp <- GetProperty(results.responseMap, qdef.id)
    }

    ## Skip questions hidden by visible_when (response is NA)
    rptSkip <- 0
    if(resp == "NA")
    {
      if(PropertyExists(qdef, "visible_when"))
      {
        rptSkip <- 1
      }
    }

    ## Skip instruction and image-only questions
    if(qdef.type == "inst" or qdef.type == "image")
    {
      rptSkip <- 1
    }

    if(not rptSkip)
    {
      ## Get question text
      qText <- ""
      if(PropertyExists(gStrings, qdef.text_key))
      {
        qText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))
      } else {
        qText <- qdef.text_key
      }

      ## Truncate long question text for readability
      if(StringLength(qText) > 120)
      {
        qText <- SubString(qText, 1, 117) + "..."
      }

      if(qdef.type == "grid")
      {
        ## Expand grid into one report row per sub-item
        gridResps <- SplitString(resp + "", " ")
        rptGridRange <- GetQuestionRange(qdef, scaleDef)
        rptGridMin <- First(rptGridRange)
        rptGridMax <- Second(rptGridRange)
        ## Support both new format (rows array) and old format (subitems)
        rptRows <- []
        if(PropertyExists(qdef, "rows"))
        {
          rptRows <- qdef.rows
        } elseif(PropertyExists(qdef, "subitems"))
        {
          loop(rptSub, qdef.subitems) { PushOnEnd(rptRows, rptSub.text_key) }
        }
        rptRowIdx <- 1
        loop(rowKey, rptRows)
        {
          subResp <- "NA"
          if(rptRowIdx <= Length(gridResps))
          {
            subResp <- Nth(gridResps, rptRowIdx)
          }

          rowText <- rowKey
          if(PropertyExists(gStrings, rowKey))
          {
            rowText <- GetProperty(gStrings, rowKey)
          }

          rptSubID <- qdef.id + "_" + rptRowIdx
          rowData <- [rowText, subResp + ""]

          if(PropertyExists(scaleDef, "dimensions") and PropertyExists(scaleDef, "scoring"))
          {
            loop(dim, scaleDef.dimensions)
            {
              dimVal <- ""
              if(PropertyExists(scaleDef.scoring, dim.id))
              {
                rptScoreDef <- GetProperty(scaleDef.scoring, dim.id)
                rptItemIDs <- rptScoreDef.items

                rptIsMember <- 0
                loop(rptItemID, rptItemIDs)
                {
                  if(rptItemID == rptSubID)
                  {
                    rptIsMember <- 1
                    break
                  }
                }

                if(rptIsMember and IsNumber(subResp))
                {
                  rptCoding <- 1
                  if(PropertyExists(rptScoreDef, "item_coding") and PropertyExists(rptScoreDef.item_coding, rptSubID))
                  {
                    rptCoding <- GetProperty(rptScoreDef.item_coding, rptSubID)
                  }
                  dimVal <- CodeResponse(subResp, rptCoding, rptGridMin, rptGridMax) + ""
                }
              }
              PushOnEnd(rowData, dimVal)
            }
          }

          PushOnEnd(respTableData, rowData)
          rptRowIdx <- rptRowIdx + 1
        }
      } else {

      rowData <- [qText, resp + ""]

      ## Add per-dimension scored values
      if(PropertyExists(scaleDef, "dimensions") and PropertyExists(scaleDef, "scoring"))
      {
        loop(dim, scaleDef.dimensions)
        {
          dimVal <- ""
          if(PropertyExists(scaleDef.scoring, dim.id))
          {
            rptScoreDef <- GetProperty(scaleDef.scoring, dim.id)
            rptItemIDs <- rptScoreDef.items

            ## Check if this question belongs to this dimension
            rptIsMember <- 0
            loop(rptItemID, rptItemIDs)
            {
              if(rptItemID == qdef.id)
              {
                rptIsMember <- 1
                break
              }
            }

            if(rptIsMember)
            {
              if(rptScoreDef.method == "sum_correct")
              {
                dimVal <- CheckItemCorrectness(qdef, resp, rptScoreDef) + ""
              } elseif(IsNumber(resp))
              {
                rptRange <- GetQuestionRange(qdef, scaleDef)
                rptMinVal <- First(rptRange)
                rptMaxVal <- Second(rptRange)
                rptCoding <- 1
                if(PropertyExists(rptScoreDef, "item_coding") and PropertyExists(rptScoreDef.item_coding, qdef.id))
                {
                  rptCoding <- GetProperty(rptScoreDef.item_coding, qdef.id)
                }
                dimVal <- CodeResponse(resp, rptCoding, rptMinVal, rptMaxVal) + ""
              }
            }
          }
          PushOnEnd(rowData, dimVal)
        }
      }

      PushOnEnd(respTableData, rowData)
      }
    }
  }

  FilePrint(htmlFile, Table(respTableData, respHeaders))

  ##############################################################################
  ## DATA FILES SECTION
  ##############################################################################

  FilePrint(htmlFile, HL())
  FilePrint(htmlFile, H("Data Files", 2))
  FilePrint(htmlFile, P("The following data files were generated for this session:"))

  ## Extract just the filename from full path for display
  csvFilename <- Nth(SplitString(gFileOut.filename, "/"), Length(SplitString(gFileOut.filename, "/")))
  pooledFilename <- Nth(SplitString(gPooledFile.filename, "/"), Length(SplitString(gPooledFile.filename, "/")))
  reportHTMLname <- reportFilename

  FilePrint(htmlFile, "<ul>")
  FilePrint(htmlFile, "<li><a href='" + csvFilename + "'>" + csvFilename + "</a> - Trial-by-trial data</li>")
  FilePrint(htmlFile, "<li><a href='../" + pooledFilename + "'>" + pooledFilename + "</a> - Summary data</li>")
  FilePrint(htmlFile, "<li><a href='" + reportHTMLname + "'>" + reportHTMLname + "</a> - This report</li>")
  FilePrint(htmlFile, "</ul>")

  ##############################################################################
  ## PARAMETERS
  ##############################################################################

  FilePrint(htmlFile, HL())
  FilePrint(htmlFile, H("Parameters", 2))
  FilePrint(htmlFile, "<table><thead><tr><th>Parameter</th><th>Value</th></tr></thead>")

  paramNames <- GetPropertyList(gParams)
  loop(pName, paramNames)
  {
    pVal <- GetProperty(gParams, pName)
    FilePrint(htmlFile, "<tr><td>" + pName + "</td><td>" + pVal + "</td></tr>")
  }

  FilePrint(htmlFile, "</table>")

  ##############################################################################
  ## FOOTER
  ##############################################################################

  FilePrint(htmlFile, HL())

  ## Add footer references if available
  if(PropertyExists(scaleDef, "report"))
  {
    if(PropertyExists(scaleDef.report, "footer_refs"))
    {
      loop(ref, scaleDef.report.footer_refs)
      {
        FilePrint(htmlFile, P(ref))
      }
    }
  }

  FilePrint(htmlFile, "<p style='font-size:0.85em;color:#888;text-align:center;'>")
  FilePrint(htmlFile, "Scale administered via <a href='https://openscales.net' target='_blank'>OpenScales</a>.")
  FilePrint(htmlFile, " Run on desktop using <a href='http://pebl.sf.net' target='_blank'>PEBL</a>")
  FilePrint(htmlFile, " | Run online via <a href='http://peblhub.online' target='_blank'>PEBLHub</a>.")
  FilePrint(htmlFile, "</p>")
  FilePrint(htmlFile, "</body></html>")

  FileClose(htmlFile)
  Print("HTML report saved: " + reportPath)

  ## Return file object with .filename property
  fileObj <- MakeCustomObject("file")
  fileObj.filename <- reportPath

  return(fileObj)
}


##############################################################################
## TRANSLATION SUPPORT
##############################################################################

define GetStrings(lang, scaleCode)
{
  ## Load translations. Priority order (most preferred first):
  ##   1. {code}-{lang}.json      (OSD/OpenScales standard)
  ##   2. {code}.pbl-{lang}.json  (legacy PEBL format)
  ##   3. {code}.{lang}.json      (dot-separated legacy)
  ## Falls back to English if requested language not found.

  lang <- Lowercase(lang)
  found <- 0

  ## Requested language
  if(found == 0 and lang != "" and lang != "en")
  {
    filename <- "translations/" + scaleCode + "-" + lang + ".json"
    if(FileExists(filename))
    {
      gStrings <- ReadTranslationJSON(filename, lang)
      found <- 1
    }
  }

  if(found == 0 and lang != "" and lang != "en")
  {
    filename <- "translations/" + scaleCode + ".pbl-" + lang + ".json"
    if(FileExists(filename))
    {
      gStrings <- ReadTranslationJSON(filename, lang)
      found <- 1
    }
  }

  if(found == 0 and lang != "" and lang != "en")
  {
    filename <- "translations/" + scaleCode + "." + lang + ".json"
    if(FileExists(filename))
    {
      gStrings <- ReadTranslationJSON(filename, lang)
      found <- 1
    }
  }

  ## English fallback
  if(found == 0)
  {
    filename <- "translations/" + scaleCode + "-en.json"
    if(FileExists(filename))
    {
      gStrings <- ReadTranslationJSON(filename, "en")
      found <- 1
    }
  }

  if(found == 0)
  {
    filename <- "translations/" + scaleCode + ".pbl-en.json"
    if(FileExists(filename))
    {
      gStrings <- ReadTranslationJSON(filename, "en")
      found <- 1
    }
  }

  if(found == 0)
  {
    filename <- "translations/" + scaleCode + ".en.json"
    if(FileExists(filename))
    {
      gStrings <- ReadTranslationJSON(filename, "en")
      found <- 1
    }
  }

  ## Fallback: embedded translations stored in _embedded_translations by LoadScaleDefinition
  if(found == 0 and PropertyExists(gScaleDef, "_embedded_translations"))
  {
    embTrans <- gScaleDef._embedded_translations
    embLangKey <- lang
    if(lang == "" or lang == "en") { embLangKey <- "en" }
    if(not PropertyExists(embTrans, embLangKey) and PropertyExists(embTrans, "en"))
    {
      embLangKey <- "en"
    }
    if(PropertyExists(embTrans, embLangKey))
    {
      gStrings <- GetProperty(embTrans, embLangKey)
      gStrings.language <- Lowercase(embLangKey)
      proplist <- GetPropertyList(gStrings)
      loop(prop, proplist)
      {
        SetProperty(gStrings, prop, FormatText(GetProperty(gStrings, prop)))
      }
      found <- 1
    }
  }

  if(found == 0)
  {
    Print("WARNING: No translation file found for: " + scaleCode)
    gStrings <- MakeCustomObject("strings")
    gStrings.debrief <- "Thank you for completing the questionnaire."
  }
}


define LoadRunnerStrings(lang)
{
  ## Load ScaleRunner UI chrome strings (separate from scale-specific gStrings).
  ## Stored in translations/ScaleRunner-{lang}.json, falls back to English,
  ## then to hardcoded defaults. Result stored in global gRunnerStrings.
  gRunnerStrings <- MakeCustomObject("RunnerStrings")

  ## Hardcoded English defaults (overwritten if a file is found)
  gRunnerStrings.type_hint <- "Start typing and hit Enter to complete your response"

  ## Try language-specific file first, then English fallback
  found <- 0
  langs <- [lang, "en"]
  loop(l, langs)
  {
    if(not found)
    {
      filename <- "translations/ScaleRunner-" + l + ".json"
      if(FileExists(filename))
      {
        obj <- ReadJSON(filename)
        if(obj != 0)
        {
          loop(key, GetPropertyList(obj))
          {
            SetProperty(gRunnerStrings, Lowercase(key), GetProperty(obj, key))
          }
        }
        found <- 1
      }
    }
  }
}


##############################################################################
## PLACEHOLDER FUNCTIONS (To be implemented)
##############################################################################

## These will be implemented in subsequent iterations

define GetVASLabel(qdef, field, transField, defaultVal)
{
  ## Helper: get VAS anchor label from translation key or literal text
  ## Checks both field names (spec and legacy), resolves through gStrings if possible
  label <- ""

  ## Try primary field first, then fallback field
  rawKey <- ""
  if(PropertyExists(qdef, field))
  {
    rawKey <- GetProperty(qdef, field)
  } elseif(PropertyExists(qdef, transField))
  {
    rawKey <- GetProperty(qdef, transField)
  }

  ## Resolve key through translations if possible
  if(rawKey != "" and rawKey != 0)
  {
    if(PropertyExists(gStrings, rawKey))
    {
      label <- GetProperty(gStrings, rawKey)
    } else {
      label <- rawKey
    }
  }

  if(label == "" or label == 0)
  {
    label <- defaultVal
  }

  return(label)
}


define DoVAS(qdef, scaleDef, prefill:"")
{
  ## Visual Analog Scale — supports horizontal (default) and vertical orientation,
  ## plus named anchor points.

  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))

  gLayout.subheader.text <- ""

  ## Resolve question head: item-level (qdef.question_head) overrides scale-level
  questionHead <- ""
  if(PropertyExists(qdef, "question_head"))
  {
    if(PropertyExists(gStrings, qdef.question_head))
    {
      questionHead <- GetProperty(gStrings, qdef.question_head)
    }
  } elseif(PropertyExists(scaleDef, "likert_options"))
  {
    if(PropertyExists(scaleDef.likert_options, "question_head"))
    {
      headKey <- scaleDef.likert_options.question_head
      if(PropertyExists(gStrings, headKey))
      {
        questionHead <- GetProperty(gStrings, headKey)
      }
    }
  }

  ## Get min/max labels
  minLabel <- GetVASLabel(qdef, "min_label", "left", "Min")
  maxLabel <- GetVASLabel(qdef, "max_label", "right", "Max")

  ## Determine orientation: "vertical" or "horizontal" (default)
  isVertical <- 0
  if(PropertyExists(qdef, "orientation"))
  {
    if(qdef.orientation == "vertical")
    {
      isVertical <- 1
    }
  }

  ## Collect named anchors if present
  hasAnchors <- 0
  anchorList <- []
  if(PropertyExists(qdef, "anchors"))
  {
    hasAnchors <- 1
    anchorList <- qdef.anchors
  }

  ## VAS configuration — adjust size based on orientation
  numTicks <- 11  ## Visual tick marks only (0, 10%, 20%, ..., 100%)
  numSteps <- 100  ## Internal resolution: 0-100 steps for smooth positioning
  if(isVertical)
  {
    vasLength <- 350  ## shorter to avoid header overlap
    vasThick <- 50
  } else {
    vasLength <- Round(gVideoWidth * 0.65)
    vasThick <- 40
  }

  ## Position in stimulus region
  centerX <- gLayout.stimulusRegion.centerX
  centerY <- gLayout.stimulusRegion.centerY + 70

  ## Question head at top of stimulus region (if present)
  tmp <- []
  headBottom <- gLayout.stimulusRegion.y + 5

  if(questionHead != "" and questionHead != 0)
  {
    headWidth <- Round(gVideoWidth * 0.75)
    headHeight <- 60
    headX <- Round((gVideoWidth - headWidth) / 2)
    headY <- gLayout.stimulusRegion.y + 5

    headBox <- MakeTextBox(questionHead, gHeadFont, headWidth, headHeight)
    headBox.isadaptive <- 1
    headBox.formatted <- 1
    headBox.justify <- "CENTER"
    AddObject(headBox, gWin)
    Move(headBox, headX, headY)
    PushOnEnd(tmp, headBox)
    headBottom <- headY + headBox.height + 10
  }

  ## Question text (item name) below the head
  questWidth <- Round(gVideoWidth * 0.80)
  questHeight <- 60
  questX <- Round((gVideoWidth - questWidth) / 2)
  questY <- headBottom

  ques <- MakeTextBox(questionText, gItemFont, questWidth, questHeight)
  ques.isadaptive <- 1
  ques.formatted <- 1
  ques.justify <- "CENTER"
  AddObject(ques, gWin)
  Move(ques, questX, questY)

  ## Create VAS elements based on orientation
  ## vasStart/vasEnd are the low/high ends of the slider in pixels
  if(isVertical)
  {
    ## Vertical: slider runs top (max) to bottom (min)
    vasTop <- centerY - vasLength/2
    vasBottom <- centerY + vasLength/2
    vasStart <- vasBottom   ## min value at bottom
    vasEnd <- vasTop        ## max value at top

    clickBox <- Rectangle(centerX, centerY, vasThick, vasLength, MakeColor("grey60"), 1)
    AddObject(clickBox, gWin)
    PushOnEnd(tmp, clickBox)

    ## Tick marks
    tickSkip <- vasLength / (numTicks - 1)
    tPos <- vasBottom
    loop(i, Sequence(1, numTicks, 1))
    {
      if(i == 1 or i == Round((numTicks+1)/2) or i == numTicks)
      {
        tickLine <- Line(centerX - 22, tPos, 45, 0, MakeColor("white"))
      } else {
        tickLine <- Line(centerX - 15, tPos, 30, 0, MakeColor("white"))
      }
      AddObject(tickLine, gWin)
      PushOnEnd(tmp, tickLine)
      tPos <- tPos - tickSkip
    }

    ## Center line
    vLine <- Line(centerX, vasTop, 0, vasLength, MakeColor("white"))
    AddObject(vLine, gWin)
    PushOnEnd(tmp, vLine)

    ## Labels or anchors
    if(hasAnchors)
    {
      loop(anc, anchorList)
      {
        frac <- (anc.value - qdef.min) / (qdef.max - qdef.min)
        ancY <- vasBottom - frac * vasLength
        ancLabel <- ""
        if(PropertyExists(gStrings, anc.label))
        {
          ancLabel <- GetProperty(gStrings, anc.label)
        } else {
          ancLabel <- anc.label
        }
        aLab <- MakeLabel(ancLabel, gVASLabelFont)
        AddObject(aLab, gWin)
        Move(aLab, centerX + vasThick/2 + aLab.width/2 + 10, ancY)
        PushOnEnd(tmp, aLab)
      }
    } else {
      minLab <- MakeLabel(minLabel, gVASLabelFont)
      AddObject(minLab, gWin)
      Move(minLab, centerX, vasBottom + 30)
      PushOnEnd(tmp, minLab)

      maxLab <- MakeLabel(maxLabel, gVASLabelFont)
      AddObject(maxLab, gWin)
      Move(maxLab, centerX, vasTop - 30)
      PushOnEnd(tmp, maxLab)
    }

    ## Red thumb indicator (horizontal bar for vertical VAS)
    thumb <- Rectangle(centerX, centerY, vasThick + 10, 5, MakeColor("red"), 1)
  } else {
    ## Horizontal: slider runs left (min) to right (max)
    vasLeft <- centerX - vasLength/2
    vasRight <- centerX + vasLength/2
    vasStart <- vasLeft    ## min value at left
    vasEnd <- vasRight     ## max value at right
    vasTop <- centerY - vasThick/2
    vasBottom <- centerY + vasThick/2

    clickBox <- Rectangle(centerX, centerY, vasLength, vasThick, MakeColor("grey60"), 1)
    AddObject(clickBox, gWin)
    PushOnEnd(tmp, clickBox)

    ## Tick marks
    tickSkip <- vasLength / (numTicks - 1)
    tPos <- vasLeft
    loop(i, Sequence(1, numTicks, 1))
    {
      if(i == 1 or i == Round((numTicks+1)/2) or i == numTicks)
      {
        tickLine <- Line(tPos, centerY - 22, 0, 45, MakeColor("white"))
      } else {
        tickLine <- Line(tPos, centerY - 15, 0, 30, MakeColor("white"))
      }
      AddObject(tickLine, gWin)
      PushOnEnd(tmp, tickLine)
      tPos <- tPos + tickSkip
    }

    ## Center line
    hLine <- Line(vasLeft, centerY, vasLength, 0, MakeColor("white"))
    AddObject(hLine, gWin)
    PushOnEnd(tmp, hLine)

    ## Labels or anchors
    if(hasAnchors)
    {
      loop(anc, anchorList)
      {
        frac <- (anc.value - qdef.min) / (qdef.max - qdef.min)
        ancX <- vasLeft + frac * vasLength
        ancLabel <- ""
        if(PropertyExists(gStrings, anc.label))
        {
          ancLabel <- GetProperty(gStrings, anc.label)
        } else {
          ancLabel <- anc.label
        }
        aLab <- MakeLabel(ancLabel, gVASLabelFont)
        AddObject(aLab, gWin)
        Move(aLab, ancX, centerY + vasThick/2 + 25)
        PushOnEnd(tmp, aLab)
      }
    } else {
      minLab <- MakeLabel(minLabel, gVASLabelFont)
      AddObject(minLab, gWin)
      Move(minLab, vasLeft, centerY + vasThick/2 + 25)
      PushOnEnd(tmp, minLab)

      maxLab <- MakeLabel(maxLabel, gVASLabelFont)
      AddObject(maxLab, gWin)
      Move(maxLab, vasRight, centerY + vasThick/2 + 25)
      PushOnEnd(tmp, maxLab)
    }

    ## Red thumb indicator (vertical bar for horizontal VAS)
    thumb <- Rectangle(centerX, centerY, 5, vasThick + 10, MakeColor("red"), 1)
  }

  ## Common thumb setup
  AddObject(thumb, gWin)
  Hide(thumb)

  ## Button positions — use footer area since VAS doesn't use it
  ## Place buttons near bottom of screen for more VAS room
  if(isVertical)
  {
    btnY <- gVideoHeight - 110
    btnX <- centerX
    backBtnX <- centerX - 200
    skipBtnX <- centerX + 100
  } else {
    btnY <- gVideoHeight - 110
    btnX <- centerX
    backBtnX <- centerX - 200
    skipBtnX <- centerX + 100
  }

  ## SKIP button for optional questions (shown before slider click)
  isRequired <- IsQuestionRequired(qdef, scaleDef)
  skipBtn <- 0
  if(not isRequired)
  {
    skipBtn <- MakeSkipButton(skipBtnX, btnY)
  }

  ## BACK button for revisable sections
  vasBackBtn <- 0
  if(gCanGoBack)
  {
    vasBackBtn <- MakeBackButton(backBtnX, btnY)
  }

  Draw()

  t1 <- GetTime()
  skipped <- 0
  wentBack <- 0
  rawRating <- 0
  doneBtn <- 0

  ## If pre-fill provided, bypass first-click and position thumb directly
  if(prefill != "")
  {
    prefillNum <- ToNumber(prefill)
    rawRating <- Round((prefillNum - qdef.min) / (qdef.max - qdef.min) * numSteps)
    if(rawRating < 0) { rawRating <- 0 }
    if(rawRating > numSteps) { rawRating <- 20 }
    if(isVertical)
    {
      thumbPos <- vasBottom - (rawRating / numSteps) * vasLength
      thumb.y <- thumbPos
    } else {
      thumbPos <- vasLeft + (rawRating / numSteps) * vasLength
      thumb.x <- thumbPos
    }
    Show(thumb)
    if(skipBtn != 0)
    {
      RemoveObject(skipBtn.border, gWin)
      RemoveObject(skipBtn.label, gWin)
      skipBtn <- 0
    }
    doneBtn <- MakeScaleButton("NEXT", btnX, btnY, 150, 50)
    Draw()
  } else {
    ## Wait for initial click on VAS, SKIP, or BACK
    vasInitTargets <- [clickBox]
    vasInitValues <- [1]
    if(skipBtn != 0)
    {
      PushOnEnd(vasInitTargets, skipBtn.border)
      PushOnEnd(vasInitValues, "SKIP")
    }
    if(vasBackBtn != 0)
    {
      PushOnEnd(vasInitTargets, vasBackBtn.border)
      PushOnEnd(vasInitValues, "BACK")
    }
    initialResp <- WaitForClickOnTarget(vasInitTargets, vasInitValues)
    if(initialResp == "SKIP") { skipped <- 1 }
    if(initialResp == "BACK") { wentBack <- 1 }

    if(not skipped and not wentBack)
    {
      ## Get click coordinate and calculate rating based on orientation
      if(isVertical)
      {
        clickCoord <- Second(gClick)
        rawRating <- numSteps - Round(((clickCoord - vasTop) / vasLength) * numSteps)
      } else {
        clickCoord <- First(gClick)
        rawRating <- Round(((clickCoord - vasLeft) / vasLength) * numSteps)
      }
      if(rawRating < 0) { rawRating <- 0 }
      if(rawRating > numSteps) { rawRating <- 20 }

      if(isVertical)
      {
        thumbPos <- vasBottom - (rawRating / numSteps) * vasLength
        thumb.y <- thumbPos
      } else {
        thumbPos <- vasLeft + (rawRating / numSteps) * vasLength
        thumb.x <- thumbPos
      }
      Show(thumb)

      if(skipBtn != 0)
      {
        RemoveObject(skipBtn.border, gWin)
        RemoveObject(skipBtn.label, gWin)
        skipBtn <- 0
      }
      doneBtn <- MakeScaleButton("NEXT", btnX, btnY, 150, 50)
      Draw()
    }
  }

  ## Allow adjustment until DONE is clicked (shared by both normal and prefill paths)
  if(not skipped and not wentBack)
  {
    continueLoop <- 1
    while(continueLoop)
    {
      if(vasBackBtn != 0)
      {
        resp <- WaitForClickOnTarget([doneBtn.border, clickBox, vasBackBtn.border], [0, 1, "BACK"])
      } else {
        resp <- WaitForClickOnTarget([doneBtn.border, clickBox], [0, 1])
      }

      if(resp == 1)
      {
        ## Clicked on VAS - update position
        if(isVertical)
        {
          clickCoord <- Second(gClick)
          rawRating <- numSteps - Round(((clickCoord - vasTop) / vasLength) * numSteps)
        } else {
          clickCoord <- First(gClick)
          rawRating <- Round(((clickCoord - vasLeft) / vasLength) * numSteps)
        }
        if(rawRating < 0) { rawRating <- 0 }
        if(rawRating > numSteps) { rawRating <- 20 }
        if(isVertical)
        {
          thumbPos <- vasBottom - (rawRating / numSteps) * vasLength
          thumb.y <- thumbPos
        } else {
          thumbPos <- vasLeft + (rawRating / numSteps) * vasLength
          thumb.x <- thumbPos
        }
        Draw()
      } elseif(resp == "BACK")
      {
        wentBack <- 1
        continueLoop <- 0
      } else {
        continueLoop <- 0
      }
    }

    if(not wentBack)
    {
      RemoveObject(doneBtn.border, gWin)
      RemoveObject(doneBtn.label, gWin)
    }
  }

  t2 <- GetTime()

  ## Build result
  if(skipped)
  {
    resultResp <- "NA"
  } else {
    if(wentBack)
    {
      resultResp <- -1
    } else {
      ## Convert to question's min-max range
      rating <- qdef.min + (rawRating / numSteps) * (qdef.max - qdef.min)
      resultResp <- Round(rating*10)/10
    }
  }

  ## Cleanup
  RemoveObject(ques, gWin)
  RemoveObjects(tmp, gWin)
  RemoveObject(thumb, gWin)
  if(skipBtn != 0)
  {
    RemoveObject(skipBtn.border, gWin)
    RemoveObject(skipBtn.label, gWin)
  }
  if(vasBackBtn != 0)
  {
    RemoveObject(vasBackBtn.border, gWin)
    RemoveObject(vasBackBtn.label, gWin)
  }
  ## doneBtn only persists if wentBack was triggered after thumb placement
  if(doneBtn != 0 and wentBack)
  {
    RemoveObject(doneBtn.border, gWin)
    RemoveObject(doneBtn.label, gWin)
  }

  retVal <- [resultResp, t2-t1]
  if(wentBack)
  {
    retVal <- [-1, 0]
  }
  return(retVal)
}


##############################################################################
## MULTI-ITEM VAS PAGE (horizontal sliders for multiple items)
## Used when a page groups multiple VAS questions together
##############################################################################

define DoVASPage(questions, scaleDef)
{
  ## Renders multiple VAS items on one page with horizontal sliders
  ## Returns list of [id, response, rt] for each item

  gLayout.subheader.text <- ""
  numItems <- Length(questions)

  ## Show question head if available
  allObjects <- []
  contentTop <- gLayout.stimulusRegion.y + 5

  ## Resolve question head: item-level (qdef.question_head) overrides scale-level
  questionHead <- ""
  if(PropertyExists(qdef, "question_head"))
  {
    if(PropertyExists(gStrings, qdef.question_head))
    {
      questionHead <- GetProperty(gStrings, qdef.question_head)
    }
  } elseif(PropertyExists(scaleDef, "likert_options"))
  {
    if(PropertyExists(scaleDef.likert_options, "question_head"))
    {
      headKey <- scaleDef.likert_options.question_head
      if(PropertyExists(gStrings, headKey))
      {
        questionHead <- GetProperty(gStrings, headKey)
      }
    }
  }

  if(questionHead != "" and questionHead != 0)
  {
    headWidth <- Round(gVideoWidth * 0.80)
    headHeight <- 60
    headX <- Round((gVideoWidth - headWidth) / 2)

    headBox <- MakeTextBox(questionHead, gHeadFont, headWidth, headHeight)
    headBox.isadaptive <- 1
    headBox.formatted <- 1
    headBox.justify <- "CENTER"
    AddObject(headBox, gWin)
    Move(headBox, headX, contentTop)
    PushOnEnd(allObjects, headBox)
    contentTop <- contentTop + headBox.height + 15
  }

  ## Layout parameters for horizontal VAS sliders
  labelWidth <- Round(gVideoWidth * 0.18)  ## Left column for item names
  sliderLeft <- labelWidth + 20            ## Start of slider area
  sliderWidth <- Round(gVideoWidth * 0.60) ## Width of each slider
  sliderRight <- sliderLeft + sliderWidth

  ## Calculate row height based on available space
  availHeight <- gVideoHeight - contentTop - 100  ## Reserve 100 for done button
  rowHeight <- Min([Round(availHeight / numItems), 55])

  ## Get anchor labels from first question (shared across items)
  firstQ <- First(questions)
  minLabel <- GetVASLabel(firstQ, "left", "min_label", "Min")
  maxLabel <- GetVASLabel(firstQ, "right", "max_label", "Max")

  ## Draw column headers (anchor labels)
  minHead <- MakeLabel(minLabel, gVASLabelFont)
  AddObject(minHead, gWin)
  Move(minHead, sliderLeft, contentTop)
  PushOnEnd(allObjects, minHead)

  maxHead <- MakeLabel(maxLabel, gVASLabelFont)
  AddObject(maxHead, gWin)
  Move(maxHead, sliderRight, contentTop)
  PushOnEnd(allObjects, maxHead)

  contentTop <- contentTop + 30

  ## Create VAS rows
  ## Determine range from first question to set tick marks and resolution
  vasMin <- firstQ.min
  vasMax <- firstQ.max
  vasRange <- vasMax - vasMin

  ## Use range+1 ticks for integer scales (e.g., 0-100 = 101 ticks)
  ## but only draw visible ticks for a few key points
  numSteps <- vasRange  ## Number of discrete steps (e.g., 100 for 0-100)
  numTicks <- 11        ## Visible tick marks on the slider
  clickBoxes <- []
  clickValues <- []
  thumbs <- []
  ratings <- []
  rowYs <- []
  vasItemFont <- MakeFont(gPEBLBaseFont, 0, 24, gTheme.questionText, gTheme.windowBg, 0)

  loop(qi, Sequence(1, numItems, 1))
  {
    qdef <- Nth(questions, qi)
    rowY <- contentTop + (qi - 1) * rowHeight + rowHeight / 2

    PushOnEnd(rowYs, rowY)
    PushOnEnd(ratings, -1)  ## -1 = not yet rated

    ## Item label on left (TextBox with word wrap to prevent overflow)
    itemText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))
    itemLab <- MakeTextBox(itemText, vasItemFont, labelWidth - 10, rowHeight)
    itemLab.isadaptive <- 1
    itemLab.justify <- "RIGHT"
    AddObject(itemLab, gWin)
    Move(itemLab, 5, rowY - itemLab.height / 2)
    PushOnEnd(allObjects, itemLab)

    ## Horizontal slider track
    sliderCenterX <- sliderLeft + sliderWidth / 2
    trackLine <- Line(sliderLeft, rowY, sliderWidth, 0, MakeColor("grey60"))
    AddObject(trackLine, gWin)
    PushOnEnd(allObjects, trackLine)

    ## Tick marks (visual only — evenly spaced)
    tickSkip <- sliderWidth / (numTicks - 1)
    midTick <- Round((numTicks + 1) / 2)
    loop(ti, Sequence(1, numTicks, 1))
    {
      tickX <- sliderLeft + (ti - 1) * tickSkip
      if(ti == 1 or ti == midTick or ti == numTicks)
      {
        tickLine <- Line(tickX, rowY - 10, 0, 20, MakeColor("grey60"))
      } else {
        tickLine <- Line(tickX, rowY - 6, 0, 12, MakeColor("grey60"))
      }
      AddObject(tickLine, gWin)
      PushOnEnd(allObjects, tickLine)
    }

    ## Clickable region (invisible rectangle covering slider area)
    clickBox <- Rectangle(sliderCenterX, rowY, sliderWidth + 20, rowHeight - 4, MakeColor("grey20"), 0)
    AddObject(clickBox, gWin)
    PushOnEnd(clickBoxes, clickBox)
    PushOnEnd(clickValues, qi)

    ## Thumb (initially hidden)
    thumbRect <- Rectangle(sliderLeft, rowY, 6, rowHeight - 8, MakeColor("red"), 1)
    AddObject(thumbRect, gWin)
    Hide(thumbRect)
    PushOnEnd(thumbs, thumbRect)
  }

  ## DONE button (below all items)
  doneY <- contentTop + numItems * rowHeight + 30
  doneBtn <- MakeScaleButton("NEXT", gVideoWidth / 2, doneY, 150, 50)
  Hide(doneBtn.border)
  Hide(doneBtn.label)

  ## SKIP button for optional questions (check if any item on page is optional)
  pageOptional <- 0
  loop(qItem, questions)
  {
    if(not IsQuestionRequired(qItem, scaleDef))
    {
      pageOptional <- 1
    }
  }
  skipBtn <- 0
  if(pageOptional)
  {
    skipBtn <- MakeSkipButton(gVideoWidth / 2 + 150, doneY)
  }

  Draw()

  ## Interaction loop
  t1 <- GetTime()
  allRated <- 0
  continueLoop <- 1
  wasSkipped <- 0

  while(continueLoop)
  {
    ## Build click targets: all sliders + done button (if all rated) + skip button
    targets <- clickBoxes
    values <- clickValues

    if(allRated)
    {
      targets <- Merge(clickBoxes, [doneBtn.border])
      values <- Merge(clickValues, [0])
    }

    if(skipBtn != 0)
    {
      targets <- Merge(targets, [skipBtn.border])
      values <- Merge(values, ["SKIP"])
    }

    resp <- WaitForClickOnTarget(targets, values)

    if(resp == "SKIP")
    {
      ## Skip entire page
      continueLoop <- 0
      wasSkipped <- 1
    } elseif(resp == 0)
    {
      ## Done button clicked
      continueLoop <- 0
    } else {

      ## Clicked on slider row resp
      clickX <- First(gClick)
      qi <- resp
      qdef <- Nth(questions, qi)
      rowY <- Nth(rowYs, qi)

      ## Convert click X to rating in the question's min-max range
      qMin <- qdef.min
      qMax <- qdef.max
      qRange <- qMax - qMin
      rawRating <- Round(qMin + ((clickX - sliderLeft) / sliderWidth) * qRange)
      if(rawRating < qMin)
      {
        rawRating <- qMin
      }
      if(rawRating > qMax)
      {
        rawRating <- qMax
      }

      ## Update thumb position
      thumbX <- sliderLeft + ((rawRating - qMin) / (qRange + 0.0)) * sliderWidth
      thumb <- Nth(thumbs, qi)
      thumb.x <- thumbX
      thumb.y <- rowY
      Show(thumb)

      ## Store rating directly (already in the question's min-max range)
      SetElement(ratings, qi, rawRating)

      ## Check if all items are rated
      allRated <- 1
      loop(r, ratings)
      {
        if(r == -1)
        {
          allRated <- 0
        }
      }

      if(allRated)
      {
        Show(doneBtn.border)
        Show(doneBtn.label)
      }

      Draw()
    }
  }

  t2 <- GetTime()
  totalRT <- t2 - t1

  ## Cleanup
  RemoveObjects(allObjects, gWin)
  RemoveObjects(clickBoxes, gWin)
  RemoveObjects(thumbs, gWin)
  RemoveObject(doneBtn.border, gWin)
  RemoveObject(doneBtn.label, gWin)
  if(skipBtn != 0)
  {
    RemoveObject(skipBtn.border, gWin)
    RemoveObject(skipBtn.label, gWin)
  }

  ## Return results as list of [qdef, response, rt] lists
  ## Split RT evenly across items (individual timing not meaningful for page)
  perItemRT <- Round(totalRT / numItems)
  resultList <- []
  if(wasSkipped)
  {
    loop(qi, Sequence(1, numItems, 1))
    {
      PushOnEnd(resultList, [Nth(questions, qi), "NA", perItemRT])
    }
  } else {
    loop(qi, Sequence(1, numItems, 1))
    {
      PushOnEnd(resultList, [Nth(questions, qi), Nth(ratings, qi), perItemRT])
    }
  }

  return(resultList)
}

define DoGrid(qdef, scaleDef, prefill:"")
{
  ## Grid/table rating (multiple items, same scale)

  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))
  gLayout.subheader.text <- "Click on each row to rate all items"

  ## Resolve column labels — values are translation keys, look up via gStrings
  optLabels <- []
  numPoints <- 0

  if(PropertyExists(qdef, "grid_options"))
  {
    ## Old format: explicit translation keys in grid_options.labels
    gridOpts <- qdef.grid_options
    numPoints <- gridOpts.points
    loop(labelKey, gridOpts.labels)
    {
      PushOnEnd(optLabels, GetProperty(gStrings, labelKey))
    }
  } elseif(PropertyExists(qdef, "columns"))
  {
    ## columns array: each element is a translation key
    numPoints <- Length(qdef.columns)
    loop(colKey, qdef.columns)
    {
      if(PropertyExists(gStrings, colKey))
      {
        PushOnEnd(optLabels, GetProperty(gStrings, colKey))
      } else {
        PushOnEnd(optLabels, colKey)
      }
    }
  }

  ## Resolve row labels — values are translation keys, look up via gStrings
  ## Build optionalRowIdxs (1-based) from optional_rows key list if present
  rowLabels <- []
  optionalRowIdxs <- []
  rowKeyList <- []
  if(PropertyExists(qdef, "subitems"))
  {
    ## Old format: objects with text_key
    loop(subitem, qdef.subitems)
    {
      PushOnEnd(rowLabels, GetProperty(gStrings, subitem.text_key))
      PushOnEnd(rowKeyList, subitem.text_key)
    }
  } elseif(PropertyExists(qdef, "rows"))
  {
    ## rows array: each element is a translation key
    loop(rowKey, qdef.rows)
    {
      if(PropertyExists(gStrings, rowKey))
      {
        PushOnEnd(rowLabels, GetProperty(gStrings, rowKey))
      } else {
        PushOnEnd(rowLabels, rowKey)
      }
      PushOnEnd(rowKeyList, rowKey)
    }
  }

  ## Mark optional rows: append "(optional)" to their labels
  if(PropertyExists(qdef, "optional_rows"))
  {
    rowIdx <- 1
    loop(rk, rowKeyList)
    {
      isOpt <- 0
      loop(optKey, qdef.optional_rows)
      {
        if(rk == optKey)
        {
          isOpt <- 1
          break
        }
      }
      if(isOpt)
      {
        PushOnEnd(optionalRowIdxs, rowIdx)
        lbl <- Nth(rowLabels, rowIdx)
        SetElement(rowLabels, rowIdx, lbl + " (optional)")
      }
      rowIdx <- rowIdx + 1
    }
  }

  numItems <- Length(rowLabels)
  ## Number of required (non-optional) rows
  numRequired <- numItems - Length(optionalRowIdxs)

  ## Question text
  quesWidth <- gLayout.stimulusRegion.width - 40
  quesX <- gLayout.stimulusRegion.x + 20
  quesY <- gLayout.stimulusRegion.y + 10

  ques <- MakeTextBox(questionText, gQuestFont, quesWidth, 80)
  ques.isadaptive <- 1
  ques.formatted <- 1
  AddObject(ques, gWin)
  Move(ques, quesX, quesY)

  ## Fonts
  headerFont <- MakeFont(gPEBLBaseFont, 1, 15, gTheme.questionText, gTheme.windowBg, 0)
  rowFont    <- MakeFont(gPEBLBaseFont, 0, 17, gTheme.questionText, gTheme.windowBg, 0)

  ## ── Adaptive grid layout ────────────────────────────────────────────────
  ##
  ## Click boxes are a fixed 40×40 square.  Column width is derived from the
  ## longest column label using a character-width estimate (avoids needing a
  ## Draw() call to get rendered text heights).
  ##
  ## Bold size-15 font: ~9 px per character average.  Add 16 px of horizontal
  ## padding (8 px each side) and clamp to [minCellW … 250].

  boxSize    <- 40
  availWidth <- gVideoWidth - 60
  minLabelW  <- 200
  minCellW   <- boxSize + 16   ## 56 px: box + 8 px margin each side
  pxPerChar  <- 9              ## avg char width for bold 15-pt font

  ## Find the longest column label in characters
  maxColChars <- 1
  loop(colLbl, optLabels)
  {
    if(StringLength(colLbl) > maxColChars)
    {
      maxColChars <- StringLength(colLbl)
    }
  }

  ## Derive column width; clamp
  colWidth <- maxColChars * pxPerChar + 16
  if(colWidth < minCellW) { colWidth <- minCellW }
  if(colWidth > 250)      { colWidth <- 250 }

  ## Find the longest row label in characters (size-17 regular font: ~10 px/char)
  maxRowChars <- 1
  loop(rowLbl, rowLabels)
  {
    if(StringLength(rowLbl) > maxRowChars)
    {
      maxRowChars <- StringLength(rowLbl)
    }
  }
  estimatedLabelW <- maxRowChars * 10 + 15

  ## Label column width = estimated need, but bounded by [minLabelW … space after columns]
  maxAvailLabelW <- availWidth - numPoints * colWidth
  if(maxAvailLabelW < minLabelW)
  {
    ## Columns too wide — shrink colWidth to free up minLabelW for labels
    labelColWidth <- minLabelW
    colWidth <- Round((availWidth - minLabelW) / numPoints)
    if(colWidth < minCellW) { colWidth <- minCellW }
  } elseif(estimatedLabelW < minLabelW)
  {
    labelColWidth <- minLabelW
  } elseif(estimatedLabelW < maxAvailLabelW)
  {
    labelColWidth <- estimatedLabelW
  } else {
    labelColWidth <- maxAvailLabelW
  }

  totalGridWidth <- labelColWidth + numPoints * colWidth
  startX <- Round((gVideoWidth - totalGridWidth) / 2)

  ## ── Create header and row-label display objects ──────────────────────────
  ## Heights are estimated from initial values (adaptive boxes update on Draw)
  headerObjects <- []
  loop(optText, optLabels)
  {
    hdr <- MakeTextBox(optText, headerFont, colWidth - 16, 22)
    hdr.isadaptive <- 1
    hdr.justify <- "CENTER"
    AddObject(hdr, gWin)
    RemoveObject(hdr, gWin)
    PushOnEnd(headerObjects, hdr)
  }

  rowLabelObjects <- []
  loop(rowText, rowLabels)
  {
    lbl <- MakeTextBox(rowText, rowFont, labelColWidth - 15, 22)
    lbl.isadaptive <- 1
    lbl.justify <- "RIGHT"
    AddObject(lbl, gWin)
    RemoveObject(lbl, gWin)
    PushOnEnd(rowLabelObjects, lbl)
  }

  ## Estimate header row height from column width vs label length:
  ## if the longest label fits on one line at colWidth, use ~26 px;
  ## otherwise allow 2 lines (~48 px)
  singleLinePx <- maxColChars * pxPerChar
  if(singleLinePx <= colWidth - 16)
  {
    headerRowHeight <- 26
  } else {
    headerRowHeight <- 48
  }

  ## Row height: fixed to fit the box with comfortable padding
  rowHeight <- boxSize + 12

  headerY <- quesY + ques.height + 20
  startY  <- headerY + headerRowHeight

  ## Place column headers
  tmp <- [ques]
  loop(i, Sequence(1, numPoints, 1))
  {
    hdr  <- Nth(headerObjects, i)
    hdrX <- startX + labelColWidth + (i - 1) * colWidth
    AddObject(hdr, gWin)
    Move(hdr, hdrX, headerY)
    PushOnEnd(tmp, hdr)
  }

  ## Create grid rows
  gridRows     <- []
  allClickBoxes <- []

  loop(itemIdx, Sequence(1, numItems, 1))
  {
    ## Vertical center of this row
    rowY <- startY + Round((itemIdx - 1) * rowHeight + rowHeight / 2)

    ## Row label — top-left positioned, vertically centered on rowY
    lbl <- Nth(rowLabelObjects, itemIdx)
    AddObject(lbl, gWin)
    Move(lbl, startX, Round(rowY - lbl.height / 2))
    PushOnEnd(tmp, lbl)

    ## Click boxes
    rowBoxes <- []
    loop(optIdx, Sequence(1, numPoints, 1))
    {
      boxX <- startX + labelColWidth + Round((optIdx - 1) * colWidth + colWidth / 2)
      box  <- Rectangle(boxX, rowY, boxSize, boxSize, MakeColor("grey40"), 0)
      box.color <- MakeColor("grey60")
      AddObject(box, gWin)
      PushOnEnd(tmp, box)
      PushOnEnd(rowBoxes, box)
      PushOnEnd(allClickBoxes, box)
    }

    ## Selection indicator (initially hidden, moved on click)
    indicator <- Rectangle(0, rowY, boxSize, boxSize, MakeColor("darkgreen"), 1)
    AddObject(indicator, gWin)
    Hide(indicator)
    PushOnEnd(tmp, indicator)

    rowData <- MakeCustomObject("GridRow")
    rowData.boxes <- rowBoxes
    rowData.indicator <- indicator
    rowData.selectedIdx <- 0
    PushOnEnd(gridRows, rowData)
  }

  ## DONE / SKIP / BACK buttons below grid
  doneY <- startY + numItems * rowHeight + 30
  doneBtn <- MakeScaleButton("NEXT", gVideoWidth/2, doneY, 150, 50)
  Hide(doneBtn.border)
  Hide(doneBtn.label)

  isRequired <- IsQuestionRequired(qdef, scaleDef)
  skipBtn <- 0
  if(not isRequired)
  {
    skipBtn <- MakeSkipButton(gVideoWidth/2 + 200, doneY)
  }

  gridBackBtn <- 0
  if(gCanGoBack)
  {
    gridBackBtn <- MakeBackButton(gVideoWidth/2 - 200, doneY)
  }

  Draw()

  ## Interaction loop
  t1 <- GetTime()
  allDone <- 0
  wasSkipped <- 0
  wentBack <- 0
  responses <- Repeat(0, numItems)

  ## Pre-fill from previous response (space-separated column indices, one per row)
  if(prefill != "")
  {
    prefillParts <- SplitString(prefill, " ")
    loop(itemIdx, Sequence(1, numItems, 1))
    {
      if(Length(prefillParts) >= itemIdx)
      {
        optIdx <- ToNumber(Nth(prefillParts, itemIdx))
        if(optIdx > 0 and optIdx <= numPoints)
        {
          SetElement(responses, itemIdx, optIdx)
          rowData <- Nth(gridRows, itemIdx)
          rowData.selectedIdx <- optIdx
          boxX <- startX + labelColWidth + Round((optIdx - 1) * colWidth + colWidth / 2)
          rowData.indicator.x <- boxX
          Show(rowData.indicator)
        }
      }
    }
    Draw()
  }

  while(not allDone)
  {
    ## Merge(allClickBoxes, []) produces a value copy so PushOnEnd below
    ## does not permanently grow allClickBoxes across loop iterations.
    clickTargets <- Merge(allClickBoxes, [])
    clickKeys    <- []

    ## Keys encode row and column: itemIdx * 100 + optIdx
    loop(itemIdx, Sequence(1, numItems, 1))
    {
      loop(optIdx, Sequence(1, numPoints, 1))
      {
        PushOnEnd(clickKeys, itemIdx * 100 + optIdx)
      }
    }

    ## Show DONE when all required rows have a response (optional rows may be skipped)
    numResponses <- 0
    loop(rowIdx2, Sequence(1, numItems, 1))
    {
      r <- Nth(responses, rowIdx2)
      isOptRow <- IsMember(rowIdx2, optionalRowIdxs)
      if(r > 0 or isOptRow)
      {
        numResponses <- numResponses + 1
      }
    }

    if(numResponses == numItems)
    {
      PushOnEnd(clickTargets, doneBtn.border)
      PushOnEnd(clickKeys, -1)
      Show(doneBtn.border)
      Show(doneBtn.label)
    }

    if(skipBtn != 0)
    {
      PushOnEnd(clickTargets, skipBtn.border)
      PushOnEnd(clickKeys, -2)
    }

    if(gridBackBtn != 0)
    {
      PushOnEnd(clickTargets, gridBackBtn.border)
      PushOnEnd(clickKeys, -3)
    }

    Draw()
    clickKey <- WaitForClickOnTarget(clickTargets, clickKeys)

    if(clickKey == -2)
    {
      allDone <- 1
      wasSkipped <- 1
    } elseif(clickKey == -3)
    {
      allDone <- 1
      wentBack <- 1
    } elseif(clickKey == -1)
    {
      allDone <- 1
    } else {
      ## Decode row and column from key
      itemIdx <- Floor(clickKey / 100)
      optIdx  <- clickKey - (itemIdx * 100)

      rowData <- Nth(gridRows, itemIdx)
      rowData.selectedIdx <- optIdx
      SetElement(responses, itemIdx, optIdx)

      ## Move indicator to selected column
      boxX <- startX + labelColWidth + Round((optIdx - 1) * colWidth + colWidth / 2)
      rowData.indicator.x <- boxX
      Show(rowData.indicator)
    }
  }

  t2 <- GetTime()

  ## Build space-separated response string
  respString <- ""
  if(wasSkipped)
  {
    respString <- "NA"
  } else {
    if(not wentBack)
    {
      if(Length(responses) > 0)
      {
        respString <- First(responses) + ""
        if(Length(responses) > 1)
        {
          loop(i, Sequence(2, Length(responses), 1))
          {
            respString <- respString + " " + Nth(responses, i)
          }
        }
      }
    }
  }

  ## Cleanup
  RemoveObjects(tmp, gWin)
  RemoveObject(doneBtn.border, gWin)
  RemoveObject(doneBtn.label, gWin)
  if(skipBtn != 0)
  {
    RemoveObject(skipBtn.border, gWin)
    RemoveObject(skipBtn.label, gWin)
  }
  if(gridBackBtn != 0)
  {
    RemoveObject(gridBackBtn.border, gWin)
    RemoveObject(gridBackBtn.label, gWin)
  }
  gLayout.subheader.text <- ""

  retVal <- [respString, t2-t1]
  if(wentBack)
  {
    retVal <- [-1, 0]
  }
  return(retVal)
}


##---------------------------------------------------------------
## Input validation helpers (C9)
##---------------------------------------------------------------

## Count words in a string by splitting on spaces and counting non-empty tokens.
define CountWords(text)
{
  words <- SplitString(text, " ")
  count <- 0
  loop(w, words)
  {
    if(StringLength(w) > 0)
    {
      count <- count + 1
    }
  }
  return(count)
}


## Resolve an error key to a translated string, or return defaultMsg if not found.
define ResolveError(errorKey, defaultMsg)
{
  msg <- defaultMsg
  if(StringLength(errorKey) > 0)
  {
    if(PropertyExists(gStrings, errorKey))
    {
      msg <- GetProperty(gStrings, errorKey)
    }
  }
  return(msg)
}


## GetValidationError: checks all text-entry constraints in the new flat multi-constraint format.
## Returns the first error message found, or "" if all constraints pass.
define GetValidationError(qdef, resp)
{
  errorMsg <- ""

  if(PropertyExists(qdef, "validation"))
  {
    v <- qdef.validation
    respLen <- StringLength(resp)

    ## --- Character length constraints ---
    if(errorMsg == "")
    {
      if(PropertyExists(v, "min_length"))
      {
        if(respLen < v.min_length)
        {
          errKey <- ""
          if(PropertyExists(v, "min_length_error")) { errKey <- v.min_length_error }
          errorMsg <- ResolveError(errKey, "Response must be at least " + v.min_length + " characters")
        }
      }
    }
    if(errorMsg == "")
    {
      if(PropertyExists(v, "max_length"))
      {
        if(respLen > v.max_length)
        {
          errKey <- ""
          if(PropertyExists(v, "max_length_error")) { errKey <- v.max_length_error }
          errorMsg <- ResolveError(errKey, "Response must be at most " + v.max_length + " characters")
        }
      }
    }

    ## --- Word count constraints ---
    if(errorMsg == "")
    {
      if(PropertyExists(v, "min_words"))
      {
        wordCount <- CountWords(resp)
        if(wordCount < v.min_words)
        {
          errKey <- ""
          if(PropertyExists(v, "min_words_error")) { errKey <- v.min_words_error }
          errorMsg <- ResolveError(errKey, "Response must be at least " + v.min_words + " words")
        }
      }
    }
    if(errorMsg == "")
    {
      if(PropertyExists(v, "max_words"))
      {
        wordCount <- CountWords(resp)
        if(wordCount > v.max_words)
        {
          errKey <- ""
          if(PropertyExists(v, "max_words_error")) { errKey <- v.max_words_error }
          errorMsg <- ResolveError(errKey, "Response must be at most " + v.max_words + " words")
        }
      }
    }

    ## --- Numeric range constraints ---
    if(errorMsg == "")
    {
      if(PropertyExists(v, "number_min"))
      {
        if(respLen > 0)
        {
          numVal <- ToNumber(resp)
          if(numVal < v.number_min)
          {
            errKey <- ""
            if(PropertyExists(v, "number_min_error")) { errKey <- v.number_min_error }
            errorMsg <- ResolveError(errKey, "Value must be at least " + v.number_min)
          }
        }
      }
    }
    if(errorMsg == "")
    {
      if(PropertyExists(v, "number_max"))
      {
        if(respLen > 0)
        {
          numVal <- ToNumber(resp)
          if(numVal > v.number_max)
          {
            errKey <- ""
            if(PropertyExists(v, "number_max_error")) { errKey <- v.number_max_error }
            errorMsg <- ResolveError(errKey, "Value must be at most " + v.number_max)
          }
        }
      }
    }

    ## --- Regex pattern constraint ---
    if(errorMsg == "")
    {
      if(PropertyExists(v, "pattern"))
      {
        if(respLen > 0)
        {
          if(RegexMatch(resp, v.pattern) == 0)
          {
            errKey <- ""
            if(PropertyExists(v, "pattern_error")) { errKey <- v.pattern_error }
            errorMsg <- ResolveError(errKey, "Response does not match required format")
          }
        }
      }
    }
  }

  return(errorMsg)
}


## GetMulticheckValidationError: checks min/max selection constraints.
## Returns the first error message found, or "" if all constraints pass.
define GetMulticheckValidationError(qdef, numChecked)
{
  errorMsg <- ""

  if(PropertyExists(qdef, "validation"))
  {
    v <- qdef.validation

    if(errorMsg == "")
    {
      if(PropertyExists(v, "min_selected"))
      {
        if(numChecked < v.min_selected)
        {
          errKey <- ""
          if(PropertyExists(v, "min_selected_error")) { errKey <- v.min_selected_error }
          errorMsg <- ResolveError(errKey, "Please select at least " + v.min_selected + " options")
        }
      }
    }
    if(errorMsg == "")
    {
      if(PropertyExists(v, "max_selected"))
      {
        if(numChecked > v.max_selected)
        {
          errKey <- ""
          if(PropertyExists(v, "max_selected_error")) { errKey <- v.max_selected_error }
          errorMsg <- ResolveError(errKey, "Please select at most " + v.max_selected + " options")
        }
      }
    }
  }

  return(errorMsg)
}


define DoShortAnswer(qdef, scaleDef, prefill:"")
{
  ## Short text entry - user types response and hits enter
  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))

  isRequired <- IsQuestionRequired(qdef, scaleDef)

  ## Use Layout subheader for instructions
  if(isRequired)
  {
    gLayout.subheader.text <- "Respond below. Hit enter when finished. (Response required)"
  } else {
    gLayout.subheader.text <- "Respond below. Hit enter when finished."
  }

  ## Question text in stimulus region (TextBox placed by upper-left corner)
  boxWidth <- gLayout.stimulusRegion.width - 40
  boxHeight <- 150
  boxX <- gLayout.stimulusRegion.x + 20
  boxY <- gLayout.stimulusRegion.y + 10

  ques <- MakeTextBox(questionText, gQuestFont, boxWidth, boxHeight)
  ques.text <- questionText
  ques.font <- gQuestFont
  ques.isadaptive <- 1
  ques.formatted <- 1
  AddObject(ques, gWin)
  Move(ques, boxX, boxY)

  ## Text entry box centered horizontally, positioned below question text
  maxlength <- 50
  if(PropertyExists(qdef, "maxlength"))
  {
    maxlength <- qdef.maxlength
  }

  tbWidth <- 800
  tbHeight <- 60
  tbX <- (gVideoWidth - tbWidth)/2
  tbY <- boxY + boxHeight + 40  ## Position below question with 40px gap
  tb <- MakeTextBox("", gQuestFont, tbWidth, tbHeight)
  AddObject(tb, gWin)
  Move(tb, tbX, tbY)

  ## Hint label just above the text entry box
  shortHintFont <- MakeFont(gPEBLBaseFont, 0, 20, MakeColor("grey60"), gTheme.windowBg, 0)
  shortHintLabel <- MakeLabel(gRunnerStrings.type_hint, shortHintFont)
  AddObject(shortHintLabel, gWin)
  Move(shortHintLabel, gVideoWidth/2, tbY - 20)

  ## Pre-fill previous answer if returning via Back
  if(prefill != "")
  {
    tb.text <- prefill
    if(isRequired)
    {
      gLayout.subheader.text <- "Previous answer shown. Edit or press Enter to confirm. (Required)"
    } else {
      gLayout.subheader.text <- "Previous answer shown. Edit or press Enter to confirm."
    }
  }

  Draw()

  t1 <- GetTime()

  ## Check for number validation (use digit-only keyboard)
  hasNumberValidation <- 0
  if(PropertyExists(qdef, "validation"))
  {
    if(PropertyExists(qdef.validation, "number_min") or PropertyExists(qdef.validation, "number_max"))
    {
      hasNumberValidation <- 1
    }
  }

  validEntry <- 0
  while(not validEntry)
  {
    if(hasNumberValidation)
    {
      resp <- GetNumberInput(tb, prefill)
    } else {
      resp <- GetInput(tb, "<return>")
    }

    ## Check required
    if(isRequired and StringLength(resp) == 0)
    {
      tb.text <- ""
      gLayout.subheader.text <- "Response required. Please enter a value."
      Draw()
    } else {
      ## Run validation
      valError <- GetValidationError(qdef, resp)
      if(valError != "")
      {
        tb.text <- ""
        gLayout.subheader.text <- valError
        Draw()
      } else {
        validEntry <- 1
      }
    }
  }

  t2 <- GetTime()

  RemoveObject(ques, gWin)
  RemoveObject(tb, gWin)
  RemoveObject(shortHintLabel, gWin)
  gLayout.subheader.text <- ""

  return([resp, t2-t1])
}


define GetNumberInput(textbox, initialValue:"")
{
  ## Digit-only input: accepts 0-9, backspace, enter/return
  ## Displays typed digits in the provided textbox
  ## Returns the entered number as a string
  ## initialValue: pre-fill with a previous response (empty string = no pre-fill)

  opts <- ["1","2","3","4","5","6","7","8","9","0",
           "<kp_1>","<kp_2>","<kp_3>","<kp_4>","<kp_5>","<kp_6>",
           "<kp_7>","<kp_8>","<kp_9>","<kp_0>",
           "<backspace>","<return>","<kp_enter>"]

  done <- 0
  out <- initialValue + ""
  textbox.text <- out

  while(not done)
  {
    resp <- WaitForListKeyPress(opts)

    if(resp == "<return>" or resp == "<kp_enter>")
    {
      done <- 1
    } else {
      if(resp == "<backspace>")
      {
        if(StringLength(out) <= 1)
        {
          out <- ""
        } else {
          out <- SubString(out, 1, StringLength(out) - 1)
        }
      } else {
        ## Strip keypad prefix: "<kp_5>" -> "5"
        if(SubString(resp, 1, 4) == "<kp_")
        {
          resp <- SubString(resp, 5, 1)
        }
        out <- out + resp
      }

      textbox.text <- out
      Draw()
    }
  }

  return(out)
}


define DoLongAnswer(qdef, scaleDef, prefill:"")
{
  ## Long text entry with edit/confirm workflow.
  ## Always starts in typing mode so the textbox is immediately active.
  ## After pressing Enter, transitions to review mode (NEXT / EDIT / BACK).
  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))

  isRequired <- IsQuestionRequired(qdef, scaleDef)

  gLayout.subheader.text <- ""

  ## Question text in stimulus region (TextBox placed by upper-left corner)
  quesWidth <- gLayout.stimulusRegion.width - 40
  quesHeight <- 120
  quesX <- gLayout.stimulusRegion.x + 20
  quesY <- gLayout.stimulusRegion.y + 10

  ques <- MakeTextBox(questionText, gQuestFont, quesWidth, quesHeight)
  ques.text <- questionText
  ques.font <- gQuestFont
  ques.isadaptive <- 1
  ques.formatted <- 1
  AddObject(ques, gWin)
  Move(ques, quesX, quesY)

  ## Text entry box (larger for long answers, placed by upper-left corner)
  rows <- 5
  cols <- 60
  if(PropertyExists(qdef, "rows"))
  {
    rows <- qdef.rows
  }
  if(PropertyExists(qdef, "cols"))
  {
    cols <- qdef.cols
  }

  tbWidth <- 800
  tbHeight <- gVideoHeight - 510
  tbX <- (gVideoWidth - tbWidth)/2
  tbY <- quesY + quesHeight + 40
  tb <- MakeTextBox("", gQuestFont, tbWidth, tbHeight)
  AddObject(tb, gWin)
  Move(tb, tbX, tbY)

  ## Hint label just above the text entry box (shown only in typing/edit mode)
  hintFont <- MakeFont(gPEBLBaseFont, 0, 20, MakeColor("grey60"), gTheme.windowBg, 0)
  hintLabel <- MakeLabel(gRunnerStrings.type_hint, hintFont)
  AddObject(hintLabel, gWin)
  Move(hintLabel, gVideoWidth/2, tbY - 20)

  ## NEXT and EDIT buttons
  nextBtn <- MakeScaleButton("NEXT", gVideoWidth/2, gVideoHeight-100, 150, 50)
  editBtn <- MakeScaleButton("EDIT", gVideoWidth/2 + 180, gVideoHeight-100, 150, 50)

  ## BACK button for revisable sections
  longBackBtn <- 0
  if(gCanGoBack)
  {
    longBackBtn <- MakeBackButton(gVideoWidth/2 - 200, gVideoHeight-100)
  }

  alldone <- 0
  inReview <- 0  ## 0 = typing mode (GetInput active), 1 = review mode (click targets active)
  wentBack <- 0
  t1 <- GetTime()
  t2 <- t1

  ## Pre-fill previous answer if returning via Back; jump straight to review mode
  resp <- ""
  if(prefill != "")
  {
    resp <- prefill
    tb.text <- resp
    inReview <- 1
    gLayout.subheader.text <- "Previous answer shown. Click NEXT to confirm or EDIT to change."
    Show(nextBtn.border)
    Show(nextBtn.label)
    Show(editBtn.border)
    Show(editBtn.label)
    Hide(hintLabel)
  } else {
    ## Always start in typing mode so the textbox is immediately active
    if(isRequired)
    {
      gLayout.subheader.text <- "Type response below, and hit enter when finished."
    } else {
      gLayout.subheader.text <- "Type response below and hit enter, or press enter to skip."
    }
    Hide(nextBtn.border)
    Hide(nextBtn.label)
    Hide(editBtn.border)
    Hide(editBtn.label)
    Show(hintLabel)
  }
  Draw()

  while(not alldone)
  {
    if(not inReview)
    {
      ## Typing mode: keyboard active, mouse inactive
      resp <- GetInput(tb, "<return>")
      t2 <- GetTime()

      if(isRequired and StringLength(resp) == 0)
      {
        ## Required and empty: re-prompt, stay in typing mode
        gLayout.subheader.text <- "Response required. Please type a response and hit enter."
        Draw()
      } else {
        ## Run validation (skip for empty optional — empty is a valid skip)
        valError <- ""
        if(StringLength(resp) > 0)
        {
          valError <- GetValidationError(qdef, resp)
        }
        if(valError != "")
        {
          gLayout.subheader.text <- valError
          Draw()
        } else {
          ## Transition to review mode
          inReview <- 1
          if(StringLength(resp) == 0)
          {
            gLayout.subheader.text <- "No response entered. Click NEXT to skip, EDIT to type a response."
          } else {
            gLayout.subheader.text <- "Click NEXT to confirm answer, or EDIT to change answer."
          }
          Show(nextBtn.border)
          Show(nextBtn.label)
          Show(editBtn.border)
          Show(editBtn.label)
          Hide(hintLabel)
          Draw()
        }
      }
    } else {
      ## Review mode: mouse active, waiting for NEXT, EDIT, or BACK
      if(longBackBtn != 0)
      {
        response <- WaitForClickOnTarget([nextBtn.border, editBtn.border, longBackBtn.border], [1, 2, 3])
      } else {
        response <- WaitForClickOnTarget([nextBtn.border, editBtn.border], [1, 2])
      }
      if(response == 2)
      {
        ## EDIT clicked: return to typing mode
        inReview <- 0
        if(isRequired)
        {
          gLayout.subheader.text <- "Type response below, and hit enter when finished."
        } else {
          gLayout.subheader.text <- "Type response below and hit enter, or press enter to skip."
        }
        Hide(nextBtn.border)
        Hide(nextBtn.label)
        Hide(editBtn.border)
        Hide(editBtn.label)
        Show(hintLabel)
        Draw()
      } elseif(response == 3)
      {
        ## BACK clicked
        wentBack <- 1
        alldone <- 1
      } else {
        ## NEXT clicked — confirmed
        t2 <- GetTime()
        alldone <- 1
      }
    }
  }

  RemoveObjects([ques, tb, hintLabel, nextBtn.border, nextBtn.label, editBtn.border, editBtn.label], gWin)
  if(longBackBtn != 0)
  {
    RemoveObject(longBackBtn.border, gWin)
    RemoveObject(longBackBtn.label, gWin)
  }
  gLayout.subheader.text <- ""

  retVal <- [resp, t2-t1]
  if(wentBack)
  {
    retVal <- [-1, 0]
  }
  return(retVal)
}

define DoMultiChoice(qdef, scaleDef, prefill:"")
{
  ## Multiple choice - click a row to select, then click NEXT to confirm
  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))

  ## Use Layout subheader for instructions
  gLayout.subheader.text <- "Click on the best answer to the question:"

  ## Resolve question head: item-level (qdef.question_head) overrides scale-level
  questionHead <- ""
  if(PropertyExists(qdef, "question_head"))
  {
    if(PropertyExists(gStrings, qdef.question_head))
    {
      questionHead <- GetProperty(gStrings, qdef.question_head)
    }
  } elseif(PropertyExists(scaleDef, "likert_options"))
  {
    if(PropertyExists(scaleDef.likert_options, "question_head"))
    {
      headKey <- scaleDef.likert_options.question_head
      if(PropertyExists(gStrings, headKey))
      {
        questionHead <- GetProperty(gStrings, headKey)
      }
    }
  }

  ## Question text in stimulus region
  boxWidth <- gLayout.stimulusRegion.width - 40
  boxHeight <- 150
  boxX <- gLayout.stimulusRegion.x + 20
  boxY <- gLayout.stimulusRegion.y + 10

  ## Show question head above the item text if present
  tmp <- []
  if(questionHead != "" and questionHead != 0)
  {
    headBox <- MakeTextBox(questionHead, gHeadFont, boxWidth, 80)
    headBox.isadaptive <- 1
    headBox.formatted <- 1
    AddObject(headBox, gWin)
    Move(headBox, boxX, boxY)
    PushOnEnd(tmp, headBox)
    boxY <- boxY + headBox.height + 5
  }

  ques <- MakeTextBox(questionText, gQuestFont, boxWidth, boxHeight)
  ques.text <- questionText
  ques.font <- gQuestFont
  ques.isadaptive <- 1
  ques.formatted <- 1
  AddObject(ques, gWin)
  Move(ques, boxX, boxY)

  ## Build option list from translations
  ## Options can be plain strings (translation keys) OR objects {text_key, value, ...}
  opts <- []
  loop(opt, qdef.options)
  {
    if(IsString(opt))
    {
      optKey <- opt
      optResponseVal <- opt
    } else {
      ## Object format: text_key for display, value for stored response
      optKey <- opt.text_key
      if(PropertyExists(opt, "value"))
      {
        optResponseVal <- opt.value
      } else {
        optResponseVal <- optKey
      }
    }
    if(PropertyExists(gStrings, optKey))
    {
      optText <- GetProperty(gStrings, optKey)
    } else {
      optText <- optKey
    }
    PushOnEnd(opts, [optResponseVal, optText])
  }

  ## Shuffle options if randomize_options is set
  if(PropertyExists(qdef, "randomize_options"))
  {
    if(qdef.randomize_options)
    {
      opts <- Shuffle(opts)
    }
  }

  ## Create selectable option rows
  rowRects <- []   ## full-width border boxes — click targets
  numHLs <- []     ## small darkgreen squares around number — selection highlight
  rlist <- []
  keylist <- []
  skip <- 50
  left <- gLayout.stimulusRegion.x + 80
  top <- boxY + ques.height + 40

  optionFont <- MakeFont(gPEBLBaseFont, 0, 22, gTheme.questionText, gTheme.windowBg, 0)
  optionFont.bgcolor.alpha <- 0  ## transparent background so numHL shows through

  numFont <- MakeFont(gPEBLBaseFont, 0, 22, gTheme.questionText, gTheme.windowBg, 0)
  numFont.bgcolor.alpha <- 0

  ## Row rectangle spans most of the stimulus region width
  rowWidth <- gLayout.stimulusRegion.width - 60
  rowCenterX <- gLayout.stimulusRegion.x + 30 + rowWidth / 2

  numOpts <- Length(opts)
  optnum <- 1
  loop(opt, opts)
  {
    optValue <- First(opt)
    optText <- Second(opt)
    y <- top + (optnum-1)*skip

    ## Small darkgreen highlight square behind the number (shown when selected)
    numHL <- Rectangle(left, y, skip-5, skip-5, MakeColor("darkgreen"), 0)
    AddObject(numHL, gWin)
    PushOnEnd(numHLs, numHL)

    ## Full-width border-only row box (click target, always visible border)
    rowRect <- Rectangle(rowCenterX, y, rowWidth, skip-5, gTheme.optionBorder, 0)
    rowRect.color <- gTheme.optionBorder
    AddObject(rowRect, gWin)
    PushOnEnd(rowRects, rowRect)
    PushOnEnd(rlist, rowRect)
    PushOnEnd(keylist, optnum)

    ## Number label (drawn on top of numHL)
    numLabel <- MakeLabel(optnum + ".", numFont)
    AddObject(numLabel, gWin)
    Move(numLabel, left, y)
    PushOnEnd(tmp, numLabel)

    ## Option text
    textWidth <- gLayout.stimulusRegion.width - 200
    text <- MakeTextBox(optText, optionFont, textWidth, skip - 10)
    text.isadaptive <- 1
    AddObject(text, gWin)
    Move(text, left + 50, y - (skip-10)/2)
    PushOnEnd(tmp, text)

    optnum <- optnum + 1
  }

  buttonY <- top + numOpts * skip + 25

  ## NEXT button (hidden until a selection is made)
  nextBtn <- MakeScaleButton("NEXT", gVideoWidth/2, buttonY, 150, 50)
  PushOnEnd(tmp, nextBtn.border)
  PushOnEnd(tmp, nextBtn.label)

  ## SKIP button for optional questions
  isRequired <- IsQuestionRequired(qdef, scaleDef)
  skipBtn <- 0
  if(not isRequired)
  {
    skipBtn <- MakeSkipButton(gVideoWidth/2 + 200, buttonY)
    PushOnEnd(tmp, skipBtn.border)
    PushOnEnd(tmp, skipBtn.label)
  }

  ## BACK button for revisable sections
  mcBackBtn <- 0
  if(gCanGoBack)
  {
    mcBackBtn <- MakeBackButton(gVideoWidth/2 - 200, buttonY)
    PushOnEnd(tmp, mcBackBtn.border)
    PushOnEnd(tmp, mcBackBtn.label)
  }

  ## Pre-fill: find matching option by value key and pre-select it
  selectedIdx <- 0
  if(prefill != "")
  {
    loop(i, Sequence(1, numOpts, 1))
    {
      if(First(Nth(opts, i)) == prefill)
      {
        selectedIdx <- i
      }
    }
    if(selectedIdx > 0)
    {
      SetSingleSelection(numHLs, selectedIdx)
    }
  }

  ## NEXT hidden until a selection is made
  nextVisible <- 1
  if(selectedIdx == 0)
  {
    Hide(nextBtn.border)
    Hide(nextBtn.label)
    nextVisible <- 0
  }

  Draw()

  t1 <- GetTime()
  continueLoop <- 1
  wasSkipped <- 0
  wentBack <- 0

  while(continueLoop)
  {
    curTargets <- rlist
    curKeys <- keylist

    if(selectedIdx > 0)
    {
      curTargets <- Merge(curTargets, [nextBtn.border])
      curKeys <- Merge(curKeys, [-1])
    }

    if(skipBtn != 0)
    {
      curTargets <- Merge(curTargets, [skipBtn.border])
      curKeys <- Merge(curKeys, [-2])
    }

    if(mcBackBtn != 0)
    {
      curTargets <- Merge(curTargets, [mcBackBtn.border])
      curKeys <- Merge(curKeys, [-3])
    }

    clicked <- WaitForClickOnTarget(curTargets, curKeys)

    if(clicked == -1)
    {
      continueLoop <- 0
    } elseif(clicked == -2)
    {
      continueLoop <- 0
      wasSkipped <- 1
    } elseif(clicked == -3)
    {
      continueLoop <- 0
      wentBack <- 1
    } else {
      selectedIdx <- clicked
      SetSingleSelection(numHLs, selectedIdx)

      Show(nextBtn.border)
      Show(nextBtn.label)
      nextVisible <- 1
      Draw()

      if(gSectionRevisable)
      {
        ## Auto-advance: briefly show NEXT then move on
        Wait(400)
        continueLoop <- 0
      }
    }
  }

  t2 <- GetTime()

  if(wasSkipped)
  {
    response <- "NA"
  } elseif(wentBack)
  {
    response <- "BACK"
  } else {
    response <- First(Nth(opts, selectedIdx))
  }

  RemoveObjects(tmp, gWin)
  RemoveObjects(rowRects, gWin)
  RemoveObjects(numHLs, gWin)
  RemoveObject(ques, gWin)
  gLayout.subheader.text <- ""

  retVal <- [response, t2-t1]
  if(wentBack)
  {
    retVal <- [-1, 0]
  }
  return(retVal)
}

define DoMultiCheck(qdef, scaleDef, prefill:"")
{
  ## Multiple selection - check all that apply
  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))

  ## Use Layout subheader for instructions
  gLayout.subheader.text <- "Click on all options that apply:"

  ## Resolve question head: item-level (qdef.question_head) overrides scale-level
  questionHead <- ""
  if(PropertyExists(qdef, "question_head"))
  {
    if(PropertyExists(gStrings, qdef.question_head))
    {
      questionHead <- GetProperty(gStrings, qdef.question_head)
    }
  } elseif(PropertyExists(scaleDef, "likert_options"))
  {
    if(PropertyExists(scaleDef.likert_options, "question_head"))
    {
      headKey <- scaleDef.likert_options.question_head
      if(PropertyExists(gStrings, headKey))
      {
        questionHead <- GetProperty(gStrings, headKey)
      }
    }
  }

  ## Question text in stimulus region (TextBox placed by upper-left corner)
  boxWidth <- gLayout.stimulusRegion.width - 40
  boxHeight <- 150
  boxX <- gLayout.stimulusRegion.x + 20
  boxY <- gLayout.stimulusRegion.y + 10

  ## Show question head above the item text if present
  tmp <- []
  if(questionHead != "" and questionHead != 0)
  {
    headBox <- MakeTextBox(questionHead, gHeadFont, boxWidth, 80)
    headBox.isadaptive <- 1
    headBox.formatted <- 1
    AddObject(headBox, gWin)
    Move(headBox, boxX, boxY)
    PushOnEnd(tmp, headBox)
    boxY <- boxY + headBox.height + 5
  }

  ques <- MakeTextBox(questionText, gQuestFont, boxWidth, boxHeight)
  ques.text <- questionText
  ques.font <- gQuestFont
  ques.isadaptive <- 1
  ques.formatted <- 1
  AddObject(ques, gWin)
  Move(ques, boxX, boxY)

  ## Build option list from translations
  ## Options can be plain strings (translation keys) OR objects {text_key, value, ...}
  opts <- []
  loop(opt, qdef.options)
  {
    if(IsString(opt))
    {
      optKey <- opt
      optResponseVal <- opt
    } else {
      ## Object format: text_key for display, value for stored response
      optKey <- opt.text_key
      if(PropertyExists(opt, "value"))
      {
        optResponseVal <- opt.value
      } else {
        optResponseVal <- optKey
      }
    }
    if(PropertyExists(gStrings, optKey))
    {
      optText <- GetProperty(gStrings, optKey)
    } else {
      optText <- optKey
    }
    PushOnEnd(opts, [optResponseVal, optText])
  }

  ## Shuffle options if randomize_options is set
  if(PropertyExists(qdef, "randomize_options"))
  {
    if(qdef.randomize_options)
    {
      opts <- Shuffle(opts)
    }
  }

  ## Create checkbox options in stimulus region
  rlist <- []
  keylist <- []
  skip <- 50  ## Increased spacing
  left <- gLayout.stimulusRegion.x + 60
  top <- boxY + ques.height + 40  ## Position options below question with 40px gap

  ## Create larger font for options
  optionFont <- MakeFont(gPEBLBaseFont, 0, 22, gTheme.questionText, gTheme.windowBg, 0)

  optnum <- 1
  loop(opt, opts)
  {
    optValue <- First(opt)
    optText <- Second(opt)

    ## Checkbox square (bigger)
    back <- Square(left, top + (optnum-1)*skip, 44, MakeColor("Grey40"), 0)
    AddObject(back, gWin)
    PushOnEnd(tmp, back)
    PushOnEnd(rlist, back)

    ## Option text using adaptive TextBox for better layout
    textWidth <- gLayout.stimulusRegion.width - 150
    text <- MakeTextBox(optText, optionFont, textWidth, skip - 10)
    text.isadaptive <- 1
    AddObject(text, gWin)
    Move(text, left + 60, top + (optnum-1)*skip - (skip-10)/2)
    PushOnEnd(tmp, text)

    PushOnEnd(keylist, optnum)
    optnum <- optnum + 1
  }

  numOpts <- Length(opts)
  checks <- SubList(rlist, 1, numOpts)  ## Keep copy of just checkbox squares (before adding NEXT button)
  checked <- Repeat(0, numOpts)

  ## Pre-fill: parse pipe-separated option keys and pre-check matching boxes
  if(prefill != "")
  {
    prefillParts <- SplitString(prefill, "|")
    idx <- 1
    loop(opt, opts)
    {
      optValue <- First(opt)
      loop(pf, prefillParts)
      {
        if(pf == optValue)
        {
          SetElement(checked, idx, 1)
        }
      }
      idx <- idx + 1
    }
    DrawChecks(checks, checked)
  }

  ## Determine if required
  isRequired <- IsQuestionRequired(qdef, scaleDef)

  ## NEXT button using MakeScaleButton (positioned dynamically based on number of options)
  buttonY <- top + (numOpts+1)*skip
  nextBtn <- MakeScaleButton("NEXT", gVideoWidth/2, buttonY, 150, 50)
  PushOnEnd(tmp, nextBtn.border)
  PushOnEnd(tmp, nextBtn.label)

  ## SKIP button for optional questions
  skipBtn <- 0
  if(not isRequired)
  {
    skipBtn <- MakeSkipButton(gVideoWidth/2 + 200, buttonY)
    PushOnEnd(tmp, skipBtn.border)
    PushOnEnd(tmp, skipBtn.label)
  }

  ## BACK button for revisable sections
  mcBackBtn <- 0
  if(gCanGoBack)
  {
    mcBackBtn <- MakeBackButton(gVideoWidth/2 - 200, buttonY)
    PushOnEnd(tmp, mcBackBtn.border)
    PushOnEnd(tmp, mcBackBtn.label)
  }

  ## Count any pre-filled checks
  numPreChecked <- 0
  loop(c, checked)
  {
    if(c) { numPreChecked <- numPreChecked + 1 }
  }

  ## Hide NEXT if required and nothing pre-checked (show when at least 1 checked)
  nextVisible <- 1
  if(isRequired and numPreChecked == 0)
  {
    Hide(nextBtn.border)
    Hide(nextBtn.label)
    nextVisible <- 0
  }

  Draw()

  t1 <- GetTime()
  continueLoop <- 1
  wasSkipped <- 0
  wentBack <- 0
  while(continueLoop)
  {
    ## Count checked items
    numChecked <- 0
    loop(c, checked)
    {
      if(c)
      {
        numChecked <- numChecked + 1
      }
    }

    ## Show/hide NEXT button based on state
    if(isRequired)
    {
      if(numChecked > 0 and (not nextVisible))
      {
        Show(nextBtn.border)
        Show(nextBtn.label)
        nextVisible <- 1
        Draw()
      } elseif(numChecked == 0 and nextVisible)
      {
        Hide(nextBtn.border)
        Hide(nextBtn.label)
        nextVisible <- 0
        Draw()
      }
    }

    ## Build click targets: always include checkboxes
    curTargets <- rlist
    curKeys <- keylist

    ## Include NEXT only if not required, or if required and at least 1 checked
    if(not isRequired)
    {
      curTargets <- Merge(curTargets, [nextBtn.border])
      curKeys <- Merge(curKeys, ["DONE"])
    } else {
      if(numChecked > 0)
      {
        curTargets <- Merge(curTargets, [nextBtn.border])
        curKeys <- Merge(curKeys, ["DONE"])
      }
    }

    ## Include SKIP button if optional
    if(skipBtn != 0)
    {
      curTargets <- Merge(curTargets, [skipBtn.border])
      curKeys <- Merge(curKeys, ["SKIP"])
    }

    ## Include BACK button if available
    if(mcBackBtn != 0)
    {
      curTargets <- Merge(curTargets, [mcBackBtn.border])
      curKeys <- Merge(curKeys, ["BACK"])
    }

    response <- WaitForClickOnTarget(curTargets, curKeys)

    if(response == "DONE")
    {
      ## Check multicheck validation before accepting
      mcValError <- GetMulticheckValidationError(qdef, numChecked)
      if(mcValError != "")
      {
        gLayout.subheader.text <- mcValError
        Draw()
      } else {
        continueLoop <- 0
      }
    } elseif(response == "SKIP")
    {
      continueLoop <- 0
      wasSkipped <- 1
    } elseif(response == "BACK")
    {
      continueLoop <- 0
      wentBack <- 1
    } else {
      ## Clicked on an option, toggle its checked state
      checked <- UpdateChecks(checked, response)
      DrawChecks(checks, checked)
      Draw()
    }
  }
  t2 <- GetTime()

  ## Build response string from checked values (pipe-separated)
  respString <- ""
  if(wasSkipped)
  {
    respString <- "NA"
  } else {
    if(not wentBack)
    {
      respList <- []
      index <- 1
      loop(isChecked, checked)
      {
        if(isChecked)
        {
          optValue <- First(Nth(opts, index))
          PushOnEnd(respList, optValue)
        }
        index <- index + 1
      }

      ## Join with pipe separator
      if(Length(respList) > 0)
      {
        respString <- First(respList)
        if(Length(respList) > 1)
        {
          loop(i, Sequence(2, Length(respList), 1))
          {
            respString <- respString + "|" + Nth(respList, i)
          }
        }
      }
    }
  }

  RemoveObjects(tmp, gWin)
  RemoveObject(ques, gWin)
  gLayout.subheader.text <- ""

  retVal <- [respString, t2-t1]
  if(wentBack)
  {
    retVal <- [-1, 0]
  }
  return(retVal)
}


define UpdateChecks(current, index)
{
  ## Toggle check state at given index
  id <- 1
  new <- []

  loop(i, current)
  {
    if(id == index)
    {
      PushOnEnd(new, 1 - i)  ## Toggle: 0->1, 1->0
    } else {
      PushOnEnd(new, i)
    }
    id <- id + 1
  }

  return(new)
}


define DrawChecks(boxes, states)
{
  ## Update filled state of checkbox squares
  combined <- Transpose([boxes, states])

  loop(pair, combined)
  {
    box <- First(pair)
    box.filled <- Second(pair)
  }
}


define SetSingleSelection(boxes, selectedIdx)
{
  ## Highlight the box at selectedIdx (1-based), clear fill on all others.
  ## Used for Likert and MultiChoice select-then-NEXT pattern.
  idx <- 1
  loop(box, boxes)
  {
    if(idx == selectedIdx)
    {
      box.filled <- 1
    } else {
      box.filled <- 0
    }
    idx <- idx + 1
  }
}


define DoInstructions(qdef, prefill:"")
{
  ## Instruction screen (no response required, just click to continue)
  gLayout.subheader.text <- ""
  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))

  ## Calculate dimensions using layout zones
  boxWidth <- gLayout.stimulusRegion.width - 100
  boxHeight <- gLayout.stimulusRegion.height
  boxX <- gLayout.stimulusRegion.x + 50
  boxY <- gLayout.stimulusRegion.y

  ## Create instruction text with border
  instBox <- MakeTextBoxWithBorder(questionText, gQuestFont, boxWidth, boxHeight, boxX, boxY)

  ## Create NEXT button in response zone (bigger: 200x60)
  buttonY <- gLayout.zones.response.y + gLayout.zones.response.height/2
  nextButton <- MakeScaleButton("NEXT", gVideoWidth/2, buttonY, 200, 60)

  ## BACK button for revisable sections
  backBtn <- 0
  if(gCanGoBack)
  {
    backBtn <- MakeBackButton(gVideoWidth/2 - 170, buttonY)
  }

  Draw()

  t1 <- GetTime()
  clickTargets <- [nextButton.border]
  clickValues <- [1]
  if(backBtn != 0)
  {
    PushOnEnd(clickTargets, backBtn.border)
    PushOnEnd(clickValues, "BACK")
  }
  resp <- WaitForClickOnTarget(clickTargets, clickValues)
  t2 <- GetTime()

  ## Cleanup
  RemoveObject(instBox.border, gWin)
  RemoveObject(instBox.textbox, gWin)
  RemoveObject(nextButton.border, gWin)
  RemoveObject(nextButton.label, gWin)
  if(backBtn != 0)
  {
    RemoveObject(backBtn.border, gWin)
    RemoveObject(backBtn.label, gWin)
  }

  retVal <- [0, t2-t1]  ## No response value for instructions
  if(resp == "BACK")
  {
    retVal <- [-1, 0]
  }
  return(retVal)
}


##############################################################################
## IMAGE QUESTION TYPE (Display image with description, NEXT to continue)
##############################################################################

define DoImage(qdef, prefill:"")
{
  ## Display image with descriptive text and NEXT button
  ## Based on survey.pbl Image() function but adapted to ScaleRunner layout
  gLayout.subheader.text <- ""

  ## Get question text from translations
  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))

  ## Get image filename from question definition
  imageFile <- qdef.image_file

  ## Load image
  img <- MakeImage(imageFile)

  ## Determine target size for image (use left portion of stimulus region)
  imgWidth <- 600
  imgHeight <- 450

  ## Calculate scaling factors
  xscale <- img.width / imgWidth
  yscale <- img.height / imgHeight

  ## Scale down if image is too large
  if(xscale > 1 or yscale > 1)
  {
    if(xscale > yscale)
    {
      scale <- xscale
    } else {
      scale <- yscale
    }

    img.zoomx <- 1 / scale
    img.zoomy <- 1 / scale
  }

  ## Position image in left portion of stimulus region
  imgX <- gLayout.stimulusRegion.x + imgWidth/2 + 10
  imgY <- gLayout.stimulusRegion.y + imgHeight/2 + 10
  AddObject(img, gWin)
  Move(img, imgX, imgY)

  ## Position text in right portion of screen
  textX <- imgX + imgWidth/2 + 30
  textY <- gLayout.stimulusRegion.y + 20
  textWidth <- gLayout.stimulusRegion.width - imgWidth - 60
  textHeight <- 300

  ## Create question text box
  ques <- MakeTextBox(questionText, gQuestFont, textWidth, textHeight)
  ques.isadaptive <- 1
  ques.formatted <- 1
  AddObject(ques, gWin)
  Move(ques, textX, textY)

  ## Create NEXT button in response zone
  buttonY <- gLayout.zones.response.y + gLayout.zones.response.height/2
  nextButton <- MakeScaleButton("NEXT", gVideoWidth/2, buttonY, 200, 60)

  ## BACK button for revisable sections
  imgBackBtn <- 0
  if(gCanGoBack)
  {
    imgBackBtn <- MakeBackButton(gVideoWidth/2 - 170, buttonY)
  }

  Draw()

  ## Wait for NEXT or BACK click
  t1 <- GetTime()
  imgClickTargets <- [nextButton.border]
  imgClickValues <- [1]
  if(imgBackBtn != 0)
  {
    PushOnEnd(imgClickTargets, imgBackBtn.border)
    PushOnEnd(imgClickValues, "BACK")
  }
  imgResp <- WaitForClickOnTarget(imgClickTargets, imgClickValues)
  t2 <- GetTime()

  ## Cleanup
  RemoveObject(img, gWin)
  RemoveObject(ques, gWin)
  RemoveObject(nextButton.border, gWin)
  RemoveObject(nextButton.label, gWin)
  if(imgBackBtn != 0)
  {
    RemoveObject(imgBackBtn.border, gWin)
    RemoveObject(imgBackBtn.label, gWin)
  }

  retVal <- ["NA", t2-t1]  ## No response value for image display
  if(imgResp == "BACK")
  {
    retVal <- [-1, 0]
  }
  return(retVal)
}


##############################################################################
## IMAGE WITH TEXT RESPONSE (Display image + collect text response)
##############################################################################

define DoImageResponse(qdef, scaleDef, prefill:"")
{
  ## Display image with text entry field and edit/confirm workflow
  ## Based on survey.pbl Image() function with collectresponses=1

  ## Get question text from translations
  questionText <- PipeAnswers(GetProperty(gStrings, qdef.text_key))

  isRequired <- IsQuestionRequired(qdef, scaleDef)

  ## Get image filename from question definition
  imageFile <- qdef.image_file

  ## Load image
  img <- MakeImage(imageFile)

  ## Determine target size for image (use left portion of stimulus region)
  imgWidth <- 600
  imgHeight <- 450

  ## Calculate scaling factors
  xscale <- img.width / imgWidth
  yscale <- img.height / imgHeight

  ## Scale down if image is too large
  if(xscale > 1 or yscale > 1)
  {
    if(xscale > yscale)
    {
      scale <- xscale
    } else {
      scale <- yscale
    }

    img.zoomx <- 1 / scale
    img.zoomy <- 1 / scale
  }

  ## Position image in left portion of stimulus region
  imgX <- gLayout.stimulusRegion.x + imgWidth/2 + 10
  imgY <- gLayout.stimulusRegion.y + imgHeight/2 + 10
  AddObject(img, gWin)
  Move(img, imgX, imgY)

  ## Position text in right portion of screen
  textX <- imgX + imgWidth/2 + 30
  textY <- gLayout.stimulusRegion.y + 20
  textWidth <- gLayout.stimulusRegion.width - imgWidth - 60
  textHeight <- 200

  ## Create question text box
  ques <- MakeTextBox(questionText, gQuestFont, textWidth, textHeight)
  ques.isadaptive <- 1
  ques.formatted <- 1
  AddObject(ques, gWin)
  Move(ques, textX, textY)

  ## Create text entry box below question text
  tbX <- textX
  tbY <- textY + textHeight + 50
  tbWidth <- textWidth
  tbHeight <- 100

  tb <- MakeTextBox("", gQuestFont, tbWidth, tbHeight)
  AddObject(tb, gWin)
  Move(tb, tbX, tbY)

  ## Create instruction label above text box
  instrText <- "Type response and hit enter:"
  instrLabel <- MakeLabel(instrText, gSmallFont)
  AddObject(instrLabel, gWin)
  Move(instrLabel, textX + textWidth/2, tbY - 30)

  ## Create NEXT and EDIT buttons in response zone
  buttonY <- gLayout.zones.response.y + gLayout.zones.response.height/2
  nextButton <- MakeScaleButton("NEXT", gVideoWidth/2 - 90, buttonY, 150, 50)
  editButton <- MakeScaleButton("EDIT", gVideoWidth/2 + 90, buttonY, 150, 50)

  ## SKIP button for optional questions
  skipBtn <- 0
  if(not isRequired)
  {
    skipBtn <- MakeSkipButton(gVideoWidth/2 + 270, buttonY)
  }

  ## Edit/confirm loop
  allDone <- 0
  wasSkipped <- 0
  t1 <- GetTime()

  while(not allDone)
  {
    ## Instruction phase: hide buttons, get text input
    instrLabel.text <- "Type response below, and hit enter when finished."
    Hide(nextButton.border)
    Hide(nextButton.label)
    Hide(editButton.border)
    Hide(editButton.label)
    Draw()

    resp <- GetInput(tb, "<return>")
    time2 <- GetTime()

    ## If required and empty, re-prompt
    if(isRequired)
    {
      if(StringLength(resp) == 0)
      {
        instrLabel.text <- "Response required. Please type a response and hit enter."
        Draw()
      } else {
        ## Confirm phase: show buttons for NEXT/EDIT choice
        instrLabel.text <- "Click NEXT to confirm answer, or EDIT to revise"
        Show(nextButton.border)
        Show(nextButton.label)
        Show(editButton.border)
        Show(editButton.label)
        Draw()

        response <- WaitForClickOnTarget([nextButton.border, editButton.border], [1, 2])
        allDone <- (response < 2)
      }
    } else {
      ## Confirm phase: show buttons for NEXT/EDIT/SKIP choice
      instrLabel.text <- "Click NEXT to confirm answer, or EDIT to revise"
      Show(nextButton.border)
      Show(nextButton.label)
      Show(editButton.border)
      Show(editButton.label)
      Draw()

      targets <- [nextButton.border, editButton.border]
      values <- [1, 2]
      if(skipBtn != 0)
      {
        targets <- Merge(targets, [skipBtn.border])
        values <- Merge(values, [3])
      }

      response <- WaitForClickOnTarget(targets, values)
      if(response == 3)
      {
        allDone <- 1
        wasSkipped <- 1
      } else {
        allDone <- (response < 2)
      }
    }
  }

  t2 <- GetTime()

  if(wasSkipped)
  {
    resp <- "NA"
  }

  ## Cleanup
  RemoveObject(img, gWin)
  RemoveObject(ques, gWin)
  RemoveObject(tb, gWin)
  RemoveObject(instrLabel, gWin)
  RemoveObject(nextButton.border, gWin)
  RemoveObject(nextButton.label, gWin)
  RemoveObject(editButton.border, gWin)
  RemoveObject(editButton.label, gWin)
  if(skipBtn != 0)
  {
    RemoveObject(skipBtn.border, gWin)
    RemoveObject(skipBtn.label, gWin)
  }

  return([resp, t2-t1])
}
