## The PEBL Symmetry Span Task
## Original implemantation by David Hegarty
##
##  Modifications by Shane Mueller
##
##
##
#


define Start(par)
 {
	## Initialize upload system (works for both online and native)
	InitializeUpload()

        GetStrings(gLanguage)

	## Create window before InitDefaults (which needs gWin)
	gWin <- MakeWindow("black")

	## Initialize LSL outlet if --lsl flag was used
	InitializeLSL(gWin)

	InitDefaults()

	parpairs <- [["feedbacktimeout",1500],
                     ["distractfile","distraction.csv"],
		     ["batterythreshold",0.85],
		     ["batteryFeedback",1],
		     ["distracttimeoutminimum",1000],
                     ["distracttimeoutmultiplier",2.5],
		     ["requirethresholdprebattery",1],
		     ["allowsecondchance",1],
		     ["responsemode","none"],
		     ["testreps",3],
		     ["testminsize",2],
		     ["testmaxsize",5]]

        gParams <- CreateParameters(parpairs,gParamFile)
	gParams.responsesemantics <- "none"
	CheckArgs()

	## Create layout - no response labels since all responses are custom mouse grid
	gLayout <- CreateLayout("symmetryspan", gWin, gParams)
	Draw()

	## Load distraction tasks
	gDistractionTasks<-LoadDistractionTasks( gDistractionFile )
	gDistractWorkingSet<-SampleN( gDistractionTasks, Length( gDistractionTasks ) )

	gDrawDebug<-DrawDebug(gDrawDebug)

	if ( gSubNum+"" == "0" )
	{
  	   gSubNum<-GetSubNum( gWin )
	}

	OpenSubOut()

        gTrial <- 1

	## Define task structure
	DefineTaskStructure()

	## Instructions
	ShowInstruction("INSTRUCTIONS", -1)

	## Practice Square Memory Only
	ShowInstruction("SQUARES", -1)
	ShowInstruction("SQUARES2", -1)
	ExecuteTaskBlock(gPracticeMemory, "practice")

	## Practice Symmetry Only
	ShowInstruction("SYMMETRY", -1)
	ShowInstruction("SYMMETRY2", -1)
	ShowInstruction("SYMMETRY3", -1)
	ShowInstruction("SYMMETRY4", -1)
	ShowInstruction("SYMMETRY5", -1)
	ShowInstruction("SYMMETRY6", -1)
	mathPracticeStats <- ExecuteTaskBlock(gPracticeMath, "practice")

	## Practice Both
	ShowInstruction("PRACBATTERY1", -1)
	ShowInstruction("PRACBATTERY2", -1)
	ShowInstruction("PRACBATTERY3", -1)
	bothPracticeStats <- ExecuteTaskBlock(gPracticeBoth, "practice")

	## Check if subject meets math accuracy criteria before test
	## Extract math accuracy from practice statistics
	## bothPracticeStats format: [results, mathCorrect, mathTotal, mathAccuracy]
	mathCorrect <- Nth(bothPracticeStats, 2)
	mathTotal <- Nth(bothPracticeStats, 3)
	mathAccuracy <- Nth(bothPracticeStats, 4)

	Print("Math practice performance: " + mathCorrect + "/" + mathTotal + " = " + mathAccuracy)

	## Check if criteria met
	metCriteria <- 1
	if(gRequireThresholdPreBattery == 1 and mathAccuracy < gBatteryThreshold)
	{
		metCriteria <- 0
		Print("Did not meet math criteria threshold: " + gBatteryThreshold + " (got " + mathAccuracy + ")")

		## Offer second chance if enabled
		if(gAllowSecondChance == 1)
		{
			Print("Offering second chance practice...")
			ShowInstruction("SECONDCHANCE", -1)

			## Run practice both again
			bothPracticeStats <- ExecuteTaskBlock(gPracticeBoth, "practice")

			## Extract second attempt accuracy
			mathCorrect <- Nth(bothPracticeStats, 2)
			mathTotal <- Nth(bothPracticeStats, 3)
			mathAccuracy <- Nth(bothPracticeStats, 4)

			Print("Second chance performance: " + mathCorrect + "/" + mathTotal + " = " + mathAccuracy)

			## Check if criteria met on second attempt
			if(mathAccuracy >= gBatteryThreshold)
			{
				metCriteria <- 1
			}
		}
	}

	## Proceed to test battery regardless of practice performance
	if(metCriteria == 0)
	{
		## Did not meet criteria, but proceed anyway with a warning message
		ShowInstruction("PROCEED_DESPITE_THRESHOLD", -1)
		Print("Did not meet symmetry criteria threshold after all attempts, but proceeding to test")
	} else {
		## Met criteria, show normal test instructions
		ShowInstruction("TRIALS", -1)
	}

	## Main Test Battery - everyone does this
	## Track when test battery starts and record start time
	gTestStartTrial <- gTrial
	testStartTime <- GetTime()
	testStats <- ExecuteTaskBlock(gTestBattery, "test")
	testDuration <- Round((GetTime() - testStartTime) / 1000.0, 1)  ## Convert ms to seconds

	## Ending
	ShowInstruction("END", 2000)

	Print("Task completed")

	## Finalize LSL
	FinalizeLSL()

	## Close files before upload (required for Windows file locking compatibility)
	FileClose(gSubOut)
	FileClose(gPositionLog)

	## Generate HTML report
	spanReport <- CalculateSpanReport(testStats, gTestStartTrial, testDuration)
	htmlFile <- CreateHTMLReport(spanReport)

	## Upload data files (works online, no-op on native)
	## Note: .filename property persists after FileClose(), so this is safe
	out <- UploadFile(gSubNum, gSubOut.filename)
	Print(out)
	out <- UploadFile(gSubNum, gPositionLog.filename)
	Print(out)
	out <- UploadFile(gSubNum, htmlFile.filename)
	Print(out)
}


define FindFirstIndex( aList, aItem )
{
	rval<-0
	found<-0

	loop( item, aLIst )
	{
		if ( found ==0 )
		{
			rval<-rval+1 
			if ( item == aItem )
			{
				found<-1
			}
		}
	}
	if ( found == 0 )
	{
		rval <- 0
	}
	return rval
}

## Wrapper to convert library WaitForDownClick() return value to 1/0 for internal use
## Returns 1 if clicked, 0 if timeout
define WaitForClick(timeout)
{
	## Call library function (returns mouse event or "<timeout>")
	resp <- WaitForDownClick(timeout)

	## Convert to 1/0 for backward compatibility
	if(resp == "<timeout>")
	{
		rval <- 0
	} else {
		rval <- 1
	}

	return(rval)
}

# show a single distract task, returns a list, first element 0/1 for success failure second element is time taken
define ShowDistract(a_WaitTO)
{
	ShowCursor(1)
	# fill up our list of tasks again
	if( Length( gDistractWorkingSet ) == 0 )
	{
		gDistractWorkingSet<-SampleN( gDistractionTasks, Length( gDistractionTasks ) )
	}

	currDistract<-Nth(gDistractWorkingSet, 1 )
	gDistractWorkingSet<-RemoveSubset( gDistractWorkingSet, [1])

	question<-Nth( currDistract, 1 )
	answer<-Nth( currDistract, 2 )
	truthVal<-Nth( currDistract, 3 )

	## SYMSPAN-SPECIFIC: question is an image object, not text
	## For symspan, question is already a loaded image
	xPos<- gLayout.centerX
	yPos<- gLayout.centerY
	AddObject( question, gWin )
	Move( question, xPos, yPos )

	footer <- Makelabel(gContinueText,glgFont)
	AddObject(footer,gWin)
	Move(footer,gLayout.centerX,gVideoHeight-100)

	Draw()

	Print("DEBUG: ShowDistract called with timeout = " + a_WaitTO + " ms")

	elapsed<-GetTime()
	rval<-WaitForClick( a_WaitTO )

	Print("DEBUG: Symmetry problem click took " + (GetTime() - elapsed) + " ms, result = " + rval + " (1=clicked, 0=timeout)")
	RemoveObject( question, gWin )

	if ( rval != 0 ) # not timeout
	{
		spc <- 8
		keyHeight <- 1.9 * gLgFontSz
		cellHeight <- keyHeight + spc

		answerLabel<-MakeLabel( answer, gStimFont )
		xPos<- gLayout.centerX
		yPos<- gLayout.centerY - cellHeight
		Move(answerLabel, xPos,yPos)
		AddObject(answerLabel,gWin)
		Draw()

		yPos <- yPos + 2 * cellHeight

		keyWidth<-3*keyHeight
		kb <- MakeKB( gWin, ["True","False"], xPos-keyWidth/2, yPos, 2, keyWidth, keyHeight, spc, 0 )
		SetMouseCursorPosition(Floor(gLayout.centerX),FLOOR(gLayout.centerY))
		SetMouseCursorPosition(Floor(gLayout.centerX),FLOOR(gLayout.centerY))

		rtStart <- GetTime()
		resp<-GetKBInput( GetClickable( kb ), ["1", "0"]  )
		rtTime <- GetTime() - rtStart
		Print("DEBUG: TRUE/FALSE response took " + rtTime + " ms")

		if ( ToNumber( resp ) == truthVal )
		{
			# return 1 to indicate correct response
			rval <- 1
			Print("DEBUG: Response was CORRECT")
		} else {
			# return 0 to indicate incorrect response
			rval <- 0
			Print("DEBUG: Response was INCORRECT")
		}

		DestroyKB( gWin, kb )

		## Measure elapsed time AFTER the TRUE/FALSE response
		elapsed<-GetTime() - elapsed
		Print("DEBUG: Total elapsed time (problem + response) = " + elapsed + " ms")
	} else {
		# return -1 to indicate timeout in repsonse to question
		rval <- -1
		elapsed<-GetTime() - elapsed
		Print("DEBUG: TIMEOUT occurred - problem not completed in " + a_WaitTO + " ms")
	}

	return [rval,elapsed]
}

define ShowTargetLetter( testVal, timeout )
{
	ShowCursor(0)
	lText <- MakeLabel(testVal, gStimFont)
	xPos<- gLayout.centerX
	yPos<- gLayout.centerY
	Move(lText, xPos,yPos)
	AddObject(lText,gWin)
	Draw()
	Wait(timeout)
	RemoveObject(lText,gWin)
}

## Symspan-specific: Show target by highlighting grid position
define ShowSymTarget( testVal, timeout )
{
	testVal<-ToNumber(testVal)
	fakeKeys<-[]
	loop( n, Sequence( 1, gGridNumCol * gGridNumRow, 1 ) )
	{
		fakeKeys<-Append( fakeKeys, ""+n )
	}

	kbp<-GetKBPositioning()

	spc <- Nth( kbp, 1 )
	keyHeight <- Nth( kbp, 2 )
	cellHeight <- Nth( kbp, 3 )
	vShift<- Nth( kbp, 4 )
	currY <- Nth( kbp, 5 )
	currX <- Nth( kbp, 6 )
	currX <- Nth( kbp, 7 )
	currY <- Nth( kbp, 8 )

	padKb <- MakeSqKB( gWin, fakeKeys, currX, currY, gGridNumCol, keyHeight, spc, 1 )

	allLabels<-[]
	allLabels<-Flatten([allLabels, GetLabels(padKb)])
	## highlight target face
	faces <- GetKeyFaces( padKb )
	hiFace <- Nth( faces, testVal )
	hiFace.color <- gSymShownTargetColor
	Draw()

	Wait(timeout)
	DestroyKB( gWin, padKb )
}

## Symspan-specific: Get keyboard positioning parameters
define GetKBPositioning()
{
	spc <- 8
	keyHeight <- 1.9 * gLgFontSz
	cellHeight <- keyHeight + spc

	## the main keypad
	## positioning of main keypad starts from centre of screen (moved up for bigger response numbers)
	vShift<- 130
	currY <- gLayout.centerY-vShift
	currX <- gLayout.centerX
	currX <- currX - ( gGridNumCol-1)/2 * cellHeight
	currY <- currY - (gGridNumRow-1)/2 * cellHeight

	## now return them...
	rval<-[]
	rval<-Append(rval, spc )
	rval<-Append(rval, keyHeight )
	rval<-Append(rval, cellHeight )
	rval<-Append(rval, vShift )
	rval<-Append(rval, currY )
	rval<-Append(rval, currX )
	rval<-Append(rval, currX )
	rval<-Append(rval, currY )

	return rval
}

define ShowTargetInputScreen(padKeys, testVals)
{
	## SYMSPAN-SPECIFIC: Use GetKBPositioning() for consistent positioning
	kbp<-GetKBPositioning()

	spc <- Nth( kbp, 1 )
	keyHeight <- Nth( kbp, 2 )
	cellHeight <- Nth( kbp, 3 )
	vShift<- Nth( kbp, 4 )
	currY <- Nth( kbp, 5 )
	currX <- Nth( kbp, 6 )

	allClickable<-[]
	allVals<-[]
	allLabels<-[]

	## SYMSPAN-SPECIFIC: Create keyboard with hideText=0 to show numbers
	padKb <- MakeSqKB( gWin, padKeys, currX, currY, gGridNumCol, keyHeight, spc, 0 )
	allClickable<-Flatten([allClickable, GetClickable(padKb)])
	allVals<-Flatten( [allVals, padKeys] )
	allLabels<-Flatten([allLabels, GetLabels(padKb)])

	# blank key
	blankX<- currX + (Nth(padKb, 2) - currX)/2
	blankY<-Nth(padKb, 3)+keyHeight+spc
	blankKey <- [gBlankKeyText]
	blankWidth <- ( Nth(padKb, 2) - currX ) + keyHeight # width==height
	blankKb <- MakeKB( gWin, blankKey, blankX, blankY, 1, blankWidth, keyHeight, spc, 0  )

	allClickable<-Flatten([allClickable, GetClickable(blankKb)])
	allVals<-Flatten([allVals, blankKey])
	allLabels<-Flatten([allLabels, GetLabels(blankKb)] )
	
	# destination for user output - use bigger font for response numbers
	padUserInput<-25
	selLabels<-[]
	## Use bigger cell height for response numbers (50% bigger font)
	responseCellHeight <- Round(gResponseFontSz * 1.5) + spc
	selLabelX<-gLayout.centerX - ( Length( testVals ) -1 )/2* responseCellHeight
	selLabelY<-blankY + cellHeight + padUserInput

	loop ( val, testVals )
	{
		l<-MakeLabel( gNoSelectionChar, gResponseFont )
		#l<-MakeLabel( val, gResponseFont )
		AddObject(l, gWin )
		Move(l, selLabelX, selLabelY )
		selLabels<-Append(selLabels, l )
		selLabelX <-selLabelX + responseCellHeight
	}
	Draw()

	# the clear/del kb
	cdKeyWidth<-2 * keyHeight
	cdKeys <- [gClearKeyText,gDelKeyText,gDoneKeyText]
	cdX<-gLayout.centerX
	cdX<- cdX - ( cdKeyWidth + spc )
	cdY<-selLabelY + responseCellHeight + padUserInput
	cdKb <- MakeKB( gWin, cdKeys, cdX, cdY, Length(cdKeys), cdKeyWidth, keyHeight, spc, 0 )

	allClickable<-Flatten([allClickable, GetClickable(cdKb)])
	allVals<-Flatten([allVals, cdKeys])
	allLabels<-Flatten([allLabels, GetLabels(cdKb)] )

	## SYMSPAN-SPECIFIC: Extract padFaces for highlighting
	padFaces <- GetKeyFaces( padKb )

	# get the user's input
	userInput<-GetMouseInput( allClickable, allVals, allLabels, selLabels, padFaces )
	Print("UserInput:" + userInput)

	# and clean up
	DestroyKB( gWin, cdKb )
	loop( l, selLabels)
	{
		RemoveObject( l, gWin)
	}
	DestroyKB( gWin, blankKb )
	DestroyKB( gWin, padKb )
	return userInput
}

## this presents a set of (instruction) lines using adaptive formatted textbox
## Uses layout system: instructions in header+subheader zone, Next button in response labels zone

define PresentStatic( timeout, centred, staticData, isLast )
{
	## staticData should be a string (possibly with <br> tags for line breaks)
	text <- staticData

	## Create font with 25% larger size
	fontSize <- Round(gLgFontSz * 1.25)
	baseFont <- MakeFont(gPEBLBaseFont, 0, fontSize, gFGColor, gBGColor, 0)

	## Position: feedback (timeout>0) centered textbox, instructions (timeout<=0) textbox at top
	if (timeout > 0) {
		## Feedback mode - use formatted textbox centered
		boxWidth <- Floor(gVideoWidth * 0.8)
		textbox <- MakeTextBox(text, baseFont, boxWidth, 500)
		SetProperty(textbox, "FORMATTED", 1)
		SetProperty(textbox, "ISADAPTIVE", 1)
		if(centred)
		{
			SetProperty(textbox,"JUSTIFY", "CENTER")
		}
		AddObject(textbox, gWin)
		boxX <- gLayout.centerX - boxWidth/2
		boxY <- gLayout.centerY - 50
		Move(textbox, boxX, boxY)
		Draw()
		WaitForClick( timeout )
		RemoveObject(textbox, gWin)
	} else {
		## Instruction mode - 80% width textbox at top of header+subheader zone
		boxWidth <- Floor(gVideoWidth * 0.8)
		textbox <- MakeTextBox(text, baseFont, boxWidth, 500)
		SetProperty(textbox, "FORMATTED", 1)
		SetProperty(textbox, "ISADAPTIVE", 1)
		AddObject(textbox, gWin)
		boxX <- gLayout.centerX - boxWidth/2
		boxY <- 50
		Move(textbox, boxX, boxY)
		Draw()

		if ( isLast )
		{
			# wait forever (1/2 an hour). Magic combo of Ctrl-Alt-Shift-\ ends pebl
			Wait( 1800000 )
		} else {
			## Show Next button in response labels zone using layout positioning
			spc<- 50
			keyHeight <- 1.9 * gLgFontSz
			keyWidth<-3*keyHeight
			## Position button in footer/response zone (centered horizontally)
			btnX <- gLayout.centerX
			btnY <- gLayout.zones.footer.y + 50
			kb <- MakeKB( gWin, [gStrings.button_next], btnX, btnY, 1, keyWidth, keyHeight, spc, 0 )
			resp<-GetKBInput( GetClickable( kb ), ["whatevs"]  )
			DestroyKB( gWin, kb )
		}
		RemoveObject(textbox, gWin)
	}
}

define MungeString( arr )
{
	rval<-""
	first <- 1
	loop( c, arr )
	{
		if(first == 0)
		{
			rval <- rval + "|"
		}
		rval <- rval + c
		first <- 0
	}
	return rval
}

define PresentRun(  distractMS, targetMS, numTarget, stages, feedback )
{
  ## SYMSPAN-SPECIFIC: Use numbered keys 1-16 instead of letters
  padKeys<-[]
  loop( n, Sequence( 1, gGridNumCol * gGridNumRow, 1 ) )
  {
    padKeys<-Append( padKeys, ""+n )
  }
	if ( numTarget > 0 )
	{
		testVals<-SampleN(padKeys, numTarget)
	} else {
		testVals<-[]
	}

	rval<-[]

	iShownTarget<-0


	##First, show a ready signal
	ready <- MakeLabel(gReadyText,gStimFont)
	AddObject(ready,gWin)
	Move(ready,gLayout.centerX,gLayout.centerY)
	Draw()
	Wait(500)
	Hide(ready)
	Draw()
	Wait(1000)


	loop( stage, stages )
	{
		stage <- Uppercase( stage )
		if ( stage == "D" )
		{
			LSLMarker("distract_onset")
			dRes<-ShowDistract( distractMS )
			LSLMarker("distract_response")
			rval<-Append( rval, Merge( [stage], dRes ) );
		} else {  ##Stage==T
			iShownTarget<-iShownTarget+1
			LSLMarker("target_onset")
			## SYMSPAN-SPECIFIC: Call ShowSymTarget instead of ShowTargetLetter
			ShowSymTarget( Nth( testVals, iShownTarget ), targetMS )
		}
	}

	if ( numTarget > 0 )
	{
		# show grid
		LSLMarker("recall_grid_onset")
		userInput<-ShowTargetInputScreen(padKeys, testVals)
		LSLMarker("recall_complete")
		rval<-Append( rval, [ "T", MungeString( testVals ), MungeString( userInput ) ] )
	}

	if ( feedback == 1 )
	{
		distractCorrect<- 0
		distractTotal<- 0
		targetCorrect<- 0
		targetTotal<- numTarget

		loop( task, rval )
		{
			if ( Nth( task, 1 ) == "D" )
			{
				if ( Nth( task, 2 ) == 1 )
				{
				    distractCorrect <- distractCorrect + 1
				}
				distractTotal<- distractTotal + 1
			} else {
				#targetCorrect <- targetCorrect + 1
				i<- 1
				while ( i <= Length( testVals ) )
				{
					if ( Nth( testVals, i ) == Nth( userInput, i ) )
					{
						targetCorrect <- targetCorrect + 1
					}

					i<- i + 1
				}
			}
		}

		text<-""

		if ( distractTotal > 0 )
		{
			if ( targetTotal > 0 )
			{
				text<-gFeedbackDT
			} else
			{
				text<-gFeedbackDOnly
			}
		} elseif( targetTotal > 0 )
		{
			text<-gFeedbackTOnly
		}
		if ( text != "" )
		{
			text <- SubstituteStrings(text, [["%CORRECT_T%", targetCorrect], ["%CORRECT_D%", distractCorrect], ["%NUM_T%", targetTotal], ["%NUM_D%", distractTotal]])
			PresentStatic( gFeedbackTimeout, 1, text, 0 )
		}
	}
	return rval
}

## SYMSPAN-SPECIFIC: Added padFaces parameter for highlighting
define GetMouseInput( clickable, values, keyLabels, selLabels, padFaces )
{
	ShowCursor(1)
	SetMouseCursorPosition(Round(gLayout.centerX), Round(gLayout.centerY))

	## Create index list for WaitForClickOnTarget to return indices instead of values
	indices <- Sequence(1, Length(clickable), 1)

	## Find indices of control buttons
	idxDone <- FindFirstIndex( values, gDoneKeyText )
	idxClear <- FindFirstIndex( values, gClearKeyText )
	idxDel <- FindFirstIndex( values, gDelKeyText )

	SetFont( Nth(keyLabels, idxDone),	gLgFont_Disabled )
	SetFont( Nth(keyLabels, idxClear),	gLgFont_Disabled )
	SetFont( Nth(keyLabels, idxDel),	gLgFont_Disabled )
	Draw()

	if ( idxDone < 1 or idxClear < 1 or idxDel < 1 )
	{
		SignalFatalError( "Couldn't find control keys!" )
	}

	rval<-[]
	done<-0
	while ( done == 0 )
	{
		## Get clicked index directly from WaitForClickOnTarget
		respIdx<-GetKBInput( clickable, indices )
		respValue <- Nth( values, respIdx )

		if ( respValue == gDoneKeyText )
		{
			# only valid if all values have been filled in
			if ( Length( rval) == Length(selLabels))
			{
				done <- 1
			}
		} elseif( respValue == gClearKeyText )
		{
			if ( Length( rval ) > 0 )
			{
				# only valid if we have some values
				# - clear them all
				# first re-enable any that've been disabeld
				loop( sel, rval )
				{
					idx<-FindFirstIndex( values, sel )
					if ( idx > 0 )
					{
						SetFont( Nth( keyLabels, idx ), gLgFont )
					}
				}
				rval<-[]

				# disable all control buttons
				SetFont( Nth(keyLabels, idxDone),	gLgFont_Disabled )
				SetFont( Nth(keyLabels, idxClear),	gLgFont_Disabled )
				SetFont( Nth(keyLabels, idxDel),	gLgFont_Disabled )

				# remove all selLabel text
				loop( sl, selLabels )
				{
					SetText( sl, gNoSelectionChar )
				}
				# finally re-draw
				Draw()
			}
		} elseif( respValue == gDelKeyText )
		{
			if ( Length( rval ) > 0 )
			{
				# only valid if we have some values
				# - delete the last character selected

				# re-enable it's selection in keypad
				deleted<-Last( rval )
				idx<-FindFirstIndex( values, deleted )
				if ( idx > 0 )
				{
					SetFont( Nth( keyLabels, idx), gLgFont )
				}

				# remove from selection & rval
				SetText( Nth(selLabels, Length(rval)), gNoSelectionChar )
				rval<-RemoveSubset(rval, List(Length(rval)))

				# definitely can't be done
				SetFont( Nth(keyLabels, idxDone),	gLgFont_Disabled )
				# may still be able to clear or delete
				if ( Length( rval ) == 0 )
				{
					SetFont( Nth(keyLabels, idxClear),	gLgFont_Disabled )
					SetFont( Nth(keyLabels, idxDel),	gLgFont_Disabled )
				}

				#finally draw
				Draw()
			}
		} elseif ( Length( rval ) < Length( selLabels ) )
		{
			if ( respValue == gBlankKeyText )
			{
				# is blank key
				rval<-Append(rval, gUnknownValue )
				SetText( Nth(selLabels, Length(rval)), gUnknownValue )
			} elseif ( FindFirstIndex( rval, respValue ) == 0 )
			{
				# Not already selected
				rval<-Append(rval, respValue )
				SetText( Nth(selLabels, Length(rval)), respValue )
				if ( gDisableGridSelections <> 0 )
				{
					SetFont( Nth( keyLabels, respIdx), gLgFont_Disabled )
				}
				## SYMSPAN-SPECIFIC: Highlight selected face if enabled
				if ( gSymSpanHighlightPickedFaces <> 0 and Length(padFaces) > 0 )
				{
					if ( respIdx > 0 and respIdx <= Length(padFaces) )
					{
						face <- Nth( padFaces, respIdx )
						face.color <- gSymShownTargetColor
					}
				}
			}
			# enable done if appropriate
			if ( Length( rval ) == Length( selLabels ) )
			{
				SetFont( Nth( keyLabels, idxDone ), gLgFont )
			}
			# always try to enable these even though it may be a no-op
			SetFont( Nth( keyLabels, idxClear ), gLgFont )
			SetFont( Nth( keyLabels, idxDel ), gLgFont )
			Draw()
		}
	} 

	return rval
}

define DrawDebug(val)
{
	if ( val == 1 )
	{
		gDebugLab1<-MakeLabel("gVideoWidth="+gVideoWidth, gDbgFont)
		AddObject( gDebugLab1, gWin )
		Move( gDebugLab1, 100, 10 )

		gDebugLab2<-MakeLabel("gVideoHeight="+gVideoHeight, gDbgFont)
		Move( gDebugLab2, 110, 30 )
		AddObject( gDebugLab2, gWin )

		gYAxis<-ThickLine(gVideoWidth/2, 0, gVideoWidth/2, gVideoHeight, 2, gDbgColor )
		AddObject( gYAxis, gWin )

		gXAxis<-ThickLine(0, gVideoHeight/2, gVideoWidth, gVideoHeight/2, 2, gDbgColor )
		AddObject( gXAxis, gWin )
	}
	return val
}

define CheckArgs()
{

	gFeedbackTimeout <- gParams.feedbacktimeout
	gDistractionFile <- gParams.distractfile
        gBatteryThreshold <- gParams.batterythreshold
	gBatteryFeedback <- gParams.batteryfeedback
        gDistractTimeoutMinimum <- gParams.distracttimeoutminimum
  	gDistractTimeoutMultiplier<-  gParams.distracttimeoutmultiplier

        gRequireThresholdPreBattery <- gParams.requirethresholdprebattery
	gAllowSecondChance <- gParams.allowsecondchance

	gTestReps <- gParams.testreps
	gTestMinSize <- gParams.testminsize
	gTestMaxSize <- gParams.testmaxsize

	if ( gBatteryThreshold >= 1 )
	{
           SignalFatalError( "BatteryThreshold must be less than 1"+gBatteryThreshold )
	}

	if ( gDistractTimeoutMinimum < 100 )
	{
          SignalFatalError( "Invalid gDistractTimeoutMinium: " +gDistractTimeoutMinimum)
	}
	if(gDistractTimeoutMultiplier < 1)
	{
   	   SignalFatalError( "Invalid gDistractMultiplier: " +gDistractTimoutMultiplier )
	}

	## Validate test battery parameters
	maxMemorySize <- gGridNumCol * gGridNumRow
	if(gTestMinSize < 2)
	{
		SignalFatalError("testminsize must be at least 2 (got " + gTestMinSize + ")")
	}
	if(gTestMaxSize > maxMemorySize)
	{
		SignalFatalError("testmaxsize cannot exceed memory pool size of " + maxMemorySize + " (got " + gTestMaxSize + ")")
	}
	if(gTestMinSize > gTestMaxSize)
	{
		SignalFatalError("testminsize (" + gTestMinSize + ") cannot be greater than testmaxsize (" + gTestMaxSize + ")")
	}
	if(gTestReps < 1)
	{
		SignalFatalError("testreps must be at least 1 (got " + gTestReps + ")")
	}

}

