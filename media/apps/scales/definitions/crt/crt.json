{
  "scale_info": {
    "name": "Cognitive Reflection Test",
    "code": "crt",
    "version": "1.0",
    "citation": "Frederick, S. (2005). Cognitive reflection and decision making. Journal of Economic Perspectives, 19(4), 25-42.",
    "description": "3-item test measuring the tendency to override an incorrect intuitive response and engage in further reflection",
    "url": "https://doi.org/10.1257/089533005775196732"
  },

  "parameters": {
    "shuffle_questions": {
      "type": "boolean",
      "default": 0,
      "description": "Randomize question order"
    }
  },

  "dimensions": [
    {
      "id": "reflection",
      "name": "Cognitive Reflection",
      "enabled_param": null
    }
  ],

  "questions": [
    {
      "id": "inst1",
      "text_key": "inst1",
      "type": "inst"
    },
    {
      "id": "q1",
      "text_key": "q1",
      "type": "short",
      "maxlength": 20
    },
    {
      "id": "q2",
      "text_key": "q2",
      "type": "short",
      "maxlength": 20
    },
    {
      "id": "q3",
      "text_key": "q3",
      "type": "short",
      "maxlength": 20
    }
  ],

  "scoring": {
    "reflection": {
      "method": "sum_correct",
      "items": ["q1", "q2", "q3"],
      "description": "Number of correct responses (0-3)",
      "correct_answers": {
        "q1": ["5", "five", ".05", "0.05", "$0.05", "five cents", "5 cents", "5c"],
        "q2": ["5", "five"],
        "q3": ["47", "forty seven", "forty-seven"]
      }
    }
  },

  "report": {
    "template": "standard",
    "include": ["timestamp", "completion_time", "dimension_scores"],
    "header": "The Cognitive Reflection Test measures reflective thinking vs. intuitive thinking.",
    "footer_refs": [
      "Frederick, S. (2005). Cognitive reflection and decision making. Journal of Economic Perspectives, 19(4), 25-42.",
      "See https://doi.org/10.1257/089533005775196732 for more information."
    ]
  },

  "data_output": {
    "individual_file": "crt-{subnum}.csv",
    "pooled_file": "crt-pooled.csv",
    "report_file": "crt-report-{subnum}.html",
    "columns": "subnum,order,time,qnum,ques,dim,valence,resp,rt",
    "pooled_columns": "subnum,timestamp,time,q1,q2,q3,correct_count,reflection_score"
  }
}
