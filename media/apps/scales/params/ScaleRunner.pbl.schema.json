{
  "test": "ScaleRunner",
  "version": "1.0",
  "description": "Scale Runner - Psychological Scale Administration",
  "parameters": [
    {
      "name": "scale",
      "type": "select",
      "default": "sample",
      "options": [
        {"value": "sample", "label": "Sample Scale (demonstrates all question types)"},
        {"value": "bigfive", "label": "Big Five Personality Inventory (50 items)"}
      ],
      "description": "Select psychological scale to administer"
    },
    {
      "name": "shuffle_questions",
      "type": "boolean",
      "default": 0,
      "description": "Randomize question order within randomization groups (group 0 = fixed)"
    }
  ]
}
