    },
    {
      "name": "StimulusDuration",
      "type": "integer",
      "default": 2500,
      "description": "Presentation time of stimulus(ms)"
    },
    {
      "name": "numStimsAct",
      "type": "integer",
      "default": 12,
      "description": "Number of displayed stimulus by participant(max.12)"
    },
    {
      "name": "numStimsRest",
      "type": "integer",
      "default": 6,
      "description": "Number of rest stimulus '00+00'(max.6)"
    },
    {
      "name": "InstructionTextSize",
      "type": "integer",
      "default": 60,
      "description": "Text size for instructions"
    },
    {
      "name": "InstructionTextSize2",
      "type": "integer",
      "default": 25,
      "description": "Text size for instructions"
    },
    {
      "name": "TaskTextSize",
      "type": "integer",
      "default": 65,
      "description": "Text size  for task"
    },
    {
      "name": "InstructionDisplayTime",
      "type": "integer",
      "default": 5,
      "description": "Display time of instructions with countdown"
    },
    {
      "name": "responsemode",
      "type": "string",
      "default": "auto",
      "description": "Response input mode",
      "enum": [
        "auto",
        "keyboardShift",
        "keyboardSafe",
        "arrowLR",
        "mousetarget",
        "touchtarget",
        "mousebutton"
      ]
    }
  ]
