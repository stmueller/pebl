{
  "test": "dualtask",
  "version": "2.0",
  "description": "Dual-Task Interference Test - Measures multi-task performance and interference effects",
  "parameters": [
    {
      "name": "numrounds",
      "type": "integer",
      "default": 4,
      "label": "Number of Rounds",
      "description": "Number of complete round-robins (pure1, pure2, dual)",
      "min": 1,
      "max": 10
    },
    {
      "name": "trialsperblock",
      "type": "integer",
      "default": 25,
      "label": "Trials Per Block",
      "description": "Number of trials in each block",
      "min": 10,
      "max": 100
    },
    {
      "name": "smallsize",
      "type": "integer",
      "default": 65,
      "label": "Small Stimulus Size",
      "description": "Size in pixels for small stimuli",
      "min": 30,
      "max": 200
    },
    {
      "name": "largesize",
      "type": "integer",
      "default": 160,
      "label": "Large Stimulus Size",
      "description": "Size in pixels for large stimuli",
      "min": 50,
      "max": 300
    },
    {
      "name": "doyoked",
      "type": "boolean",
      "default": 0,
      "label": "Include Yoked Trials",
      "description": "Include yoked dual-task trials (respond simultaneously)",
      "options": [0, 1]
    },
    {
      "name": "stimtype",
      "type": "select",
      "default": 4,
      "label": "Stimulus Type",
      "description": "Type of visual stimulus",
      "options": [
        {"value": 1, "label": "Circle/Square + Size"},
        {"value": 2, "label": "Arrow Direction + Size"},
        {"value": 3, "label": "Double Arrows (no offset)"},
        {"value": 4, "label": "Double Arrows (offset)"}
      ]
    },
    {
      "name": "type4offset",
      "type": "integer",
      "default": 40,
      "label": "Type 4 Offset",
      "description": "Horizontal offset for type 4 stimuli (pixels)",
      "min": 0,
      "max": 100
    },
    {
      "name": "dim1keys",
      "type": "array",
      "default": ["1", "2"],
      "label": "Dimension 1 Keys",
      "description": "Response keys for dimension 1 (left hand)",
      "hidden": true
    },
    {
      "name": "dim2keys",
      "type": "array",
      "default": ["9", "0"],
      "label": "Dimension 2 Keys",
      "description": "Response keys for dimension 2 (right hand)",
      "hidden": true
    },
    {
      "name": "responsemode",
      "type": "string",
      "default": "none",
      "label": "Response Mode",
      "description": "Layout response mode (none for custom handling)",
      "hidden": true
    }
  ]
}
