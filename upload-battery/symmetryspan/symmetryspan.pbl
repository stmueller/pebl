## Execute the task using list-based system

## SYMSPAN-SPECIFIC: LoadDistractionTasks loads images instead of text
define LoadDistractionTasks( a_File )
{
	Print( "Loading distraction tasks from " + a_File +"...")

	## Use ReadCSV() for proper CSV parsing with quote handling
	table <- ReadCSV( a_File )

	if ( Length( table ) == 0 )
	{
		SignalFatalError( "No distraction tasks loaded from " + a_File )
	}

	rval <- []
	loop( row, table )
	{
		if(Length(row) < 3)
		{
			SignalFatalError( "Invalid Distraction Spec (need 3 columns): " + row )
		}

		imageFile <- StripSpace(Nth(row, 1))
		answer <- StripSpace(Nth(row, 2))
		isTF <- Lowercase(StripSpace(Nth(row, 3)))

		## Validate fields
		if(StringLength(imageFile) < 1)
		{
			SignalFatalError( "Invalid Distraction Spec (empty image file)" )
		}
		if(StringLength(answer) < 1)
		{
			SignalFatalError( "Invalid Distraction Spec (empty answer)" )
		}

		## Parse true/false value
		tfValue <- Nth( SplitString( isTF, "" ), 1 )
		if ( tfValue == "t" )
		{
			tfValue <- 1
		} elseif ( tfValue == "f" )
		{
			tfValue <- 0
		} else {
			SignalFatalError( "Invalid Distraction Spec (expected t or f): " + isTF )
		}

		## SYMSPAN-SPECIFIC: Load image instead of storing text
		im <- MakeImage( imageFile )
		rval <- Append( rval, [im, answer, tfValue] )
	}

	Print( "Loaded " + Length(rval) + " distraction tasks" )
	return rval
}

define GetKBInput( kb, value_map )
{
	rval<- WaitForClickOnTarget(  kb, value_map )

	return rval
}

## SYMSPAN-SPECIFIC: Added hideText parameter and keyFaces return
define MakeSqKB(win, keys,  kbLeft, kbTop, nCol, keySz, spc, hideText  )
{
	return MakeKB( win, keys,  kbLeft, kbTop, nCol, keySz, keySz, spc, hideText  )
}

## SYMSPAN-SPECIFIC: Added hideText parameter and keyFaces return
define MakeKB(win, keys,  kbLeft,kbTop, nCol, keyWidth, keyHeight, spc, hideText  )
{
	border<-4

	cellWidth<-keyWidth+spc
	cellHeight<-keyHeight+spc

	xExtent<-kbLeft
	yExtent<-kbTop
	clickable <- []
	labels<-[]
	stuff <- []
	keyFaces <- []  ## SYMSPAN-SPECIFIC: Track colored rectangles
	i<-1
	loop(aKey,keys)
	{
		colnum <- Mod( i-1, nCol )
		rownum <- Floor( (i-1)/nCol )
		i<-i+1

		back1 <- Rectangle(kbLeft+colnum*cellWidth,kbTop+rownum*cellHeight,keyWidth, keyHeight,gKeyBorder,1)
		keyFace <- Rectangle(kbLeft+colnum*cellWidth,kbTop+rownum*cellHeight,keyWidth-4,keyHeight-4, gKeyFace,1)

		## SYMSPAN-SPECIFIC: Hide text labels for grid display
		if ( hideText==1 ) {
			lab <- MakeLabel("",gLgFont)
		} else {
			lab <- MakeLabel(aKey,gLgFont)
		}

		AddObject(back1,win)
		AddObject(keyFace,win)
		AddObject(lab,win)
		x<-kbLeft+colnum*cellWidth
		y<-kbTop+rownum*cellHeight
		Move(lab,x,y)
		if ( x > xExtent ) { xExtent <- x }
		if ( y > yExtent ) { yExtent <- y }
		clickable <- Append(clickable,back1)
		stuff <- Append(stuff,[lab,back1,keyFace])
		labels <- Append(labels, lab)
		keyFaces <- Append( keyFaces, keyFace )  ## SYMSPAN-SPECIFIC
	}
	Draw()

	## SYMSPAN-SPECIFIC: Return keyFaces as 7th element
	return [clickable,xExtent,yExtent, cellWidth, Flatten(stuff), labels, keyFaces]
}

define GetClickable( kb )
{
	return Nth(kb, 1)
}

define GetLabels( kb )
{
	return Nth(kb, 6)
}

## SYMSPAN-SPECIFIC: Extract keyFaces from keyboard
define GetKeyFaces( kb )
{
	return Nth(kb, 7)
}

define DestroyKB(win,kb)
{
	loop( obj, Flatten( Nth(kb, 5 ) ) )
	{
		RemoveObject( obj, win)
	}

}


## SYMSPAN-SPECIFIC: Load symmetryspan translations
define GetStrings(lang)
{
  lang <- Uppercase(lang)
  fname <- "translations/symmetryspan.pbl-" + Lowercase(lang) + ".json"

  if(FileExists(fname))
  {
    gStrings <- ReadTranslationJSON(fname, lang)
  } else {
    gStrings <- ReadTranslationJSON("translations/symmetryspan.pbl-en.json", lang)
  }

  ## Set UI strings from translations
  gReadyText <- gStrings.ready_prompt
  gContinueText <- gStrings.click_prompt
  gDoneKeyText <- gStrings.button_done
  gClearKeyText <- gStrings.button_clear
  gDelKeyText <- gStrings.button_del
  gBlankKeyText <- gStrings.button_blank
}


