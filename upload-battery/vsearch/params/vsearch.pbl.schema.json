{
  "test": "vsearch",
  "version": "1.0",
  "description": "VSEARCH Test",
  "parameters": [
    {
      "name": "boxwidth",
      "type": "integer",
      "default": 600,
      "description": "Width in pixels of search box"
    },
    {
      "name": "boxheight",
      "type": "integer",
      "default": 400,
      "description": "height in pixels of search box"
    },
    {
      "name": "targs",
      "type": "string",
      "default": "OX",
      "description": "Text string of target symbols"
    },
    {
      "name": "foils",
      "type": "string",
      "default": "UDGCQ",
      "description": "Text string of foil symbols"
    },
    {
      "name": "searchsizes",
      "type": "list",
      "default": [10,20,30],
      "description": "Search array sizes (list of integers)"
    },
    {
      "name": "numtargs",
      "type": "list",
      "default": [0,1,5],
      "description": "Number of targets conditions (list of integers)"
    },
    {
      "name": "targcols",
      "type": "list",
      "default": ["white","green"],
      "description": "Target colors (list of color names)"
    },
    {
      "name": "foilcolor",
      "type": "string",
      "default": "white",
      "description": "Foil color"
    },
    {
      "name": "reps",
      "type": "integer",
      "default": 5,
      "description": "Number of repetitions for whole design."
    }
  ]
}
