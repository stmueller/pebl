## Define the task structure using PEBL native lists
define DefineTaskStructure()
{
  Print("Defining task structure...")

  ## Practice Letter Memory Only (no math)
  gPracticeMemory <- [
    ["memory_only", 2, 1000, 1],  ## numLetters, letterDuration, showFeedback
    ["memory_only", 2, 1000, 1],
    ["memory_only", 3, 1000, 1],
    ["memory_only", 3, 1000, 1]
  ]

  ## Practice Math Only (no letters) - 15 trials alternating 1-2 problems
  gPracticeMath <- [
    ["math_only", 1, 1],  ## numProblems, showFeedback
    ["math_only", 2, 1],
    ["math_only", 1, 1],
    ["math_only", 2, 1],
    ["math_only", 1, 1],
    ["math_only", 2, 1],
    ["math_only", 1, 1],
    ["math_only", 2, 1],
    ["math_only", 1, 1],
    ["math_only", 2, 1],
    ["math_only", 1, 1],
    ["math_only", 2, 1],
    ["math_only", 1, 1],
    ["math_only", 2, 1],
    ["math_only", 1, 1]
  ]

  ## Practice Both (with criteria checking)
  ## Format: ["battery", reps, setSizes, letterDuration, showFeedback, mathThreshold]
  ## Following Unsworth et al. (2005) pattern: 3 practice trials of set size 2
  gPracticeBoth <- [
    ["battery", 3, [2], 650, 1, gBatteryThreshold]
  ]

  ## Main Test Battery
  ## Generate set sizes from parameters
  testSizes <- Sequence(gTestMinSize, gTestMaxSize, 1)
  gTestBattery <- [
    ["battery", gTestReps, testSizes, 650, 0, gBatteryThreshold]
  ]

  Print("Task structure defined")
  Print("Test battery: " + gTestReps + " reps of sizes " + testSizes)
}


## Extract images from text with <img>path</img> tags
## Returns [cleanedText, imagePath]
## If no image found, returns [originalText, ""]
define ExtractImages(text)
{
  cleanedText <- text
  imagePath <- ""

  ## Find <img> tag
  imgStart <- FindInString(text, "<img>", 1)

  if(imgStart > 0)
  {
    ## Find </img> tag
    imgEnd <- FindInString(text, "</img>", imgStart)

    if(imgEnd > 0)
    {
      ## Extract image path (between <img> and </img>)
      ## SubString uses (start, length) not (start, end)
      pathStart <- imgStart + 5
      pathLength <- imgEnd - pathStart
      imagePath <- SubString(text, pathStart, pathLength)

      ## Concatenate text before and after the image tag
      beforeLength <- imgStart - 1
      if(beforeLength > 0)
      {
        beforeImg <- SubString(text, 1, beforeLength)
      } else {
        beforeImg <- ""
      }

      afterStart <- imgEnd + 6
      afterLength <- StringLength(text) - afterStart + 1
      if(afterLength > 0)
      {
        afterImg <- SubString(text, afterStart, afterLength)
      } else {
        afterImg <- ""
      }

      cleanedText <- beforeImg + afterImg
    }
  }

  return([cleanedText, imagePath])
}


## Show instruction from gStrings
## Handles special case: if text contains <img>path</img> tags, displays the image
define ShowInstruction(key, timeout)
{
  ## Look up instruction text from gStrings
  key <- Lowercase(key)
  text <- GetProperty(gStrings, key)

  if(text == "")
  {
    SignalFatalError("Unknown instruction key: " + key)
  }

  ## Extract any embedded images
  extracted <- ExtractImages(text)
  cleanedText <- First(extracted)
  imagePath <- Second(extracted)

  ## Check if we found an image
  if(imagePath != "")
  {
    ## Load and display the image
    practiceImage <- MakeImage(imagePath)
    AddObject(practiceImage, gWin)
    Move(practiceImage, gLayout.centerX, gLayout.centerY - 100)

    ## Create textbox for the instruction text below image
    fontSize <- Round(gLgFontSz * 1.25)
    baseFont <- MakeFont(gPEBLBaseFont, 0, fontSize, gFGColor, gBGColor, 0)
    boxWidth <- Floor(gVideoWidth * 0.8)
    textbox <- MakeTextBox(cleanedText, baseFont, boxWidth, 300)
    SetProperty(textbox, "FORMATTED", 1)
    SetProperty(textbox, "ISADAPTIVE", 1)
    AddObject(textbox, gWin)
    boxX <- gLayout.centerX - boxWidth/2
    boxY <- gLayout.centerY + 100
    Move(textbox, boxX, boxY)
    Draw()

    ## Show Next button
    spc <- 50
    keyHeight <- 1.9 * gLgFontSz
    keyWidth <- 3 * keyHeight
    btnX <- gLayout.centerX
    btnY <- gLayout.zones.footer.y + 50
    kb <- MakeKB(gWin, [gStrings.button_next], btnX, btnY, 1, keyWidth, keyHeight, spc, 0)
    resp <- GetKBInput(GetClickable(kb), ["whatevs"])
    DestroyKB(gWin, kb)

    ## Clean up
    RemoveObject(textbox, gWin)
    RemoveObject(practiceImage, gWin)

  } else {
    ## Normal instruction - show using PresentStatic
    PresentStatic(timeout, 0, text, 0)
  }
}


## Run a memory-only trial (letters, no math)
define RunMemoryTrial(numLetters, duration, feedback)
{
  ## Build stages list - just letters
  stages <- Repeat("T", numLetters)

  ## Use existing PresentRun but with no math
  result <- PresentRun(-1, duration, numLetters, stages, feedback)

  ## Log practice trial
  ProcessRunResult(stages, result, 1, [-1, duration, numLetters])

  return result
}


## Run a math-only trial (math problems, no letters)
## Returns [result, mathCorrect, mathTotal, mathAccuracy]
define RunMathTrial(numProblems, feedback)
{
  ## Build stages list - just distraction tasks
  stages <- Repeat("D", numProblems)

  ## Use existing PresentRun but with no letters
  result <- PresentRun(-1, 0, 0, stages, feedback)

  ## Log practice trial
  ProcessRunResult(stages, result, 1, [-1, 0, 0])

  ## Calculate math statistics from this trial
  mathCorrect <- 0
  mathTotal <- 0
  loop(item, result)
  {
    if(First(item) == "D")
    {
      mathTotal <- mathTotal + 1
      if(Nth(item, 2) == 1)  ## 1 = correct
      {
        mathCorrect <- mathCorrect + 1
      }
    }
  }

  ## Calculate accuracy
  if(mathTotal > 0)
  {
    mathAccuracy <- mathCorrect / mathTotal
  } else {
    mathAccuracy <- 0
  }

  ## Return list: [result, mathCorrect, mathTotal, mathAccuracy]
  return [result, mathCorrect, mathTotal, mathAccuracy]
}


## Check if math performance meets criteria
define CheckMathCriteria(threshold)
{
  if(gTotNumDistract == 0)
  {
    rval <- 1  ## No practice yet, allow to proceed
  } else {
    accuracy <- gNumCorrectDistract / gTotNumDistract
    rval <- accuracy >= threshold
  }

  return rval
}


## Update accuracy and trial counter labels with current information
define UpdateStatusLabels(currentTrial, totalTrials)
{
  if(gAccuracyLabel != 0)
  {
    ## Calculate current accuracy percentage
    if(gTotNumDistract > 0)
    {
      accuracy <- Round((gNumCorrectDistract / gTotNumDistract) * 100)
      SetText(gAccuracyLabel, "Accuracy: " + accuracy + "%")
    } else {
      SetText(gAccuracyLabel, "Accuracy: 0%")
    }
  }

  if(gTrialCounterLabel != 0)
  {
    SetText(gTrialCounterLabel, "Test " + currentTrial + "/" + totalTrials)
  }

  if(gAccuracyLabel != 0 or gTrialCounterLabel != 0)
  {
    Draw()
  }
}


## Calculate math timeout based on practice performance
define CalculateMathTimeout()
{
  if(Length(gTimesDistract) == 0)
  {
    Print("DEBUG: No practice times available, using minimum timeout: " + gDistractTimeoutMinimum)
    rval <- gDistractTimeoutMinimum
  } else {
    avgTime <- Mean(gTimesDistract)
    sdTime <- StdDev(gTimesDistract)
    timeout <- avgTime + (gDistractTimeoutMultiplier * sdTime)
    rval <- Max([timeout, gDistractTimeoutMinimum])

    Print("DEBUG: gTimesDistract = " + gTimesDistract)
    Print("DEBUG: Mean time = " + avgTime + " ms, SD = " + sdTime + " ms")
    Print("DEBUG: Multiplier = " + gDistractTimeoutMultiplier)
    Print("DEBUG: Calculated timeout = " + timeout + " ms")
    Print("DEBUG: Final timeout (max with minimum) = " + rval + " ms")
  }

  ## Round to integer for RegisterEvent compatibility
  return Round(rval)
}


## Generate trial sequence for battery
define GenerateTrialSequence(reps, setSizes)
{
  ## Create a flat list with 'reps' of each set size
  trialList <- Flatten(ShuffleRepeat(setSizes, reps))

  return trialList
}


## Run a battery of trials
## Returns [results, mathCorrect, mathTotal, mathAccuracy]
define RunBatteryBlock(reps, setSizes, letterDuration, showFeedback, mathThreshold, phaseType)
{
  ## Calculate math timeout from practice performance
  Print("DEBUG: ========== Starting " + phaseType + " battery ==========")
  Print("DEBUG: Total practice trials recorded: " + Length(gTimesDistract))
  mathTimeout <- CalculateMathTimeout()
  Print("DEBUG: Math timeout set to: " + mathTimeout + " ms for " + phaseType + " phase")

  ## Create status labels for test phase
  if(phaseType == "test")
  {
    ## Create blue font 50% bigger for status labels
    blueColor <- MakeColor("blue")
    labelFontSize <- Round(gLgFontSz * 1.5)
    statusFont <- MakeFont(gPEBLBaseFont, 0, labelFontSize, blueColor, gBGColor, 0)

    ## Create accuracy label
    gAccuracyLabel <- MakeLabel("Accuracy: 0%", statusFont)
    AddObject(gAccuracyLabel, gWin)

    ## Position accuracy label in subheader zone on the right
    accLabelX <- gVideoWidth - 150  ## More space from right for longer text
    accLabelY <- gLayout.zones.subheader.y - 5
    Move(gAccuracyLabel, accLabelX, accLabelY)

    ## Create trial counter label
    gTrialCounterLabel <- MakeLabel("Test 0/0", statusFont)
    AddObject(gTrialCounterLabel, gWin)

    ## Position trial counter label below accuracy label
    trialLabelX <- gVideoWidth - 150
    trialLabelY <- accLabelY + labelFontSize + 5
    Move(gTrialCounterLabel, trialLabelX, trialLabelY)

    Draw()

    Print("Status labels created at (" + accLabelX + ", " + accLabelY + ")")
  }

  ## Generate trial sequence
  trialList <- GenerateTrialSequence(reps, setSizes)
  Print("Trial sequence: " + trialList)
  totalTrials <- Length(trialList)

  ## Run trials
  results <- []
  batteryMathCorrect <- 0
  batteryMathTotal <- 0
  currentTrialNum <- 0

  loop(setSize, trialList)
  {
    currentTrialNum <- currentTrialNum + 1

    ## Update status labels for test phase BEFORE running trial
    if(phaseType == "test")
    {
      UpdateStatusLabels(currentTrialNum, totalTrials)
    }

    ## Build stages: alternating D and T
    stages <- []
    loop(i, Sequence(1, setSize, 1))
    {
      stages <- Append(stages, "D")
      stages <- Append(stages, "T")
    }

    ## Run the trial
    result <- PresentRun(mathTimeout, letterDuration, setSize, stages, showFeedback)
    results <- Append(results, result)

    ## Count math performance in this trial
    loop(item, result)
    {
      if(First(item) == "D")
      {
        batteryMathTotal <- batteryMathTotal + 1
        if(Nth(item, 2) == 1)  ## 1 = correct
        {
          batteryMathCorrect <- batteryMathCorrect + 1
        }
      }
    }

    ## Log to file
    ProcessRunResult(stages, result, 1, [mathTimeout, letterDuration, setSize])

    gTrial <- gTrial + 1
  }

  ## Calculate accuracy
  if(batteryMathTotal > 0)
  {
    batteryMathAccuracy <- batteryMathCorrect / batteryMathTotal
  } else {
    batteryMathAccuracy <- 0
  }

  ## Remove status labels for test phase
  if(phaseType == "test")
  {
    if(gAccuracyLabel != 0)
    {
      RemoveObject(gAccuracyLabel, gWin)
      gAccuracyLabel <- 0
    }
    if(gTrialCounterLabel != 0)
    {
      RemoveObject(gTrialCounterLabel, gWin)
      gTrialCounterLabel <- 0
    }
    Draw()
    Print("Status labels removed")
  }

  ## Return list: [results, mathCorrect, mathTotal, mathAccuracy]
  return [results, batteryMathCorrect, batteryMathTotal, batteryMathAccuracy]
}


## Execute a block of tasks
## Returns [results, mathCorrect, mathTotal, mathAccuracy]
define ExecuteTaskBlock(block, phaseType)
{
  Print("Executing task block: " + phaseType)

  LSLMarker("block_" + phaseType + "_start")

  results <- []
  blockMathCorrect <- 0
  blockMathTotal <- 0

  loop(task, block)
  {
    taskType <- First(task)

    if(taskType == "instruction")
    {
      instructKey <- Nth(task, 2)
      timeout <- -1
      if(Length(task) > 2)
      {
        timeout <- Nth(task, 3)
      }
      ShowInstruction(instructKey, timeout)

    } elseif(taskType == "memory_only")
    {
      numLetters <- Nth(task, 2)
      letterDuration <- Nth(task, 3)
      showFeedback <- Nth(task, 4)
      result <- RunMemoryTrial(numLetters, letterDuration, showFeedback)
      results <- Append(results, result)
      ## gTrial is incremented inside RunMemoryTrial

    } elseif(taskType == "math_only")
    {
      numProblems <- Nth(task, 2)
      showFeedback <- Nth(task, 3)
      trialStats <- RunMathTrial(numProblems, showFeedback)
      results <- Append(results, trialStats)

      ## Accumulate math statistics from this trial
      ## trialStats format: [result, mathCorrect, mathTotal, mathAccuracy]
      blockMathCorrect <- blockMathCorrect + Nth(trialStats, 2)
      blockMathTotal <- blockMathTotal + Nth(trialStats, 3)
      ## gTrial is incremented inside RunMathTrial

    } elseif(taskType == "battery")
    {
      ## Extract parameters from battery task definition
      ## Format: ["battery", reps, setSizes, letterDuration, showFeedback, mathThreshold]
      reps <- Nth(task, 2)
      setSizes <- Nth(task, 3)
      letterDuration <- Nth(task, 4)
      showFeedback <- Nth(task, 5)
      mathThreshold <- Nth(task, 6)
      batteryStats <- RunBatteryBlock(reps, setSizes, letterDuration, showFeedback, mathThreshold, phaseType)
      results <- Append(results, batteryStats)

      ## Accumulate math statistics from battery
      ## batteryStats format: [results, mathCorrect, mathTotal, mathAccuracy]
      blockMathCorrect <- blockMathCorrect + Nth(batteryStats, 2)
      blockMathTotal <- blockMathTotal + Nth(batteryStats, 3)
    } else {
      SignalFatalError("Unknown task type: " + taskType)
    }
  }

  ## Calculate block accuracy
  if(blockMathTotal > 0)
  {
    blockMathAccuracy <- blockMathCorrect / blockMathTotal
  } else {
    blockMathAccuracy <- 0
  }

  LSLMarker("block_" + phaseType + "_end")

  ## Return list: [results, mathCorrect, mathTotal, mathAccuracy]
  return [results, blockMathCorrect, blockMathTotal, blockMathAccuracy]
}


