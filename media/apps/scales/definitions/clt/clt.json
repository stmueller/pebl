{
  "scale_info": {
    "name": "Cognitive Load Theory Questionnaire",
    "code": "clt",
    "abbreviation": "CLT",
    "description": "15-item scale measuring three types of cognitive load during learning",
    "citation": "Krieglstein, F., Beege, M., Rey, G. D., Sanchez-Stockhammer, C., & Schneider, S. (2023). Development and validation of a theory-based questionnaire to measure different types of cognitive load. Educational Psychology Review, 35(1), 37. https://doi.org/10.1007/s10648-023-09738-0",
    "license": "Creative Commons Attribution 4.0 (CC BY 4.0)",
    "license_url": "https://creativecommons.org/licenses/by/4.0/",
    "version": "1.0",
    "url": "https://doi.org/10.1007/s10648-023-09738-0"
  },

  "parameters": {
    "shuffle_questions": {
      "type": "boolean",
      "default": 0,
      "description": "Randomize question order"
    }
  },

  "likert_options": {
    "points": 9,
    "question_head": "question_head",
    "labels": ["likert_1", "likert_2", "likert_3", "likert_4", "likert_5", "likert_6", "likert_7", "likert_8", "likert_9"]
  },

  "dimensions": [
    {
      "id": "ICL",
      "name": "Intrinsic Cognitive Load",
      "abbreviation": "ICL",
      "description": "Cognitive load imposed by the inherent difficulty of the learning content",
      "enabled_param": null
    },
    {
      "id": "ECL",
      "name": "Extraneous Cognitive Load",
      "abbreviation": "ECL",
      "description": "Cognitive load imposed by the design of the learning material",
      "enabled_param": null
    },
    {
      "id": "GCL",
      "name": "Germane Cognitive Load",
      "abbreviation": "GCL",
      "description": "Cognitive load associated with actively processing and understanding the material",
      "enabled_param": null
    }
  ],

  "questions": [
    {
      "id": "inst1",
      "text_key": "inst1",
      "type": "inst",
      "dimension": null,
      "coding": 0
    },
    {
      "id": "icl1",
      "text_key": "icl1",
      "type": "likert",
      "dimension": "ICL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "icl2",
      "text_key": "icl2",
      "type": "likert",
      "dimension": "ICL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "icl3",
      "text_key": "icl3",
      "type": "likert",
      "dimension": "ICL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "icl4",
      "text_key": "icl4",
      "type": "likert",
      "dimension": "ICL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "icl5",
      "text_key": "icl5",
      "type": "likert",
      "dimension": "ICL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "ecl1",
      "text_key": "ecl1",
      "type": "likert",
      "dimension": "ECL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "ecl2",
      "text_key": "ecl2",
      "type": "likert",
      "dimension": "ECL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "ecl3",
      "text_key": "ecl3",
      "type": "likert",
      "dimension": "ECL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "ecl4",
      "text_key": "ecl4",
      "type": "likert",
      "dimension": "ECL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "ecl5",
      "text_key": "ecl5",
      "type": "likert",
      "dimension": "ECL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "gcl1",
      "text_key": "gcl1",
      "type": "likert",
      "dimension": "GCL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "gcl3",
      "text_key": "gcl3",
      "type": "likert",
      "dimension": "GCL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "gcl5",
      "text_key": "gcl5",
      "type": "likert",
      "dimension": "GCL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "gcl6",
      "text_key": "gcl6",
      "type": "likert",
      "dimension": "GCL",
      "coding": 1,
      "likert_points": 9
    },
    {
      "id": "gcl7",
      "text_key": "gcl7",
      "type": "likert",
      "dimension": "GCL",
      "coding": 1,
      "likert_points": 9
    }
  ],

  "scoring": {
    "ICL": {
      "method": "mean_coded",
      "items": ["icl1", "icl2", "icl3", "icl4", "icl5"],
      "description": "Mean intrinsic cognitive load (1-9 scale)"
    },
    "ECL": {
      "method": "mean_coded",
      "items": ["ecl1", "ecl2", "ecl3", "ecl4", "ecl5"],
      "description": "Mean extraneous cognitive load (1-9 scale)"
    },
    "GCL": {
      "method": "mean_coded",
      "items": ["gcl1", "gcl3", "gcl5", "gcl6", "gcl7"],
      "description": "Mean germane cognitive load (1-9 scale)"
    }
  },

  "report": {
    "template": "standard",
    "include": ["timestamp", "completion_time", "dimension_scores"],
    "header": "The CLT Questionnaire measures three types of cognitive load experienced during learning.",
    "footer_refs": [
      "Krieglstein, F., Beege, M., Rey, G. D., Sanchez-Stockhammer, C., & Schneider, S. (2023). Development and validation of a theory-based questionnaire to measure different types of cognitive load. Educational Psychology Review, 35(1), 37.",
      "See <a href='https://doi.org/10.1007/s10648-023-09738-0'>https://doi.org/10.1007/s10648-023-09738-0</a> for more information.",
      "Licensed under <a href='https://creativecommons.org/licenses/by/4.0/'>Creative Commons Attribution 4.0 (CC BY 4.0)</a>"
    ]
  },

  "data_output": {
    "individual_file": "clt-{subnum}.csv",
    "pooled_file": "clt-pooled.csv",
    "report_file": "clt-report-{subnum}.html",
    "columns": "subnum,order,time,qnum,ques,dim,valence,resp,rt",
    "pooled_columns": "subnum,timestamp,time,icl1,icl2,icl3,icl4,icl5,ecl1,ecl2,ecl3,ecl4,ecl5,gcl1,gcl3,gcl5,gcl6,gcl7,ICL,ECL,GCL"
  }
}
